/* ===== THREAD CARD ===== */
.thread-card{background:transparent;border-radius:14px;padding:0;box-sizing:border-box;display:flex;flex-direction:column}
.thread-card__header{margin-bottom:16px;padding-bottom:12px;border-bottom:1px solid rgba(255,255,255,.15)}
.thread-card__header h3{font-family:var(--font-headline);font-size:1.05rem;font-weight:800;margin:0;color:#fff}
.thread-empty{color:#888;font-style:italic;font-size:.9rem;text-align:center;padding:32px 0}
.thread-list{display:flex;flex-direction:column;gap:16px}

/* ===== POST (thread item) ===== */
.post{background:#fff;border-radius:12px;padding:16px;border:1px solid #e8e8e8}
.post--alt{background:#f2ead9}
.post--child{margin-left:32px;border-left:3px solid #ff9900;border-radius:0 12px 12px 0;padding:14px 16px}
.post-header{display:flex;align-items:center;gap:8px;margin-bottom:6px;flex-wrap:wrap}
.post-tag{font-size:.6rem;font-weight:700;color:#fff;background:#ff9900;padding:3px 10px;border-radius:20px;text-transform:uppercase;letter-spacing:.8px}
.post-author{font-size:.88rem;font-weight:700;color:#333}
.post-date{font-size:.72rem;color:#bbb;margin-left:auto}
.post-del{background:none;border:none;cursor:pointer;font-size:.82rem;opacity:.3;padding:0;transition:opacity .2s}
.post-del:hover{opacity:1}
.post-body{font-size:.92rem;color:#333;margin:0 0 10px;line-height:1.6}
.post-actions{display:flex;gap:8px;align-items:center}

/* ===== VOTE BUTTONS ===== */
.th-vote{background:#fff;border:1.5px solid #e0e0e0;border-radius:20px;padding:4px 14px;font-size:.8rem;cursor:pointer;transition:all .2s;display:inline-flex;align-items:center;gap:4px}
.th-vote:hover{border-color:#ff9900;background:#fff8ee}
.th-vote--on{background:#fff3e0;border-color:#ff9900;font-weight:700}
.th-vote span{font-weight:600;font-size:.78rem}

/* ===== REPLY ===== */
.post-reply-btn{background:none;border:none;font-size:.8rem;color:#ff9900;cursor:pointer;font-weight:700;transition:color .2s}
.post-reply-btn:hover{color:#cc7a00;text-decoration:underline}
.post-reply-box{display:flex;gap:8px;margin-top:12px;padding-top:12px;border-top:1px solid #eee}
.post-reply-inp{flex:1}

/* ===== RESPONSIVE =====
   Mobile: whole lightbox scrolls as one unit, columns don't scroll internally.
   Overrides desktop flex/overflow architecture. */
@media(max-width:900px){
  .photo-grid{grid-template-columns:repeat(2,1fr)}
  .lightbox{height:auto;max-height:95vh;overflow-y:auto;display:block}
  .lb-layout{grid-template-columns:1fr;flex:none;min-height:auto}
  .lb-left{overflow:visible;min-height:auto;padding-right:0}
  .lb-right{overflow:visible;min-height:auto;padding-right:0}
  .upload-grid{grid-template-columns:1fr}
}
@media(max-width:540px){
  .photo-grid{grid-template-columns:1fr}
  .mp-title{font-size:1.6rem}
  .mp-header{flex-direction:column}
}
</style>

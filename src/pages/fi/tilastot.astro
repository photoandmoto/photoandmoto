---
import BaseLayout from '../../layouts/BaseLayout.astro';
const lang = 'fi';

// Read data at build time
import fs from 'fs';
const rawData = fs.readFileSync('public/data/champions.json', 'utf-8');
---

<BaseLayout 
  title="Tilastot" 
  lang={lang}
  description="Motocrossin mestarit kautta aikain - tilastot ja statistiikat"
>
  <section class="stats-page">
    <div class="container">
      <div class="section__header">
        <h1 class="section__title">Mestarit kautta aikain</h1>
        <p class="section__subtitle">Motocrossin mestaruustilastot vuodesta 1947</p>
      </div>
      
      <div class="tabs">
        <button class="tab active" data-tab="fim">FIM MM-mestarit</button>
        <button class="tab" data-tab="sml">SM-mestarit</button>
        <button class="tab" data-tab="mxdn">MX des Nations</button>
        <button class="tab" data-tab="ama">AMA-mestarit</button>
        <button class="tab" data-tab="xama">Trans-AMA</button>
      </div>
      
      <div class="stats-content">
        <div class="chart-container">
          <canvas id="champChart" height="300"></canvas>
        </div>
        <div class="table-container">
          <table id="statsTable">
            <thead id="tableHead"></thead>
            <tbody id="tableBody"></tbody>
          </table>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>

<script define:vars={{ rawData }}>
  const DATA = JSON.parse(rawData);
  let currentChart = null;
  
  const tabConfig = {
    fim: {
      title: 'FIM MM-mestarit',
      columns: ['Vuosi', '500cc', '250cc', '125cc', 'MX1', 'MX2', 'MX3', 'MXGP', 'WMX'],
      keys: ['year', '500cc', '250cc', '125cc', 'MX1', 'MX2', 'MX3', 'MXGP', 'WMX'],
      chartLabel: 'Eniten MM-titteleitä'
    },
    sml: {
      title: 'SM-mestarit',
      columns: ['Vuosi', 'Alle 500', 'Alle 250', 'Alle 125', 'Yli 125', 'MX2', 'MX1'],
      keys: ['year', 'Alle 500', 'Alle 250', 'Alle 125', 'Yli 125', 'Alle 125 / MX2', 'A-Avoin / MX1'],
      chartLabel: 'Eniten SM-titteleitä'
    },
    mxdn: {
      title: 'Motocross des Nations',
      columns: ['Vuosi', 'Maa', 'Kuljettajat'],
      keys: ['year', 'country', 'riders'],
      chartLabel: 'Eniten MXdN-voittoja (maa)'
    },
    ama: {
      title: 'AMA-mestarit',
      columns: ['Vuosi', '500 MX', '450 MX', '450 SX', '250 MX', '250 SX West', '250 SX East'],
      keys: ['year', '500 MX', '450 MX', '450 SX', '250 MX', '250 SX West', '250 SX East'],
      chartLabel: 'Eniten AMA-titteleitä'
    },
    xama: {
      title: 'Trans-AMA',
      columns: ['Vuosi', 'Sarja', 'Kuljettaja', 'Maa', 'Pyörä'],
      keys: ['year', 'series', 'rider', 'country', 'bike'],
      chartLabel: 'Trans-AMA voitot'
    }
  };
  
  function renderTable(tabId) {
    const config = tabConfig[tabId];
    const items = DATA[tabId];
    
    // Build header
    const thead = document.getElementById('tableHead');
    thead.innerHTML = '<tr>' + config.columns.map(c => '<th>' + c + '</th>').join('') + '</tr>';
    
    // Build body
    const tbody = document.getElementById('tableBody');
    tbody.innerHTML = items.map((item, i) => {
      const cls = i % 2 === 0 ? '' : ' class="alt"';
      return '<tr' + cls + '>' + config.keys.map(k => '<td>' + (item[k] || '') + '</td>').join('') + '</tr>';
    }).join('');
  }
  
  function renderChart(tabId) {
    const config = tabConfig[tabId];
    const items = DATA[tabId];
    
    // Count titles per person/country
    const counts = {};
    
    if (tabId === 'mxdn') {
      items.forEach(item => {
        const key = item.country;
        if (key) counts[key] = (counts[key] || 0) + 1;
      });
    } else if (tabId === 'xama') {
      items.forEach(item => {
        const key = item.rider;
        if (key) counts[key] = (counts[key] || 0) + 1;
      });
    } else {
      items.forEach(item => {
        const keys = config.keys.slice(1);
        keys.forEach(k => {
          const name = item[k];
          if (name && name.trim()) {
            counts[name] = (counts[name] || 0) + 1;
          }
        });
      });
    }
    
    // Sort and take top 15
    const sorted = Object.entries(counts)
      .sort((a, b) => b[1] - a[1])
      .slice(0, 15);
    
    const ctx = document.getElementById('champChart').getContext('2d');
    
    if (currentChart) currentChart.destroy();
    
    currentChart = new Chart(ctx, {
      type: 'bar',
      data: {
        labels: sorted.map(s => s[0]),
        datasets: [{
          label: config.chartLabel,
          data: sorted.map(s => s[1]),
          backgroundColor: '#ff9900',
          borderColor: '#cc7a00',
          borderWidth: 1,
          borderRadius: 4
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        indexAxis: 'y',
        plugins: {
          legend: { display: false },
          title: {
            display: true,
            text: config.chartLabel,
            font: { size: 16, weight: 'bold', family: 'Montserrat' },
            color: '#1D1D1F'
          }
        },
        scales: {
          x: {
            ticks: { stepSize: 1, font: { family: 'Montserrat' } },
            grid: { color: '#eee' }
          },
          y: {
            ticks: { font: { family: 'Montserrat', size: 12 } },
            grid: { display: false }
          }
        }
      }
    });
  }
  
  function switchTab(tabId) {
    document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
    document.querySelector('[data-tab="' + tabId + '"]').classList.add('active');
    renderTable(tabId);
    renderChart(tabId);
  }
  
  // Tab click handlers
  document.querySelectorAll('.tab').forEach(tab => {
    tab.addEventListener('click', () => switchTab(tab.dataset.tab));
  });
  
  // Initial render
  switchTab('fim');
</script>

<style>
  .stats-page {
    padding: var(--space-6) 0;
  }
  
  .tabs {
    display: flex;
    gap: 4px;
    margin-bottom: var(--space-5);
    flex-wrap: wrap;
    border-bottom: 2px solid #eee;
    padding-bottom: 0;
  }
  
  .tab {
    padding: 12px 20px;
    background: none;
    border: none;
    font-family: var(--font-headline);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--text-secondary);
    cursor: pointer;
    border-bottom: 3px solid transparent;
    margin-bottom: -2px;
    transition: all var(--transition-fast);
  }
  
  .tab:hover {
    color: var(--brand-primary);
  }
  
  .tab.active {
    color: var(--brand-primary);
    border-bottom-color: var(--brand-primary);
  }
  
  .chart-container {
    background: var(--bg-secondary);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    margin-bottom: var(--space-5);
    height: 450px;
  }
  
  .table-container {
    overflow-x: auto;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
  }
  
  #statsTable {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }
  
  #statsTable th {
    background: #000;
    color: white;
    font-family: var(--font-headline);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    padding: 12px 14px;
    text-align: left;
    position: sticky;
    top: 0;
  }
  
  #statsTable td {
    padding: 10px 14px;
    border-bottom: 1px solid #eee;
  }
  
  #statsTable tr.alt {
    background: var(--bg-secondary);
  }
  
  #statsTable tr:hover {
    background: rgba(255, 153, 0, 0.1);
  }
  
  @media (max-width: 768px) {
    .tabs {
      gap: 2px;
    }
    
    .tab {
      padding: 8px 12px;
      font-size: 0.75rem;
    }
    
    .chart-container {
      height: 350px;
    }
  }
</style>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
const lang = 'fi';
import fs from 'fs';
const rawData = fs.readFileSync('public/data/champions.json', 'utf-8');
---
<BaseLayout title="Tilastot" lang={lang} description="Motocrossin mestarit kautta aikain">
  <section class="stats-page">
    <div class="container">
      <div class="section__header">
        <h1 class="section__title">Mestarit kautta aikain</h1>
        <p class="section__subtitle">Motocrossin mestaruustilastot vuodesta 1947</p>
      </div>
      <div class="st-counters">
        <div class="st-counter-item"><span class="st-counter-number" data-target="292">0</span><span class="st-counter-label">Mestaruutta</span></div>
        <div class="st-counter-item"><span class="st-counter-number" data-target="78">0</span><span class="st-counter-label">Vuotta historiaa</span></div>
        <div class="st-counter-item"><span class="st-counter-number" data-target="257">0</span><span class="st-counter-label">Kuljettajaa</span></div>
        <div class="st-counter-item"><span class="st-counter-number" data-target="5">0</span><span class="st-counter-label">Sarjaa</span></div>
      </div>
      <div class="st-search-wrap"><input type="text" id="globalSearch" placeholder="Hae kuljettajaa, vuotta tai maata..." class="st-search-input" /><div id="searchResults" class="st-search-results"></div></div>
      <div class="st-tabs">
        <button class="st-tab st-tab-active" data-tab="fim">FIM MM</button>
        <button class="st-tab" data-tab="sml">SM-mestarit</button>
        <button class="st-tab" data-tab="mxdn">MX des Nations</button>
        <button class="st-tab" data-tab="ama">AMA</button>
        <button class="st-tab" data-tab="xama">Trans-AMA</button>
      </div>
      <div id="tabContent" class="st-tab-content"></div>
    </div>
  </section>
</BaseLayout>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script define:vars={{rawData}}>
const DATA=JSON.parse(rawData);let chart1=null,chart2=null;
function animC(){document.querySelectorAll('.st-counter-number').forEach(el=>{const t=parseInt(el.dataset.target),s=t/125;let c=0;const i=setInterval(()=>{c+=s;if(c>=t){el.textContent=t;clearInterval(i)}else el.textContent=Math.floor(c)},16)})}
function setupSearch(){const inp=document.getElementById('globalSearch'),box=document.getElementById('searchResults');inp.addEventListener('input',()=>{const q=inp.value.trim().toLowerCase();if(q.length<2){box.style.display='none';return}const m=[];DATA.fim.forEach(e=>{Object.entries(e).forEach(([k,v])=>{if(k!=='year'&&v&&String(v).toLowerCase().includes(q))m.push({s:'FIM',y:e.year,c:k,n:v})});if(String(e.year).includes(q))Object.entries(e).forEach(([k,v])=>{if(k!=='year'&&v)m.push({s:'FIM',y:e.year,c:k,n:v})})});DATA.sml_full.forEach(e=>{[1,2,3].forEach(p=>{const d=e['pos'+p];if(d)Object.entries(d).forEach(([k,v])=>{if(v&&String(v).toLowerCase().includes(q))m.push({s:'SM '+['','🥇','🥈','🥉'][p],y:e.year,c:k,n:v})})})});DATA.mxdn.forEach(e=>{if(e.country.toLowerCase().includes(q)||e.riders.toLowerCase().includes(q)||String(e.year).includes(q))m.push({s:'MXdN',y:e.year,c:e.country,n:e.riders})});DATA.ama.forEach(e=>{Object.entries(e).forEach(([k,v])=>{if(k!=='year'&&v&&String(v).toLowerCase().includes(q))m.push({s:'AMA',y:e.year,c:k,n:v})})});DATA.xama.forEach(e=>{if(e.rider.toLowerCase().includes(q)||e.country.toLowerCase().includes(q)||String(e.year).includes(q))m.push({s:'X-AMA',y:e.year,c:e.series,n:e.rider+' ('+e.country+')'})});const seen=new Set,u=m.filter(x=>{const k=x.s+x.y+x.c+x.n;if(seen.has(k))return false;seen.add(k);return true}).slice(0,30);box.innerHTML=u.length?u.map(x=>'<div class="st-sr"><span class="st-sr-s">'+x.s+'</span><span class="st-sr-y">'+x.y+'</span><span class="st-sr-c">'+x.c+'</span><span class="st-sr-n">'+x.n+'</span></div>').join(''):'<div class="st-sr-empty">Ei tuloksia</div>';box.style.display='block'});document.addEventListener('click',e=>{if(!e.target.closest('.st-search-wrap'))box.style.display='none'})}
function mkChart(id,lbl,val,ttl,tp){const c=document.getElementById(id);if(!c)return null;return new Chart(c.getContext('2d'),{type:tp||'bar',data:{labels:lbl,datasets:[{label:ttl,data:val,backgroundColor:'#ff9900',borderRadius:4,borderWidth:0}]},options:{responsive:true,maintainAspectRatio:false,indexAxis:'y',plugins:{legend:{display:false},title:{display:true,text:ttl,font:{size:14,weight:'bold',family:'Montserrat'},color:'#1D1D1F'}},scales:{x:{ticks:{stepSize:1,font:{family:'Montserrat',size:11}},grid:{color:'#eee'}},y:{ticks:{font:{family:'Montserrat',size:11}},grid:{display:false}}}}})}
function destroyC(){if(chart1){chart1.destroy();chart1=null}if(chart2){chart2.destroy();chart2=null}}
function setupDec(sel){document.querySelectorAll('.st-dec-btn').forEach(b=>{b.addEventListener('click',()=>{document.querySelectorAll('.st-dec-btn').forEach(x=>x.classList.remove('st-dec-on'));b.classList.add('st-dec-on');const d=b.dataset.decade;document.querySelectorAll(sel).forEach(r=>{r.style.display=(d==='all'||r.dataset.decade===d)?'':'none'})})})}
function renderFIM(){const c={};DATA.fim.forEach(e=>{Object.entries(e).forEach(([k,v])=>{if(k!=='year'&&v)c[v]=(c[v]||0)+1})});const s=Object.entries(c).sort((a,b)=>b[1]-a[1]),lg=s.filter(x=>x[1]>=3),t15=s.slice(0,15);let h='<div class="st-chart"><canvas id="c1"></canvas></div><h3 class="st-sub">Legendat (3+ titteliä)</h3><div class="st-lg-grid">';lg.forEach(([n,cnt])=>{const tt=[];DATA.fim.forEach(e=>{Object.entries(e).forEach(([k,v])=>{if(v===n&&k!=='year')tt.push(e.year+' '+k)})});h+='<div class="st-lg-card"><div class="st-lg-n">'+cnt+'</div><div><div class="st-lg-name">'+n+'</div><div class="st-lg-det">'+tt.join(', ')+'</div></div></div>'});h+='</div><h3 class="st-sub">Kaikki mestarit</h3><div class="st-dec-row">';[1950,1960,1970,1980,1990,2000,2010,2020].forEach(d=>{h+='<button class="st-dec-btn" data-decade="'+d+'">'+d+'</button>'});h+='<button class="st-dec-btn st-dec-on" data-decade="all">Kaikki</button></div><div class="st-tbl-scroll"><table class="st-tbl"><thead><tr><th>Vuosi</th><th>500cc</th><th>250cc</th><th>125cc</th><th>MX1</th><th>MX2</th><th>MX3</th><th>MXGP</th><th>WMX</th></tr></thead><tbody>';DATA.fim.slice().reverse().forEach((e,i)=>{h+='<tr data-decade="'+(Math.floor(e.year/10)*10)+'" class="'+(i%2?'st-alt':'')+'"><td class="st-yr">'+e.year+'</td>';['500cc','250cc','125cc','MX1','MX2','MX3','MXGP','WMX'].forEach(k=>{h+='<td>'+(e[k]||'')+'</td>'});h+='</tr>'});h+='</tbody></table></div>';document.getElementById('tabContent').innerHTML=h;destroyC();chart1=mkChart('c1',t15.map(x=>x[0]),t15.map(x=>x[1]),'Eniten FIM MM-titteleitä');setupDec('.st-tbl tbody tr')}
function renderSML(){const c={};DATA.sml_full.forEach(e=>{if(e.pos1)Object.values(e.pos1).forEach(n=>{if(n)c[n]=(c[n]||0)+1})});const t15=Object.entries(c).sort((a,b)=>b[1]-a[1]).slice(0,15);const allCls=new Set;DATA.sml_full.forEach(e=>{[1,2,3].forEach(p=>{if(e['pos'+p])Object.keys(e['pos'+p]).forEach(k=>allCls.add(k))})});const clsOrd=['Alle 500','Alle 250','Alle 125','Yli 125','Alle 125 / MX2','A-Avoin / MX1'],cls=clsOrd.filter(x=>allCls.has(x)),sn={'Alle 500':'500','Alle 250':'250','Alle 125':'125','Yli 125':'Yli 125','Alle 125 / MX2':'MX2','A-Avoin / MX1':'MX1'};let h='<div class="st-chart"><canvas id="c1"></canvas></div><h3 class="st-sub">SM-podiumit vuosittain</h3><div class="st-dec-row">';[1950,1960,1970,1980,1990,2000,2010,2020].forEach(d=>{h+='<button class="st-dec-btn" data-decade="'+d+'">'+d+'</button>'});h+='<button class="st-dec-btn st-dec-on" data-decade="all">Kaikki</button></div><div class="st-tbl-scroll"><table class="st-tbl st-sm"><thead><tr><th>Vuosi</th><th>Sija</th>';cls.forEach(x=>{h+='<th>'+(sn[x]||x)+'</th>'});h+='</tr></thead><tbody>';DATA.sml_full.slice().reverse().forEach(e=>{const rspan=[1,2,3].filter(p=>e['pos'+p]).length;let first=true;[1,2,3].forEach(pos=>{const p=e['pos'+pos];if(!p)return;const rc=pos===1?'st-gold':pos===2?'st-silver':'st-bronze';h+='<tr data-decade="'+(Math.floor(e.year/10)*10)+'" class="'+rc+'">';if(first){h+='<td class="st-yr st-yr-m" rowspan="'+rspan+'">'+e.year+'</td>';first=false}h+='<td class="st-pos st-p'+pos+'">'+pos+'.</td>';cls.forEach(x=>{h+='<td>'+(p[x]||'')+'</td>'});h+='</tr>'})});h+='</tbody></table></div>';document.getElementById('tabContent').innerHTML=h;destroyC();chart1=mkChart('c1',t15.map(x=>x[0]),t15.map(x=>x[1]),'Eniten SM-titteleitä');setupDec('.st-sm tbody tr')}
function renderMXDN(){const c={};DATA.mxdn.forEach(e=>{c[e.country]=(c[e.country]||0)+1});const s=Object.entries(c).sort((a,b)=>b[1]-a[1]),cols=['#ff9900','#1D1D1F','#888','#cc7a00','#444','#bbb','#ff6600','#333','#ddd','#aa5500','#555','#666'];let h='<div class="st-chart-row"><div class="st-chart st-chart-h"><canvas id="c1"></canvas></div><div class="st-chart st-chart-h"><canvas id="c2"></canvas></div></div><h3 class="st-sub">Voitot maittain</h3><div class="st-cc-grid">';s.forEach(([co,cnt])=>{const yrs=DATA.mxdn.filter(e=>e.country===co).map(e=>e.year);h+='<div class="st-cc-card"><div class="st-cc-n">'+cnt+'</div><div><div class="st-cc-name">'+co+'</div><div class="st-cc-yr">'+Math.min(...yrs)+' – '+Math.max(...yrs)+'</div></div></div>'});h+='</div><h3 class="st-sub">Voittajat vuosittain</h3><div class="st-tbl-scroll"><table class="st-tbl"><thead><tr><th>Vuosi</th><th>Maa</th><th>Kuljettajat</th></tr></thead><tbody>';DATA.mxdn.slice().reverse().forEach((e,i)=>{h+='<tr class="'+(i%2?'st-alt':'')+'"><td class="st-yr">'+e.year+'</td><td>'+e.country+'</td><td class="st-rid">'+e.riders+'</td></tr>'});h+='</tbody></table></div>';document.getElementById('tabContent').innerHTML=h;destroyC();chart1=new Chart(document.getElementById('c1').getContext('2d'),{type:'doughnut',data:{labels:s.map(x=>x[0]),datasets:[{data:s.map(x=>x[1]),backgroundColor:cols.slice(0,s.length),borderWidth:2,borderColor:'#fff'}]},options:{responsive:true,maintainAspectRatio:false,plugins:{title:{display:true,text:'MXdN voitot',font:{size:14,weight:'bold',family:'Montserrat'}},legend:{position:'right',labels:{font:{family:'Montserrat',size:10}}}}}});chart2=mkChart('c2',s.map(x=>x[0]),s.map(x=>x[1]),'Voitot maittain')}
function renderAMA(){const c={};DATA.ama.forEach(e=>{Object.entries(e).forEach(([k,v])=>{if(k!=='year'&&v)c[v]=(c[v]||0)+1})});const t15=Object.entries(c).sort((a,b)=>b[1]-a[1]).slice(0,15);let h='<div class="st-chart"><canvas id="c1"></canvas></div><h3 class="st-sub">AMA-mestarit vuosittain</h3><div class="st-tbl-scroll"><table class="st-tbl"><thead><tr><th>Vuosi</th><th>500 MX</th><th>450 MX</th><th>450 SX</th><th>250 MX</th><th>250 SX W</th><th>250 SX E</th></tr></thead><tbody>';DATA.ama.slice().reverse().forEach((e,i)=>{h+='<tr class="'+(i%2?'st-alt':'')+'"><td class="st-yr">'+e.year+'</td>';['500 MX','450 MX','450 SX','250 MX','250 SX West','250 SX East'].forEach(k=>{h+='<td>'+(e[k]||'')+'</td>'});h+='</tr>'});h+='</tbody></table></div>';document.getElementById('tabContent').innerHTML=h;destroyC();chart1=mkChart('c1',t15.map(x=>x[0]),t15.map(x=>x[1]),'Eniten AMA-titteleitä')}
function renderXAMA(){let h='<div class="st-xa-grid">';DATA.xama.forEach(e=>{h+='<div class="st-xa-card"><div class="st-xa-yr">'+e.year+'</div><div class="st-xa-ser">'+e.series+'</div><div class="st-xa-rid">'+e.rider+'</div><div class="st-xa-det">'+e.country+' · '+e.bike+'</div></div>'});h+='</div>';document.getElementById('tabContent').innerHTML=h;destroyC()}
function switchTab(id){document.querySelectorAll('.st-tab').forEach(t=>t.classList.remove('st-tab-active'));document.querySelector('[data-tab="'+id+'"]').classList.add('st-tab-active');const el=document.getElementById('tabContent');el.style.opacity='0';setTimeout(()=>{({fim:renderFIM,sml:renderSML,mxdn:renderMXDN,ama:renderAMA,xama:renderXAMA})[id]();el.style.opacity='1'},150)}
document.querySelectorAll('.st-tab').forEach(t=>{t.addEventListener('click',()=>switchTab(t.dataset.tab))});animC();setupSearch();switchTab('fim');
</script>
<style is:global>
.stats-page{padding:var(--space-6) 0}
.st-counters{display:grid;grid-template-columns:repeat(4,1fr);gap:var(--space-3);margin-bottom:var(--space-6)}
.st-counter-item{text-align:center;padding:var(--space-4);background:#000;border-radius:var(--radius-md);color:#fff}
.st-counter-number{display:block;font-size:2.5rem;font-weight:900;color:#ff9900;font-family:var(--font-headline)}
.st-counter-label{font-size:.8rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;opacity:.8}
.st-search-wrap{position:relative;margin-bottom:var(--space-5)}
.st-search-input{width:100%;padding:14px 18px;font-family:var(--font-body);font-size:1rem;border:2px solid #ddd;border-radius:var(--radius-md);background:#fff}
.st-search-input:focus{outline:none;border-color:#ff9900}
.st-search-results{display:none;position:absolute;top:100%;left:0;right:0;background:#fff;border:2px solid #ff9900;border-top:none;border-radius:0 0 var(--radius-md) var(--radius-md);max-height:350px;overflow-y:auto;z-index:100;box-shadow:0 10px 25px rgba(0,0,0,.15)}
.st-sr{display:grid;grid-template-columns:80px 50px 110px 1fr;gap:6px;padding:8px 14px;border-bottom:1px solid #eee;font-size:.85rem;align-items:center}
.st-sr:hover{background:rgba(255,153,0,.08)}
.st-sr-s{font-weight:700;color:#ff9900;font-size:.75rem;text-transform:uppercase}
.st-sr-y{font-weight:700;color:#000}
.st-sr-c{color:#6E6E73;font-size:.8rem}
.st-sr-n{font-weight:600}
.st-sr-empty{padding:16px;text-align:center;color:#6E6E73}
.st-tabs{display:flex;gap:4px;margin-bottom:var(--space-5);border-bottom:2px solid #eee}
.st-tab{padding:12px 20px;background:none;border:none;font-family:var(--font-headline);font-size:.85rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#6E6E73;cursor:pointer;border-bottom:3px solid transparent;margin-bottom:-2px;transition:all .15s}
.st-tab:hover{color:#ff9900}
.st-tab-active{color:#ff9900;border-bottom-color:#ff9900}
.st-tab-content{transition:opacity .15s;min-height:400px}
.st-chart{background:#F9F9F9;border-radius:var(--radius-md);padding:var(--space-4);margin-bottom:var(--space-4);height:420px}
.st-chart-row{display:grid;grid-template-columns:1fr 1fr;gap:var(--space-3);margin-bottom:var(--space-4)}
.st-chart-h{height:320px}
.st-sub{font-size:1.15rem;font-weight:800;margin:var(--space-4) 0 var(--space-3);color:#1D1D1F}
.st-dec-row{display:flex;gap:6px;margin-bottom:var(--space-3);flex-wrap:wrap}
.st-dec-btn{padding:6px 14px;background:#F9F9F9;border:2px solid #ddd;border-radius:20px;font-family:var(--font-headline);font-size:.8rem;font-weight:700;cursor:pointer;transition:all .15s;color:#6E6E73}
.st-dec-btn:hover,.st-dec-on{background:#ff9900;border-color:#ff9900;color:#fff}
.st-lg-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:10px;margin-bottom:var(--space-4)}
.st-lg-card{display:flex;gap:12px;background:#F9F9F9;border-radius:var(--radius-md);padding:14px;align-items:center;transition:transform .15s,box-shadow .15s}
.st-lg-card:hover{transform:translateY(-2px);box-shadow:0 4px 12px rgba(0,0,0,.1)}
.st-lg-n{font-size:2rem;font-weight:900;color:#ff9900;min-width:45px;text-align:center;font-family:var(--font-headline)}
.st-lg-name{font-weight:800;font-size:.95rem;margin-bottom:3px}
.st-lg-det{font-size:.72rem;color:#6E6E73;line-height:1.4}
.st-tbl-scroll{max-height:500px;overflow-y:auto;border-radius:var(--radius-md);box-shadow:0 1px 3px rgba(0,0,0,.08);margin-bottom:var(--space-4)}
.st-tbl{width:100%;border-collapse:collapse;font-size:.82rem}
.st-tbl th{background:#000;color:#fff;font-family:var(--font-headline);font-size:.72rem;text-transform:uppercase;letter-spacing:.5px;padding:10px;text-align:left;position:sticky;top:0;z-index:2}
.st-tbl td{padding:7px 10px;border-bottom:1px solid #eee}
.st-alt{background:#F9F9F9}
.st-tbl tbody tr:hover{background:rgba(255,153,0,.08)}
.st-yr{font-weight:800;color:#ff9900}
.st-yr-m{vertical-align:top}
.st-rid{font-size:.78rem}
.st-gold{background:#FFF8E1}
.st-silver{background:#F5F5F5}
.st-bronze{background:#FFF}
.st-pos{font-weight:800;min-width:22px;display:inline-block}
.st-p1{color:#BA7517}
.st-p2{color:#888}
.st-p3{color:#A0522D}
.st-cc-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(190px,1fr));gap:10px;margin-bottom:var(--space-4)}
.st-cc-card{display:flex;gap:10px;background:#F9F9F9;border-radius:var(--radius-md);padding:12px;align-items:center;transition:box-shadow .15s}
.st-cc-card:hover{box-shadow:0 4px 12px rgba(0,0,0,.1)}
.st-cc-n{font-size:1.6rem;font-weight:900;color:#ff9900;min-width:40px;text-align:center;font-family:var(--font-headline)}
.st-cc-name{font-weight:800;font-size:.9rem}
.st-cc-yr{font-size:.78rem;color:#6E6E73}
.st-xa-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:10px}
.st-xa-card{background:#F9F9F9;border-radius:var(--radius-md);padding:14px;transition:transform .15s,box-shadow .15s}
.st-xa-card:hover{transform:translateY(-2px);box-shadow:0 4px 12px rgba(0,0,0,.1)}
.st-xa-yr{font-size:1.5rem;font-weight:900;color:#ff9900;font-family:var(--font-headline)}
.st-xa-ser{font-size:.72rem;text-transform:uppercase;letter-spacing:.5px;color:#6E6E73;font-weight:700;margin:2px 0 4px}
.st-xa-rid{font-weight:800;font-size:.95rem}
.st-xa-det{font-size:.82rem;color:#6E6E73;margin-top:2px}
@media(max-width:768px){.st-counters{grid-template-columns:repeat(2,1fr)}.st-counter-number{font-size:2rem}.st-tabs{overflow-x:auto;flex-wrap:nowrap}.st-tab{font-size:.75rem;padding:10px 14px;white-space:nowrap}.st-chart-row{grid-template-columns:1fr}.st-chart-h{height:280px}.st-sr{grid-template-columns:70px 45px 1fr}.st-sr-c{display:none}.st-lg-grid{grid-template-columns:1fr}}
</style>

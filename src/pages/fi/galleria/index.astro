---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { ui } from '../../../i18n/ui';

const lang = 'fi';
const t = ui[lang];

const galleries = await getCollection('galleries');
---

<BaseLayout 
  title="Galleria" 
  lang={lang}
  description="Moottoriurheilukuvien galleria - Photo & Moto"
>
  <section class="section">
    <div class="container">
      <div class="section__header">
        <h1 class="section__title">Galleria</h1>
        <p class="section__subtitle">Tutustu kuvagallerioihin eri lajien ja aikakausien parista</p>
      </div>
      
      <p class="gallery-intro">Astu maailmaan missä jokainen kuva kertoo tarinan. Maailma, jossa jokainen kuva sykkii tarinaa ja moottoriurheilun huumaava menneisyys ja jännitys heräävät eloon, on vain klikkauksen päässä sinusta.</p>
      
      <div class="grid grid--3">
        {galleries.map(gallery => (
          <article class="card">
            <a href={`/fi/galleria/${gallery.data.slug}`}>
              <img 
                src={`/galleries/${gallery.data.slug}/${gallery.data.cover_image}`}
                alt={gallery.data.title}
                class="card__image"
                loading="lazy"
              />
              <div class="card__content">
                <h2 class="card__title">{gallery.data.title}</h2>
                <p class="card__text">{gallery.data.description}</p>
                <p class="gallery-count">
                  {t['gallery.photoCount'].replace('{count}', gallery.data.images.length.toString())}
                </p>
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .gallery-intro {
    max-width: 100%;
    margin: 0 auto var(--space-6);
    text-align: center;
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--text-secondary);
    font-weight: 600;
  }

  .gallery-count {
    font-size: 0.875rem;
    color: var(--brand-primary);
    font-weight: 600;
    margin-top: var(--space-1);
  }
</style>

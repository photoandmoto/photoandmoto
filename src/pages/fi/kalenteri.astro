---
import BaseLayout from '../../layouts/BaseLayout.astro';
const lang = 'fi';
import fs from 'fs';
const rawEvents = fs.readFileSync('public/data/calendar.json', 'utf-8');
---
<BaseLayout title="Kilpailukalenteri 2026" lang={lang} description="MXGP, AMA ja SM motocross-kilpailukalenteri 2026">
  <section class="cal-page">
    <div class="container">
      <div class="section__header">
        <h1 class="section__title">Kilpailukalenteri 2026</h1>
        <p class="section__subtitle">MXGP · AMA · SM · SML</p>
      </div>
      <div class="cal-filters" id="calFilters"></div>
      <div class="cal-layout">
        <div class="cal-main">
          <div class="cal-nav">
            <button class="cal-nav-btn" id="prevMonth">‹</button>
            <h2 class="cal-month-title" id="monthTitle"></h2>
            <button class="cal-nav-btn" id="nextMonth">›</button>
          </div>
          <div class="cal-grid">
            <div class="cal-hdr">Ma</div><div class="cal-hdr">Ti</div><div class="cal-hdr">Ke</div><div class="cal-hdr">To</div><div class="cal-hdr">Pe</div><div class="cal-hdr">La</div><div class="cal-hdr">Su</div>
            <div id="calDays"></div>
          </div>
          <div id="dayDetail" class="cal-detail"></div>
        </div>
        <div class="cal-sidebar">
          <h3 class="cal-side-title" id="upcomingTitle">Tulevat kilpailut</h3>
          <div id="upcomingList" class="cal-upcoming"></div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
<script define:vars={{rawEvents}}>
const EVENTS=JSON.parse(rawEvents);
const CATS={MXGP:'#ff9900',MotoGP:'#E10600',AMA:'#E24B4A',SM:'#1D9E75',SML:'#378ADD',Motocross:'#D4537E',Enduro:'#7F77DD',Trial:'#639922',Muu:'#888'};
const MONTH_NAMES=['Tammikuu','Helmikuu','Maaliskuu','Huhtikuu','Toukokuu','Kesäkuu','Heinäkuu','Elokuu','Syyskuu','Lokakuu','Marraskuu','Joulukuu'];
let curMonth=new Date().getMonth();
let curYear=2026;
let activeFilters=new Set(Object.keys(CATS));

function init(){
  renderFilters();
  renderMonth();
  renderUpcoming();
  document.getElementById('prevMonth').addEventListener('click',()=>{curMonth--;if(curMonth<0){curMonth=11;curYear--}renderMonth();renderUpcoming()});
  document.getElementById('nextMonth').addEventListener('click',()=>{curMonth++;if(curMonth>11){curMonth=0;curYear++}renderMonth();renderUpcoming()});
}

function renderFilters(){
  const el=document.getElementById('calFilters');
  el.innerHTML=Object.entries(CATS).map(([cat,col])=>'<button class="cal-filter cal-filter-on" data-cat="'+cat+'" style="--fc:'+col+'">'+cat+'</button>').join('');
  el.querySelectorAll('.cal-filter').forEach(btn=>{
    btn.addEventListener('click',()=>{
      const c=btn.dataset.cat;
      if(activeFilters.has(c)){activeFilters.delete(c);btn.classList.remove('cal-filter-on')}
      else{activeFilters.add(c);btn.classList.add('cal-filter-on')}
      renderMonth();renderUpcoming();
    });
  });
}

function getEventsForDate(y,m,d){
  const ds=y+'-'+String(m+1).padStart(2,'0')+'-'+String(d).padStart(2,'0');
  return EVENTS.filter(e=>e.date===ds&&activeFilters.has(e.category));
}

function renderMonth(){
  document.getElementById('monthTitle').textContent=MONTH_NAMES[curMonth]+' '+curYear;
  const first=new Date(curYear,curMonth,1);
  const lastDay=new Date(curYear,curMonth+1,0).getDate();
  let startDay=first.getDay();startDay=startDay===0?6:startDay-1;
  const today=new Date();
  const isToday=(d)=>today.getFullYear()===curYear&&today.getMonth()===curMonth&&today.getDate()===d;

  let h='';
  for(let i=0;i<startDay;i++)h+='<div class="cal-day cal-day-empty"></div>';
  for(let d=1;d<=lastDay;d++){
    const evts=getEventsForDate(curYear,curMonth,d);
    const todayCls=isToday(d)?' cal-today':'';
    const hasEvt=evts.length?' cal-has-event':'';
    h+='<div class="cal-day'+todayCls+hasEvt+'" data-day="'+d+'">';
    h+='<span class="cal-day-num">'+d+'</span>';
    if(evts.length){
      h+='<div class="cal-dots">';
      evts.forEach(e=>{h+='<span class="cal-dot" style="background:'+CATS[e.category]+'"></span>'});
      h+='</div>';
    }
    h+='</div>';
  }
  
  const container=document.getElementById('calDays');
  container.innerHTML=h;
  
  container.querySelectorAll('.cal-day[data-day]').forEach(day=>{
    day.addEventListener('click',()=>{
      const d=parseInt(day.dataset.day);
      const evts=getEventsForDate(curYear,curMonth,d);
      const detail=document.getElementById('dayDetail');
      if(!evts.length){detail.innerHTML='';detail.style.display='none';return}
      detail.style.display='block';
      detail.innerHTML='<h4 class="cal-det-date">'+d+'. '+MONTH_NAMES[curMonth]+' '+curYear+'</h4>'+
        evts.map(e=>'<div class="cal-det-event"><span class="cal-det-badge" style="background:'+CATS[e.category]+'">'+e.category+'</span><div class="cal-det-title">'+e.title+'</div>'+(e.location?'<div class="cal-det-loc">📍 '+e.location+'</div>':'')+(e.description?'<div class="cal-det-desc">'+e.description+'</div>':'')+'</div>').join('');
      
      container.querySelectorAll('.cal-day').forEach(x=>x.classList.remove('cal-day-sel'));
      day.classList.add('cal-day-sel');
    });
  });
  
  document.getElementById('dayDetail').style.display='none';
}

const MONTH_NAMES_GEN=['Tammikuun','Helmikuun','Maaliskuun','Huhtikuun','Toukokuun','Kesäkuun','Heinäkuun','Elokuun','Syyskuun','Lokakuun','Marraskuun','Joulukuun'];

function renderUpcoming(){
  const today=new Date().toISOString().split('T')[0];
  const titleEl=document.getElementById('upcomingTitle');
  const el=document.getElementById('upcomingList');

  titleEl.textContent=MONTH_NAMES_GEN[curMonth]+' tulevat kilpailut';

  // Filter to events in currently-viewed month that are still upcoming (date >= today)
  const monthStr=String(curMonth+1).padStart(2,'0');
  const yearStr=String(curYear);
  const upcoming=EVENTS.filter(e=>{
    if(!activeFilters.has(e.category))return false;
    if(e.date<today)return false;
    // event date is YYYY-MM-DD
    return e.date.startsWith(yearStr+'-'+monthStr);
  });

  if(!upcoming.length){el.innerHTML='<p class="cal-no-events">Ei tulevia kilpailuja</p>';return}
  el.innerHTML=upcoming.map(e=>{
    const d=new Date(e.date);
    const day=d.getDate();
    const mon=MONTH_NAMES[d.getMonth()].substring(0,3);
    return '<div class="cal-up-item"><div class="cal-up-date"><span class="cal-up-day">'+day+'</span><span class="cal-up-mon">'+mon+'</span></div><div class="cal-up-info"><span class="cal-up-badge" style="background:'+CATS[e.category]+'">'+e.category+'</span><div class="cal-up-title">'+e.title+'</div>'+(e.location?'<div class="cal-up-loc">'+e.location+'</div>':'')+'</div></div>';
  }).join('');
}

init();
</script>
<style is:global>
.cal-page{padding:var(--space-6) 0}
.cal-filters{display:flex;gap:8px;margin-bottom:var(--space-4);flex-wrap:wrap}
.cal-filter{padding:6px 14px;border-radius:20px;font-family:var(--font-headline);font-size:.78rem;font-weight:700;cursor:pointer;transition:all .15s;border:2px solid var(--fc);background:transparent;color:var(--fc)}
.cal-filter-on{background:var(--fc);color:#fff}
.cal-layout{display:grid;grid-template-columns:1fr 320px;gap:var(--space-5)}
.cal-main{min-width:0}
.cal-nav{display:flex;align-items:center;justify-content:space-between;margin-bottom:var(--space-3)}
.cal-nav-btn{background:none;border:2px solid #ddd;border-radius:50%;width:36px;height:36px;font-size:1.2rem;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .15s;color:#1D1D1F}
.cal-nav-btn:hover{border-color:#ff9900;color:#ff9900}
.cal-month-title{font-size:1.3rem;font-weight:800;color:#1D1D1F;font-family:var(--font-headline)}
.cal-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:2px}
.cal-hdr{text-align:center;font-size:.75rem;font-weight:700;color:#6E6E73;padding:8px 0;text-transform:uppercase;font-family:var(--font-headline)}
#calDays{display:contents}
.cal-day{min-height:70px;background:#F9F9F9;border-radius:var(--radius-sm);padding:6px;cursor:pointer;transition:all .15s;position:relative}
.cal-day:hover{background:#eee}
.cal-day-empty{background:transparent;cursor:default}
.cal-day-num{font-size:.8rem;font-weight:700;color:#1D1D1F}
.cal-today{background:#FFF8E1}
.cal-today .cal-day-num{color:#ff9900;font-weight:900}
.cal-has-event{border-left:3px solid #ff9900}
.cal-day-sel{background:#fff;box-shadow:0 0 0 2px #ff9900}
.cal-dots{display:flex;gap:3px;flex-wrap:wrap;margin-top:4px}
.cal-dot{width:8px;height:8px;border-radius:50%;display:block}
.cal-detail{background:#fff;border:2px solid #ff9900;border-radius:var(--radius-md);padding:var(--space-3);margin-top:var(--space-3)}
.cal-det-date{font-size:1rem;font-weight:800;color:#ff9900;margin-bottom:var(--space-2);font-family:var(--font-headline)}
.cal-det-event{padding:10px 0;border-bottom:1px solid #eee}
.cal-det-event:last-child{border-bottom:none}
.cal-det-badge{display:inline-block;font-size:.65rem;font-weight:700;color:#fff;padding:2px 8px;border-radius:10px;text-transform:uppercase;margin-bottom:4px}
.cal-det-title{font-weight:700;font-size:.9rem;margin-bottom:2px}
.cal-det-loc{font-size:.82rem;color:#6E6E73}
.cal-det-desc{font-size:.78rem;color:#6E6E73;margin-top:4px}
.cal-sidebar{min-width:0}
.cal-side-title{font-size:1rem;font-weight:800;margin-bottom:var(--space-3);color:#1D1D1F;font-family:var(--font-headline)}
.cal-upcoming{display:flex;flex-direction:column;gap:8px}
.cal-up-item{display:flex;gap:12px;background:#F9F9F9;border-radius:var(--radius-md);padding:10px;transition:box-shadow .15s}
.cal-up-item:hover{box-shadow:0 2px 8px rgba(0,0,0,.08)}
.cal-up-date{min-width:44px;text-align:center;background:#000;border-radius:var(--radius-sm);padding:6px 4px;color:#fff}
.cal-up-day{display:block;font-size:1.2rem;font-weight:900;color:#ff9900;font-family:var(--font-headline);line-height:1}
.cal-up-mon{display:block;font-size:.65rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;opacity:.8;margin-top:2px}
.cal-up-info{min-width:0}
.cal-up-badge{display:inline-block;font-size:.6rem;font-weight:700;color:#fff;padding:1px 6px;border-radius:8px;text-transform:uppercase;margin-bottom:2px}
.cal-up-title{font-weight:700;font-size:.82rem;line-height:1.3}
.cal-up-loc{font-size:.75rem;color:#6E6E73}
.cal-no-events{color:#6E6E73;font-style:italic}
@media(max-width:768px){.cal-layout{grid-template-columns:1fr}.cal-day{min-height:50px}.cal-sidebar{margin-top:var(--space-4)}}
</style>

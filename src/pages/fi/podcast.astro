---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import heroImage from '../../assets/site/hero-podcast.jpg';

const lang = 'fi';

const episodes = [
  {
    title: 'Heikki Mikkola: Nelinkertainen Motocrossin Maailmanmestari',
    description: 'Tarina legendaarisesta suomalaiskuljettajasta, joka voitti neljä motocrossin maailmanmestaruutta.',
    file: '/audio/Heikki Mikkola_ Nelinkertainen Motocrossin Maailmanmestari.mp3',
  },
  {
    title: 'Honda CR250: Legendan Synty ja Loppu',
    description: 'Honda CR250:n tarina – motocrossin ikonisimman pyörän nousu ja tuotannon päättyminen.',
    file: '/audio/Honda CR250_ Legendan Synty ja Loppu.mp3',
  },
  {
    title: 'Suzuki Motocross Racing: From Disastrous Start to Golden Era',
    description: 'Suzukin tie motocrossin katastrofaalisesta alusta kultaiselle aikakaudelle.',
    file: '/audio/Suzuki Motocross Racing_ From Disastrous Start to Golden Era.mp3',
  },
  {
    title: 'Motocross of Nations: Historia ja Voittajat',
    description: 'Motocross of Nations -kilpailun historia ja sen merkittävimmät voittajat vuosien varrelta.',
    file: '/audio/Motocross of Nations_ Historia ja Voittajat.mp3',
  },
  {
    title: 'Danny "Magoo" Chandlerin perintö motocrossissa',
    description: 'Muisto Danny Chandlerista – lahjakkuudesta, joka jätti lähtemättömän jäljen motocrossiin.',
    file: '/audio/Danny _Magoo_ Chandlerin perintö motocrossissa.mp3',
  },
];
---

<BaseLayout 
  title="Podcast" 
  lang={lang}
  description="Photo & Moto -podcast: keskusteluja motocrossin ja moottoriurheilun maailmasta, kuljettajien tarinoita ja lajin kulttuuria."
>
  <section class="section">
    <div class="container">
      <PageHero
        image={heroImage}
        title="Podcast"
        subtitle="Moottoriurheilun tarinoita äänimuodossa"
        focus="center 30%"
      />
      
      <p class="podcast-intro">Sukella moottoriurheilun historian sykähdyttäviin tarinoihin podcast-muodossa. Kuuntele legendojen tarinat, ikonisten pyörien historia ja lajin merkittävimmät hetket.</p>
      
      <div class="episode-list">
        {episodes.map((ep, i) => (
          <div class="episode" id={`ep-${i}`}>
            <div class="episode-number">{i + 1}</div>
            <div class="episode-content">
              <h2 class="episode-title">{ep.title}</h2>
              <p class="episode-desc">{ep.description}</p>
              <div class="episode-player">
                <audio preload="none" controlslist="nodownload">
                  <source src={ep.file} type="audio/mpeg" />
                </audio>
                <div class="player-controls">
                  <button class="play-btn" data-index={i} aria-label="Play">
                    <svg class="icon-play" viewBox="0 0 24 24" width="28" height="28" fill="currentColor">
                      <polygon points="5,3 19,12 5,21" />
                    </svg>
                    <svg class="icon-pause" viewBox="0 0 24 24" width="28" height="28" fill="currentColor" style="display:none;">
                      <rect x="5" y="3" width="4" height="18" />
                      <rect x="15" y="3" width="4" height="18" />
                    </svg>
                  </button>
                  <div class="player-track">
                    <div class="player-progress-bg">
                      <div class="player-progress" data-index={i}></div>
                    </div>
                    <div class="player-time">
                      <span class="time-current" data-index={i}>0:00</span>
                      <span class="time-total" data-index={i}>--:--</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  let currentPlaying = null;
  
  document.querySelectorAll('.play-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const index = btn.getAttribute('data-index');
      const episode = document.getElementById('ep-' + index);
      const audio = episode.querySelector('audio');
      const iconPlay = btn.querySelector('.icon-play');
      const iconPause = btn.querySelector('.icon-pause');
      
      if (audio.paused) {
        // Stop any currently playing
        if (currentPlaying && currentPlaying !== audio) {
          currentPlaying.pause();
          const prevBtn = currentPlaying.closest('.episode').querySelector('.play-btn');
          prevBtn.querySelector('.icon-play').style.display = '';
          prevBtn.querySelector('.icon-pause').style.display = 'none';
          prevBtn.closest('.episode').classList.remove('episode--playing');
        }
        
        audio.play();
        currentPlaying = audio;
        iconPlay.style.display = 'none';
        iconPause.style.display = '';
        episode.classList.add('episode--playing');
      } else {
        audio.pause();
        iconPlay.style.display = '';
        iconPause.style.display = 'none';
        episode.classList.remove('episode--playing');
      }
    });
  });
  
  // Progress bars
  document.querySelectorAll('audio').forEach((audio, i) => {
    const progress = document.querySelector(`.player-progress[data-index="${i}"]`);
    const timeCurrent = document.querySelector(`.time-current[data-index="${i}"]`);
    const timeTotal = document.querySelector(`.time-total[data-index="${i}"]`);
    const progressBg = progress.parentElement;
    
    function formatTime(s) {
      if (isNaN(s)) return '--:--';
      const m = Math.floor(s / 60);
      const sec = Math.floor(s % 60);
      return m + ':' + (sec < 10 ? '0' : '') + sec;
    }
    
    audio.addEventListener('loadedmetadata', () => {
      timeTotal.textContent = formatTime(audio.duration);
    });
    
    audio.addEventListener('timeupdate', () => {
      const pct = (audio.currentTime / audio.duration) * 100;
      progress.style.width = pct + '%';
      timeCurrent.textContent = formatTime(audio.currentTime);
    });
    
    audio.addEventListener('ended', () => {
      const btn = audio.closest('.episode').querySelector('.play-btn');
      btn.querySelector('.icon-play').style.display = '';
      btn.querySelector('.icon-pause').style.display = 'none';
      audio.closest('.episode').classList.remove('episode--playing');
      progress.style.width = '0%';
      timeCurrent.textContent = '0:00';
    });
    
    // Click to seek
    progressBg.addEventListener('click', (e) => {
      const rect = progressBg.getBoundingClientRect();
      const pct = (e.clientX - rect.left) / rect.width;
      audio.currentTime = pct * audio.duration;
    });
  });
</script>

<style is:global>
  .podcast-intro {
    max-width: 100%;
    margin: 0 auto var(--space-6);
    text-align: center;
    font-size: 1.15rem;
    line-height: 1.7;
    color: var(--text-primary);
    font-weight: 600;
  }
  
  .episode-list {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  
  .episode {
    display: flex;
    gap: var(--space-4);
    background: #fff;
    border-radius: var(--radius-md);
    padding: var(--space-4);
    box-shadow: var(--shadow-sm);
    border-left: 4px solid #ddd;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  
  .episode--playing {
    border-left-color: #ff9900;
    box-shadow: var(--shadow-md);
  }
  
  .episode-number {
    font-family: var(--font-headline);
    font-size: 2rem;
    font-weight: 900;
    color: #ddd;
    min-width: 40px;
    text-align: center;
    line-height: 1;
    padding-top: 4px;
  }
  
  .episode--playing .episode-number {
    color: #ff9900;
  }
  
  .episode-content {
    flex: 1;
    min-width: 0;
  }
  
  .episode-title {
    font-size: 1.15rem;
    font-weight: 800;
    color: var(--text-primary);
    margin-bottom: var(--space-1);
    line-height: 1.3;
  }
  
  .episode-desc {
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin-bottom: var(--space-3);
    line-height: 1.5;
  }
  
  .player-controls {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }
  
  .play-btn {
    background: #ff9900;
    border: none;
    border-radius: 50%;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: white;
    flex-shrink: 0;
    transition: background 0.15s, transform 0.1s;
  }
  
  .play-btn:hover {
    background: #e68a00;
    transform: scale(1.05);
  }
  
  .play-btn:active {
    transform: scale(0.95);
  }
  
  .player-track {
    flex: 1;
    min-width: 0;
  }
  
  .player-progress-bg {
    width: 100%;
    height: 6px;
    background: #eee;
    border-radius: 3px;
    cursor: pointer;
    position: relative;
    margin-bottom: 6px;
  }
  
  .player-progress {
    height: 100%;
    background: #ff9900;
    border-radius: 3px;
    width: 0%;
    transition: width 0.1s linear;
  }
  
  .player-time {
    display: flex;
    justify-content: space-between;
    font-size: 0.75rem;
    color: #999;
    font-family: var(--font-body);
  }
  
  audio { display: none; }
  
  @media (max-width: 768px) {
    .episode {
      flex-direction: column;
      gap: var(--space-2);
    }
    
    .episode-number {
      font-size: 1.2rem;
    }
    
    .play-btn {
      width: 42px;
      height: 42px;
    }
  }
</style>
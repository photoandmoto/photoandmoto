---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import heroImage from '../../assets/mxgp/hero-trentino.jpg';
import upcomingImage from '../../assets/mxgp/upcoming-default.jpg';
import fs from 'fs';

const lang = 'fi';
const raw = fs.readFileSync('public/data/mxgp-results.json', 'utf-8');
const data = JSON.parse(raw);
const race = data.latestRace;
const standings = data.standings;
const nextRace = data.nextRace;

// Backward-compat: if old flat shape ({fi:[], en:[]}) is still on disk, treat as empty per-tab
const rawHL = data.highlights || {};
const hlFi = (rawHL.fi && !Array.isArray(rawHL.fi)) ? rawHL.fi : {};
// New 5-bucket schema (with backward-compat for older 3-bucket schema)
const highlightsByTab: {
  mxgp_quali: string[]; mxgp_race: string[];
  mx2_quali: string[];  mx2_race: string[];
  standings: string[];
} = {
  mxgp_quali: hlFi.mxgp_quali || [],
  mxgp_race:  hlFi.mxgp_race  || hlFi.mxgp || [],
  mx2_quali:  hlFi.mx2_quali  || [],
  mx2_race:   hlFi.mx2_race   || hlFi.mx2  || [],
  standings:  hlFi.standings  || [],
};
const tabTitles: Record<string, string> = {
  mxgp: 'MXGP – Viikonlopun kohokohdat',
  mx2: 'MX2 – Viikonlopun kohokohdat',
  standings: 'MM-sarjan tilanne',
};
const qualiTitles: Record<string, string> = {
  mxgp: 'MXGP – Aika-ajo (lauantai)',
  mx2: 'MX2 – Aika-ajo (lauantai)',
};
const hasAnyHighlights =
  highlightsByTab.mxgp_quali.length + highlightsByTab.mxgp_race.length +
  highlightsByTab.mx2_quali.length  + highlightsByTab.mx2_race.length +
  highlightsByTab.standings.length > 0;

function formatDate(dateStr: string) {
  const d = new Date(dateStr);
  const months = ['tammikuuta','helmikuuta','maaliskuuta','huhtikuuta','toukokuuta','kesäkuuta','heinäkuuta','elokuuta','syyskuuta','lokakuuta','marraskuuta','joulukuuta'];
  return `${d.getDate()}. ${months[d.getMonth()]} ${d.getFullYear()}`;
}

function daysUntil(dateStr: string): number | null {
  if (!dateStr) return null;
  const target = new Date(dateStr + 'T00:00:00').getTime();
  const today = new Date(); today.setHours(0,0,0,0);
  const diff = Math.round((target - today.getTime()) / (1000 * 60 * 60 * 24));
  return diff >= 0 ? diff : null;
}
---

<BaseLayout 
  title="MXGP 2026 — Tulokset ja MM-pisteet" 
  lang={lang}
  description="MXGP ja MX2 viimeisimmät kilpailutulokset ja MM-sarjan pistetilanne 2026"
>
  <section class="mxgp-page">
    <div class="container">
      <p class="page-eyebrow">MXGP 2026 · Tulokset ja MM-pistetilanne</p>

      {race ? (
        <>
          <!-- Race overview: hero (current race) + next-race card side-by-side on desktop -->
          <div class={`race-overview ${nextRace ? 'race-overview--has-next' : ''}`}>
            <!-- Hero Race Banner: photo background + race info overlay -->
            <div class="race-hero">
              <Image
                src={heroImage}
                alt="MXGP race photo"
                class="race-hero__img"
                widths={[768, 1280, 1920]}
                sizes="(max-width: 768px) 100vw, (max-width: 1280px) 100vw, 1920px"
                loading="eager"
              />
              <div class="race-hero__overlay"></div>
              <div class="race-hero__content">
                <div class="race-hero__round">Osakilpailu {race.round}/{data.totalRounds}</div>
                <h1 class="race-hero__title">{race.name}</h1>
                <div class="race-hero__meta">
                  <span>📍 {race.location}</span>
                  <span>📅 {formatDate(race.date)}</span>
                </div>
                {data.seasonComplete && (
                  <div class="race-hero__final">🏆 Kausi päättynyt — lopulliset tulokset</div>
                )}
              </div>
            </div>

            {nextRace && (
              <div class="next-race">
                <Image
                  src={upcomingImage}
                  alt="Upcoming MXGP race"
                  class="next-race__img"
                  widths={[400, 600, 900]}
                  sizes="(max-width: 768px) 100vw, 33vw"
                  loading="eager"
                />
                <div class="next-race__overlay"></div>
                <div class="next-race__content">
                  <div class="next-race__eyebrow">Seuraava osakilpailu</div>
                  <div class="next-race__round">Osakilpailu {nextRace.round}/{data.totalRounds}</div>
                  <h2 class="next-race__title">{nextRace.name}</h2>
                  <div class="next-race__meta">
                    <div>📍 {nextRace.location}</div>
                    {nextRace.date && <div>📅 {formatDate(nextRace.date)}</div>}
                  </div>
                  {daysUntil(nextRace.date) !== null && (
                    <div class="next-race__countdown">
                      <span class="next-race__countdown-num">{daysUntil(nextRace.date)}</span>
                      <span class="next-race__countdown-label">{daysUntil(nextRace.date) === 1 ? 'päivä jäljellä' : 'päivää jäljellä'}</span>
                    </div>
                  )}
                </div>
              </div>
            )}
          </div>

          <!-- Highlights Cards (per-tab; MXGP & MX2 each get a small Saturday card + main Weekend card) -->
          {hasAnyHighlights && (
            <div class="highlights-stack" id="highlightsStack">
              <!-- MXGP group -->
              <div class="highlights-group highlights-group--active" data-highlights-group="mxgp">
                {highlightsByTab.mxgp_quali.length > 0 && (
                  <div class="highlights-card highlights-card--saturday">
                    <div class="highlights-card__header">
                      <span class="highlights-card__icon">🕒</span>
                      <h3 class="highlights-card__title">{qualiTitles.mxgp}</h3>
                    </div>
                    <ul class="highlights-card__list">
                      {highlightsByTab.mxgp_quali.map((h: string) => (<li>{h}</li>))}
                    </ul>
                  </div>
                )}
                {highlightsByTab.mxgp_race.length > 0 && (
                  <div class="highlights-card">
                    <div class="highlights-card__header">
                      <span class="highlights-card__icon">🏁</span>
                      <h3 class="highlights-card__title">{tabTitles.mxgp}</h3>
                    </div>
                    <ul class="highlights-card__list">
                      {highlightsByTab.mxgp_race.map((h: string) => (<li>{h}</li>))}
                    </ul>
                  </div>
                )}
              </div>

              <!-- MX2 group -->
              <div class="highlights-group" data-highlights-group="mx2">
                {highlightsByTab.mx2_quali.length > 0 && (
                  <div class="highlights-card highlights-card--saturday">
                    <div class="highlights-card__header">
                      <span class="highlights-card__icon">🕒</span>
                      <h3 class="highlights-card__title">{qualiTitles.mx2}</h3>
                    </div>
                    <ul class="highlights-card__list">
                      {highlightsByTab.mx2_quali.map((h: string) => (<li>{h}</li>))}
                    </ul>
                  </div>
                )}
                {highlightsByTab.mx2_race.length > 0 && (
                  <div class="highlights-card">
                    <div class="highlights-card__header">
                      <span class="highlights-card__icon">🏁</span>
                      <h3 class="highlights-card__title">{tabTitles.mx2}</h3>
                    </div>
                    <ul class="highlights-card__list">
                      {highlightsByTab.mx2_race.map((h: string) => (<li>{h}</li>))}
                    </ul>
                  </div>
                )}
              </div>

              <!-- Standings group -->
              <div class="highlights-group" data-highlights-group="standings">
                {highlightsByTab.standings.length > 0 && (
                  <div class="highlights-card">
                    <div class="highlights-card__header">
                      <span class="highlights-card__icon">🏆</span>
                      <h3 class="highlights-card__title">{tabTitles.standings}</h3>
                    </div>
                    <ul class="highlights-card__list">
                      {highlightsByTab.standings.map((h: string) => (<li>{h}</li>))}
                    </ul>
                  </div>
                )}
              </div>
            </div>
          )}

          <!-- Tab Navigation -->
          <div class="mxgp-tabs" id="classTabs">
            <button class="mxgp-tab mxgp-tab--active" data-class="mxgp">MXGP</button>
            <button class="mxgp-tab" data-class="mx2">MX2</button>
            <button class="mxgp-tab" data-class="standings">MM-pisteet</button>
          </div>

          <!-- MXGP Results -->
          <div class="mxgp-panel mxgp-panel--active" data-panel="mxgp">
            {race.mxgp.qualifying.length > 0 && (
              <>
                <h3 class="result-section-title">Aika-ajo (lauantai)</h3>
                <div class="table-wrap">
                  <table class="result-table result-table--compact">
                    <thead><tr><th>Sija</th><th>Kuljettaja</th><th>Merkki</th><th>Maa</th></tr></thead>
                    <tbody>
                      {race.mxgp.qualifying.map((r: any) => (
                        <tr class={r.pos <= 3 ? `podium podium--${r.pos}` : ''}>
                          <td class="pos">{r.pos}</td><td class="rider">{r.rider}</td><td>{r.bike}</td><td>{r.nat}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </>
            )}

            <div class="race-grid">
              <div>
                <h3 class="result-section-title">Lähtö 1 (sunnuntai)</h3>
                <div class="table-wrap">
                  <table class="result-table result-table--compact">
                    <thead><tr><th>Sija</th><th>Kuljettaja</th><th>Merkki</th><th>Pist.</th></tr></thead>
                    <tbody>
                      {race.mxgp.race1.map((r: any) => (
                        <tr class={r.pos <= 3 ? `podium podium--${r.pos}` : ''}>
                          <td class="pos">{r.pos}</td><td class="rider">{r.rider}</td><td>{r.bike}</td><td class="pts">{r.pts}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
              <div>
                <h3 class="result-section-title">Lähtö 2 (sunnuntai)</h3>
                <div class="table-wrap">
                  <table class="result-table result-table--compact">
                    <thead><tr><th>Sija</th><th>Kuljettaja</th><th>Merkki</th><th>Pist.</th></tr></thead>
                    <tbody>
                      {race.mxgp.race2.map((r: any) => (
                        <tr class={r.pos <= 3 ? `podium podium--${r.pos}` : ''}>
                          <td class="pos">{r.pos}</td><td class="rider">{r.rider}</td><td>{r.bike}</td><td class="pts">{r.pts}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
            </div>

            <h3 class="result-section-title">GP-kokonaistulos</h3>
            <div class="table-wrap">
              <table class="result-table">
                <thead><tr><th>Sija</th><th>Kuljettaja</th><th>Merkki</th><th>Maa</th><th>Pist.</th></tr></thead>
                <tbody>
                  {race.mxgp.overall.map((r: any) => (
                    <tr class={r.pos <= 3 ? `podium podium--${r.pos}` : ''}>
                      <td class="pos">{r.pos}</td><td class="rider">{r.rider}</td><td>{r.bike}</td><td>{r.nat}</td><td class="pts">{r.pts}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>

          <!-- MX2 Results -->
          <div class="mxgp-panel" data-panel="mx2">
            {race.mx2.qualifying.length > 0 && (
              <>
                <h3 class="result-section-title">Aika-ajo (lauantai)</h3>
                <div class="table-wrap">
                  <table class="result-table result-table--compact">
                    <thead><tr><th>Sija</th><th>Kuljettaja</th><th>Merkki</th><th>Maa</th></tr></thead>
                    <tbody>
                      {race.mx2.qualifying.map((r: any) => (
                        <tr class={r.pos <= 3 ? `podium podium--${r.pos}` : ''}>
                          <td class="pos">{r.pos}</td><td class="rider">{r.rider}</td><td>{r.bike}</td><td>{r.nat}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </>
            )}

            <div class="race-grid">
              <div>
                <h3 class="result-section-title">Lähtö 1 (sunnuntai)</h3>
                <div class="table-wrap">
                  <table class="result-table result-table--compact">
                    <thead><tr><th>Sija</th><th>Kuljettaja</th><th>Merkki</th><th>Pist.</th></tr></thead>
                    <tbody>
                      {race.mx2.race1.map((r: any) => (
                        <tr class={r.pos <= 3 ? `podium podium--${r.pos}` : ''}>
                          <td class="pos">{r.pos}</td><td class="rider">{r.rider}</td><td>{r.bike}</td><td class="pts">{r.pts}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
              <div>
                <h3 class="result-section-title">Lähtö 2 (sunnuntai)</h3>
                <div class="table-wrap">
                  <table class="result-table result-table--compact">
                    <thead><tr><th>Sija</th><th>Kuljettaja</th><th>Merkki</th><th>Pist.</th></tr></thead>
                    <tbody>
                      {race.mx2.race2.map((r: any) => (
                        <tr class={r.pos <= 3 ? `podium podium--${r.pos}` : ''}>
                          <td class="pos">{r.pos}</td><td class="rider">{r.rider}</td><td>{r.bike}</td><td class="pts">{r.pts}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
            </div>

            <h3 class="result-section-title">GP-kokonaistulos</h3>
            <div class="table-wrap">
              <table class="result-table">
                <thead><tr><th>Sija</th><th>Kuljettaja</th><th>Merkki</th><th>Maa</th><th>Pist.</th></tr></thead>
                <tbody>
                  {race.mx2.overall.map((r: any) => (
                    <tr class={r.pos <= 3 ? `podium podium--${r.pos}` : ''}>
                      <td class="pos">{r.pos}</td><td class="rider">{r.rider}</td><td>{r.bike}</td><td>{r.nat}</td><td class="pts">{r.pts}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>

          <!-- Standings -->
          <div class="mxgp-panel" data-panel="standings">
            <div class="standings-grid">
              <div>
                <h3 class="result-section-title">MXGP — MM-pistetilanne</h3>
                <div class="table-wrap">
                  <table class="result-table">
                    <thead><tr><th>Sija</th><th>Kuljettaja</th><th>Merkki</th><th>Maa</th><th>Pist.</th></tr></thead>
                    <tbody>
                      {standings.mxgp.map((r: any) => (
                        <tr class={r.pos <= 3 ? `podium podium--${r.pos}` : ''}>
                          <td class="pos">{r.pos}</td><td class="rider">{r.rider}</td><td>{r.bike}</td><td>{r.nat}</td><td class="pts">{r.pts}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
              <div>
                <h3 class="result-section-title">MX2 — MM-pistetilanne</h3>
                <div class="table-wrap">
                  <table class="result-table">
                    <thead><tr><th>Sija</th><th>Kuljettaja</th><th>Merkki</th><th>Maa</th><th>Pist.</th></tr></thead>
                    <tbody>
                      {standings.mx2.map((r: any) => (
                        <tr class={r.pos <= 3 ? `podium podium--${r.pos}` : ''}>
                          <td class="pos">{r.pos}</td><td class="rider">{r.rider}</td><td>{r.bike}</td><td>{r.nat}</td><td class="pts">{r.pts}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
          </div>

          <p class="mxgp-updated">Päivitetty: {data.lastUpdated} · Päivittyy automaattisesti joka sunnuntai</p>
          <p class="mxgp-source">Lähde: <a href="https://mxgpresults.com" target="_blank" rel="noopener">mxgpresults.com</a></p>
        </>
      ) : (
        <div class="mxgp-offseason">
          <p>MXGP 2026 -kausi ei ole vielä alkanut. Tulokset päivittyvät automaattisesti ensimmäisen osakilpailun jälkeen.</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<script>
  const tabs = document.querySelectorAll('.mxgp-tab');
  const panels = document.querySelectorAll('.mxgp-panel');
  const hlGroups = document.querySelectorAll('.highlights-group');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const target = (tab as HTMLElement).dataset.class;
      tabs.forEach(t => t.classList.remove('mxgp-tab--active'));
      panels.forEach(p => p.classList.remove('mxgp-panel--active'));
      tab.classList.add('mxgp-tab--active');
      document.querySelector(`[data-panel="${target}"]`)?.classList.add('mxgp-panel--active');

      hlGroups.forEach(g => g.classList.remove('highlights-group--active'));
      document.querySelector(`[data-highlights-group="${target}"]`)?.classList.add('highlights-group--active');
    });
  });
</script>

<style is:global>
  .mxgp-page { padding: var(--space-6) 0 var(--space-8); }

  /* Slim page eyebrow above the hero */
  .page-eyebrow {
    font-family: var(--font-headline);
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    color: var(--text-secondary);
    margin: 0 0 var(--space-2);
  }

  /* Race overview grid: hero + next-race side-by-side on desktop */
  .race-overview {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    margin-bottom: var(--space-5);
  }
  .race-overview--has-next {
    grid-template-columns: minmax(0, 2fr) minmax(0, 1fr);
  }

  /* Next-race card */
  .next-race {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    color: white;
    border-left: 4px solid rgba(255, 165, 0, 0.55);
    min-height: 360px;
    background: #1a1a1a;
  }
  .next-race__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  .next-race__overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(135deg, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.55) 60%, rgba(0,0,0,0.4) 100%),
      linear-gradient(to top, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0) 55%);
  }
  .next-race__content {
    position: absolute;
    inset: 0;
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }
  .next-race__eyebrow {
    font-family: var(--font-headline);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: rgba(255, 165, 0, 0.95);
    margin-bottom: var(--space-2);
    text-shadow: 0 1px 3px rgba(0,0,0,0.7);
  }
  .next-race__round {
    font-family: var(--font-headline);
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: rgba(255,255,255,0.85);
    margin-bottom: var(--space-1);
    text-shadow: 0 1px 3px rgba(0,0,0,0.7);
  }
  .next-race__title {
    font-size: clamp(1.3rem, 2.4vw, 1.8rem);
    font-weight: 900;
    margin: 0 0 var(--space-3);
    color: white;
    line-height: 1.15;
    text-shadow: 0 2px 6px rgba(0,0,0,0.85);
  }
  .next-race__meta {
    display: flex;
    flex-direction: column;
    gap: 4px;
    font-size: 0.92rem;
    color: rgba(255,255,255,0.95);
    margin-bottom: var(--space-3);
    text-shadow: 0 1px 3px rgba(0,0,0,0.7);
  }
  .next-race__countdown {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-top: auto;
    padding-top: var(--space-3);
    border-top: 1px solid rgba(255,255,255,0.2);
  }
  .next-race__countdown-num {
    font-family: var(--font-headline);
    font-size: 2.4rem;
    font-weight: 900;
    color: var(--brand-primary);
    line-height: 1;
    text-shadow: 0 2px 6px rgba(0,0,0,0.85);
  }
  .next-race__countdown-label {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.9);
    text-transform: lowercase;
    text-shadow: 0 1px 3px rgba(0,0,0,0.7);
  }

  /* Race Hero (photo background + race info overlay) */
  .race-hero {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    height: 360px;
    background: #1a1a1a;
    border-left: 5px solid var(--brand-primary);
  }
  .race-hero__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  .race-hero__overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(135deg, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.45) 50%, rgba(0,0,0,0.25) 100%),
      linear-gradient(to top, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0) 60%);
  }
  .race-hero__content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: var(--space-5);
    color: white;
  }
  .race-hero__round {
    font-family: var(--font-headline);
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--brand-primary);
    margin-bottom: var(--space-1);
    text-shadow: 0 1px 3px rgba(0,0,0,0.7);
  }
  .race-hero__title {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 900;
    margin: 0 0 var(--space-2);
    color: white;
    text-shadow: 0 2px 6px rgba(0,0,0,0.8);
    line-height: 1.1;
  }
  .race-hero__meta {
    display: flex;
    gap: var(--space-4);
    font-size: 0.95rem;
    color: rgba(255,255,255,0.92);
    flex-wrap: wrap;
    text-shadow: 0 1px 3px rgba(0,0,0,0.7);
  }
  .race-hero__final {
    margin-top: var(--space-2);
    font-family: var(--font-headline);
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--brand-primary);
    text-shadow: 0 1px 3px rgba(0,0,0,0.7);
  }

  /* Tabs */
  .mxgp-tabs {
    display: flex;

---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHero from '../../../components/PageHero.astro';
import heroImage from '../../../assets/site/hero-aikakone.jpg';
import { getCollection } from 'astro:content';
import { ui } from '../../../i18n/ui';

const lang = 'fi';
const t = ui[lang];

const articles = (await getCollection('articles', ({ data }) =>
  data.language === 'fi' && !data.draft
)).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout
  title="Aikakone"
  lang={lang}
  description="Motocrossin ja moottoriurheilun historia-artikkelit: suomalaiset tähdet, legendaariset kilpailut ja vuosikymmenten tarinoita radalta."
>
  <section class="section">
    <div class="container">
      <PageHero
        image={heroImage}
        title="Aikakone"
        subtitle="Matka moottoriurheilun historian havinaan"
      />

      <p class="aikakone-intro">Aikakone moottoriurheilun ytimessä. Lue lyhyitä paloja lajin historiasta ja tulevaisuuden murroksista juuri sellaisina kuin ne ovat.</p>

      {articles.length > 0 ? (
        <div class="articles-grid">
          {articles.map(article => {
            const formattedDate = new Intl.DateTimeFormat('fi-FI', {
              year: 'numeric',
              month: 'short',
              day: 'numeric'
            }).format(article.data.date);

            return (
              <article class="article-card">
                <a href={`/fi/aikakone/${article.id.replace(/^fi\//, '')}`}>
                  <div class="article-card__image-wrap">
                    <img
                      src={article.data.featured_image}
                      alt={article.data.title}
                      class="article-card__image"
                      loading="lazy"
                    />
                  </div>
                  <div class="article-card__content">
                    <div class="article-card__meta">
                      <span class="badge badge--small">{article.data.category}</span>
                      <span class="article-card__date">{formattedDate}</span>
                    </div>
                    <h2 class="article-card__title">{article.data.title}</h2>
                    {article.data.subtitle && (
                      <p class="article-card__text">{article.data.subtitle}</p>
                    )}
                  </div>
                </a>
              </article>
            );
          })}
        </div>
      ) : (
        <div class="empty-state">
          <p>Ei vielä artikkeleita. Palaa pian!</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .aikakone-intro {
    max-width: 100%;
    margin: 0 auto var(--space-6);
    text-align: center;
    font-size: 1.15rem;
    line-height: 1.7;
    color: var(--text-primary);
    font-weight: 600;
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-3);
  }

  .article-card {
    background: white;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
    transition: transform var(--transition-base), box-shadow var(--transition-base);
  }

  .article-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }

  .article-card a {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .article-card__image-wrap {
    overflow: hidden;
    aspect-ratio: 16 / 10;
  }

  .article-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--transition-base);
  }

  .article-card:hover .article-card__image {
    transform: scale(1.05);
  }

  .article-card__content {
    padding: var(--space-2);
  }

  .article-card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    margin-bottom: var(--space-1);
  }

  .badge--small {
    font-size: 0.65rem;
    padding: 2px 8px;
  }

  .article-card__date {
    font-size: 0.75rem;
    color: var(--text-secondary);
  }

  .article-card__title {
    font-size: 0.95rem;
    color: var(--brand-secondary);
    margin-bottom: var(--space-1);
    line-height: 1.3;
  }

  .article-card__text {
    font-size: 0.8rem;
    color: var(--text-secondary);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .empty-state {
    text-align: center;
    padding: var(--space-8) 0;
    color: var(--text-secondary);
  }

  @media (max-width: 1024px) {
    .articles-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .articles-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .articles-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import heroImage from '../../assets/site/hero-etusivu.jpg';
import { getCollection } from 'astro:content';
import { ui } from '../../i18n/ui';

const lang = 'fi';
const t = ui[lang];

const articles = (await getCollection('articles', ({ data }) => 
  data.language === 'fi' && !data.draft
)).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const featuredArticle = articles[0];
const recentArticles = articles.slice(1, 4);

const galleries = await getCollection('galleries');
const featuredGalleries = galleries.slice(0, 4);
---

<BaseLayout 
  title="Etusivu" 
  lang={lang}
  description="Motocrossin ja moottoripyöräurheilun kuvia, tarinoita ja tuloksia 1960-luvulta nykypäivään. MXGP 2026, Aikakone-arkisto ja valokuvagalleria."
>
  <!-- Hero Section -->
  <section class="section section--hero">
    <div class="container">
      <PageHero
        image={heroImage}
        title={t['hero.tagline']}
        subtitle={t['hero.subtitle']}
      />
    </div>
  </section>
  
  <!-- Intro Section -->
  <section class="intro-section">
    <div class="container">
      <div class="intro-grid">
        <div class="intro-col">
          <h2 class="intro-title">Tervetuloa fiilistelemään</h2>
          <div class="intro-image-wrap">
            <img src="/images/intro-gallery.jpg" alt="Tervetuloa fiilistelemään" class="intro-image" />
          </div>
          <p class="intro-text">Moottoriurheilun historiaa ja huikeita tarinoita. Päivitämme kuvia ja juttuja jatkuvasti, joten pysy vauhdissa mukana!</p>
        </div>
        <div class="intro-col">
          <h2 class="intro-title">Palaa ajassa taaksepäin</h2>
          <div class="intro-image-wrap">
            <img src="/images/intro-articles.jpg" alt="Palaa ajassa taaksepäin" class="intro-image" />
          </div>
          <p class="intro-text">Syvenny moottoriurheilun tarinoihin ja tekniikkaan. Tuomme historian sykähdyttävimmät hetket suoraan luoksesi.</p>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Latest Articles -->
  {featuredArticle && (
    <section class="section latest-articles">
      <div class="container">
        <div class="section__header">
          <h2 class="section__title">{t['latest.title']}</h2>
        </div>
        
        <article class="featured-card">
          <a href={`/fi/aikakone/${featuredArticle.slug.replace(/^fi\//, '')}`}>
            <div class="featured-card__image-wrap">
              <img 
                src={featuredArticle.data.featured_image} 
                alt={featuredArticle.data.title}
                class="featured-card__image"
              />
            </div>
            <div class="featured-card__content">
              <span class="badge">{featuredArticle.data.category}</span>
              <h3 class="featured-card__title">{featuredArticle.data.title}</h3>
              {featuredArticle.data.subtitle && (
                <p class="featured-card__text">{featuredArticle.data.subtitle}</p>
              )}
              <span class="featured-card__read">{t['article.readMore']} →</span>
            </div>
          </a>
        </article>
        
        {recentArticles.length > 0 && (
          <div class="recent-grid">
            {recentArticles.map(article => (
              <article class="card">
                <a href={`/fi/aikakone/${article.slug.replace(/^fi\//, '')}`}>
                  <img 
                    src={article.data.featured_image} 
                    alt={article.data.title}
                    class="card__image"
                  />
                  <div class="card__content">
                    <span class="badge">{article.data.category}</span>
                    <h3 class="card__title">{article.data.title}</h3>
                    {article.data.subtitle && (
                      <p class="card__text">{article.data.subtitle}</p>
                    )}
                  </div>
                </a>
              </article>
            ))}
          </div>
        )}
        
        <div style="text-align: center; margin-top: var(--space-5);">
          <a href="/fi/aikakone" class="btn btn--secondary">Kaikki artikkelit</a>
        </div>
      </div>
    </section>
  )}
  
  <!-- Featured Galleries -->
  {featuredGalleries.length > 0 && (
    <section class="section featured-galleries">
      <div class="container">
        <div class="section__header">
          <h2 class="section__title">Galleria</h2>
          <p class="section__subtitle">Tutustu kuvagallerioihin</p>
        </div>
        
        <p class="gallery-intro">Löydä suosikkihetkesi helposti. Kuvat välittävät historian tunnelman ja vievät sinut suoraan lajin merkittävimpiin hetkiin aidoimmillaan.</p>
        
        <div class="grid grid--4">
          {featuredGalleries.map(gallery => (
            <article class="card">
              <a href={`/fi/galleria/${gallery.data.slug}`}>
                <img 
                  src={`/galleries/${gallery.data.slug}/${gallery.data.cover_image}`}
                  alt={gallery.data.title}
                  class="card__image"
                  loading="lazy"
                />
                <div class="card__content">
                  <h3 class="card__title">{gallery.data.title}</h3>
                  <p class="card__text">
                    {t['gallery.photoCount'].replace('{count}', gallery.data.images.length.toString())}
                  </p>
                </div>
              </a>
            </article>
          ))}
        </div>
        
        <div style="text-align: center; margin-top: var(--space-6);">
          <a href="/fi/galleria" class="btn btn--secondary">Katso kaikki galleriat</a>
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  /* Intro section - white background */
  .section--hero {
    padding-bottom: 0;
  }
  
  .intro-section {
    background: white;
    color: var(--text-primary);
    padding: 0 0 var(--space-8);
  }
  
  .intro-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6);
    align-items: start;
  }
  
  .intro-image-wrap {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-md);
    margin-bottom: var(--space-3);
    height: 280px;
  }
  
  .intro-image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }
  
  .intro-title {
    font-size: 1.75rem;
    font-weight: 900;
    color: var(--text-primary);
    margin-bottom: var(--space-3);
    text-align: center;
  }
  
  .intro-text {
    font-size: 1.15rem;
    line-height: 1.7;
    color: var(--text-primary);
    font-weight: 600;
  }
  
  /* Latest Articles */
  .latest-articles {
    background: var(--bg-secondary);
  }
  
  .featured-card {
    background: white;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
    overflow: hidden;
    margin-bottom: var(--space-4);
    transition: transform var(--transition-base), box-shadow var(--transition-base);
  }
  
  .featured-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }
  
  .featured-card a {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    text-decoration: none;
    color: inherit;
  }
  
  .featured-card__image-wrap { overflow: hidden; }
  
  .featured-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    min-height: 210px;
  }
  
  .featured-card__content {
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  
  .featured-card__title {
    font-size: 1.75rem;
    color: var(--brand-secondary);
    margin: var(--space-2) 0;
    line-height: 1.2;
  }
  
  .featured-card__text {
    color: var(--text-secondary);
    font-size: 1.05rem;
    line-height: 1.6;
    margin-bottom: var(--space-3);
  }
  
  .featured-card__read {
    font-family: var(--font-headline);
    color: var(--brand-primary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-size: 0.9rem;
    font-weight: 700;
  }
  
  .recent-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
  }
  
  /* Gallery section */
  .featured-galleries {
    background: white;
  }
  
  .gallery-intro {
    max-width: 100%;
    margin: 0 auto var(--space-6);
    text-align: center;
    font-size: 1.15rem;
    line-height: 1.7;
    color: var(--text-primary);
    font-weight: 600;
  }
  
  @media (max-width: 768px) {
    .featured-card a { grid-template-columns: 1fr; }
    .featured-card__image { min-height: 200px; }
    .recent-grid { grid-template-columns: 1fr; }
    .intro-grid { grid-template-columns: 1fr; }
    .intro-image-wrap { height: 220px; }
  }
</style>
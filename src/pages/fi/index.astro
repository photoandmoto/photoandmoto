---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import TrendingTicker from '../../components/TrendingTicker.astro';
import { getCollection } from 'astro:content';
import { ui } from '../../i18n/ui';

const lang = 'fi';
const t = ui[lang];

const articles = (await getCollection('articles', ({ data }) =>
  data.language === 'fi' && !data.draft
)).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const slugFor = (a: any) => `/fi/aikakone/${a.slug.replace(/^fi\//, '')}`;

// Featured grid: 1 big + 2 stacked
const bigCard = articles[0];
const stackedCards = articles.slice(1, 3);

// Secondary row: 4 cards
const secondaryCards = articles.slice(3, 7);

// Ticker: latest 5 article titles
const tickerItems = articles.slice(0, 5).map(a => ({
  href: slugFor(a),
  title: a.data.title,
}));

const galleries = await getCollection('galleries');
const featuredGalleries = galleries.slice(0, 4);
---

<BaseLayout
  title="Etusivu"
  lang={lang}
  description="Motocrossin ja moottoripyöräurheilun kuvia, tarinoita ja tuloksia 1960-luvulta nykypäivään. MXGP 2026, Aikakone-arkisto ja valokuvagalleria."
>
  <TrendingTicker label="Nyt luetuimmat" items={tickerItems} slot="pre-header" />

  {/* ===== Featured grid (hero) ===== */}
  {bigCard && (
    <section class="section featured-grid-section">
      <div class="container">
        <div class="featured-grid">
          <div class="featured-grid__big">
            <ArticleCard
              href={slugFor(bigCard)}
              image={bigCard.data.featured_image}
              category={bigCard.data.category}
              title={bigCard.data.title}
              subtitle={bigCard.data.subtitle}
              size="lg"
            />
          </div>
          <div class="featured-grid__stack">
            {stackedCards.map(a => (
              <ArticleCard
                href={slugFor(a)}
                image={a.data.featured_image}
                category={a.data.category}
                title={a.data.title}
                size="md"
              />
            ))}
          </div>
        </div>

        {secondaryCards.length > 0 && (
          <div class="secondary-row">
            {secondaryCards.map(a => (
              <ArticleCard
                href={slugFor(a)}
                image={a.data.featured_image}
                category={a.data.category}
                title={a.data.title}
                size="sm"
              />
            ))}
          </div>
        )}

        <div class="all-articles-link">
          <a href="/fi/aikakone" class="btn btn--secondary">Kaikki artikkelit</a>
        </div>
      </div>
    </section>
  )}

  {/* ===== Intro / welcome section ===== */}
  <section class="intro-section">
    <div class="container">
      <div class="intro-grid">
        <div class="intro-col">
          <h2 class="intro-title">Tervetuloa fiilistelemään</h2>
          <div class="intro-image-wrap">
            <img src="/images/intro-gallery.jpg" alt="Tervetuloa fiilistelemään" class="intro-image" />
          </div>
          <p class="intro-text">Moottoriurheilun historiaa ja huikeita tarinoita. Päivitämme kuvia ja juttuja jatkuvasti, joten pysy vauhdissa mukana!</p>
        </div>
        <div class="intro-col">
          <h2 class="intro-title">Palaa ajassa taaksepäin</h2>
          <div class="intro-image-wrap">
            <img src="/images/intro-articles.jpg" alt="Palaa ajassa taaksepäin" class="intro-image" />
          </div>
          <p class="intro-text">Syvenny moottoriurheilun tarinoihin ja tekniikkaan. Tuomme historian sykähdyttävimmät hetket suoraan luoksesi.</p>
        </div>
      </div>
    </div>
  </section>

  {/* ===== Gallery section ===== */}
  {featuredGalleries.length > 0 && (
    <section class="section featured-galleries">
      <div class="container">
        <div class="section__header">
          <h2 class="section__title">Galleria</h2>
          <p class="section__subtitle">Tutustu kuvagallerioihin</p>
        </div>

        <p class="gallery-intro">Löydä suosikkihetkesi helposti. Kuvat välittävät historian tunnelman ja vievät sinut suoraan lajin merkittävimpiin hetkiin aidoimmillaan.</p>

        <div class="grid grid--4">
          {featuredGalleries.map(gallery => (
            <article class="card">
              <a href={`/fi/galleria/${gallery.data.slug}`}>
                <img
                  src={`/galleries/${gallery.data.slug}/${gallery.data.cover_image}`}
                  alt={gallery.data.title}
                  class="card__image"
                  loading="lazy"
                />
                <div class="card__content">
                  <h3 class="card__title">{gallery.data.title}</h3>
                  <p class="card__text">
                    {t['gallery.photoCount'].replace('{count}', gallery.data.images.length.toString())}
                  </p>
                </div>
              </a>
            </article>
          ))}
        </div>

        <div style="text-align: center; margin-top: var(--space-6);">
          <a href="/fi/galleria" class="btn btn--secondary">Katso kaikki galleriat</a>
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .featured-grid-section {
    background: var(--bg-secondary);
    padding-top: var(--space-5);
    padding-bottom: var(--space-6);
  }

  /* 1 big + 2 stacked */
  .featured-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: var(--space-3);
  }

  .featured-grid__stack {
    display: grid;
    grid-template-rows: 1fr 1fr;
    gap: var(--space-3);
  }

  /* Secondary row: 4 cards */
  .secondary-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-3);
    margin-top: var(--space-3);
  }

  .all-articles-link {
    text-align: center;
    margin-top: var(--space-5);
  }

  /* Intro section */
  .intro-section {
    background: white;
    color: var(--text-primary);
    padding: var(--space-8) 0;
  }

  .intro-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6);
    align-items: start;
  }

  .intro-image-wrap {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-md);
    margin-bottom: var(--space-3);
    height: 280px;
  }

  .intro-image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .intro-title {
    font-size: 1.75rem;
    font-weight: 900;
    color: var(--text-primary);
    margin-bottom: var(--space-3);
    text-align: center;
  }

  .intro-text {
    font-size: 1.15rem;
    line-height: 1.7;
    color: var(--text-primary);
    font-weight: 600;
  }

  /* Gallery section */
  .featured-galleries {
    background: white;
  }

  .gallery-intro {
    max-width: 100%;
    margin: 0 auto var(--space-6);
    text-align: center;
    font-size: 1.15rem;
    line-height: 1.7;
    color: var(--text-primary);
    font-weight: 600;
  }

  /* Mobile */
  @media (max-width: 900px) {
    .featured-grid {
      grid-template-columns: 1fr;
    }
    .featured-grid__stack {
      grid-template-rows: auto auto;
      grid-template-columns: 1fr 1fr;
    }
    .secondary-row {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 540px) {
    .featured-grid__stack {
      grid-template-columns: 1fr;
    }
    .secondary-row {
      grid-template-columns: 1fr;
    }
    .intro-grid { grid-template-columns: 1fr; }
    .intro-image-wrap { height: 220px; }
  }
</style>

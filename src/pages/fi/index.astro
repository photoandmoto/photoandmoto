---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import TrendingTicker from '../../components/TrendingTicker.astro';
import UpcomingRaces from '../../components/UpcomingRaces.astro';
import { getCollection } from 'astro:content';
import { ui } from '../../i18n/ui';

const lang = 'fi';
const t = ui[lang];

const articles = (await getCollection('articles', ({ data }) =>
  data.language === 'fi' && !data.draft
)).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const slugFor = (a: any) => `/fi/aikakone/${a.slug.replace(/^fi\//, '')}`;
const imgFor = (a: any) => a.data.card_image || a.data.featured_image;

// Featured grid: 1 big + 2 stacked
const bigCard = articles[0];
const stackedCards = articles.slice(1, 3);

// Secondary row: 4 cards
const secondaryCards = articles.slice(3, 7);

// Ticker: latest 5 article titles
const tickerItems = articles.slice(0, 5).map(a => ({
  href: slugFor(a),
  title: a.data.title,
}));

const galleries = await getCollection('galleries');
const featuredGalleries = galleries.slice(0, 4);

// Podcast episodes (MVP: placeholder image for all)
const podcastEpisodes = [
  {
    title: 'Heikki Mikkola: Nelinkertainen Motocrossin Maailmanmestari',
    subtitle: 'Tarina legendaarisesta suomalaiskuljettajasta',
    href: '/fi/podcast#ep-0',
  },
  {
    title: 'Honda CR250: Legendan Synty ja Loppu',
    subtitle: 'Motocrossin ikonisimman pyörän tarina',
    href: '/fi/podcast#ep-1',
  },
  {
    title: 'Suzuki Motocross Racing: From Disastrous Start to Golden Era',
    subtitle: 'Suzukin tie motocrossin kultaiselle aikakaudelle',
    href: '/fi/podcast#ep-2',
  },
  {
    title: 'Motocross of Nations: Historia ja Voittajat',
    subtitle: 'Motocross of Nations -kilpailun legendat',
    href: '/fi/podcast#ep-3',
  },
];
---

<BaseLayout
  title="Etusivu"
  lang={lang}
  description="Motocrossin ja moottoripyöräurheilun kuvia, tarinoita ja tuloksia 1960-luvulta nykypäivään. MXGP 2026, Aikakone-arkisto ja valokuvagalleria."
>
  <TrendingTicker label="Nyt luetuimmat" items={tickerItems} slot="pre-header" />

  {/* ===== Featured grid (hero) ===== */}
  {bigCard && (
    <section class="section featured-grid-section">
      <div class="container">
        <div class="section-header-row">
          <h2 class="section-heading">Uusimmat artikkelit</h2>
          <a href="/fi/aikakone" class="section-all-link">Kaikki artikkelit →</a>
        </div>
        <div class="featured-grid">
          <div class="featured-grid__big">
            <ArticleCard
              href={slugFor(bigCard)}
              image={imgFor(bigCard)}
              category={bigCard.data.category}
              title={bigCard.data.title}
              subtitle={bigCard.data.subtitle}
              size="lg"
            />
          </div>
          <div class="featured-grid__stack">
            {stackedCards.map(a => (
              <ArticleCard
                href={slugFor(a)}
                image={imgFor(a)}
                category={a.data.category}
                title={a.data.title}
                size="md"
              />
            ))}
          </div>
        </div>

        {secondaryCards.length > 0 && (
          <div class="secondary-row">
            {secondaryCards.map(a => (
              <ArticleCard
                href={slugFor(a)}
                image={imgFor(a)}
                category={a.data.category}
                title={a.data.title}
                size="sm"
              />
            ))}
          </div>
        )}
      </div>
    </section>
  )}

  {/* ===== Upcoming races band ===== */}
  <UpcomingRaces />

  {/* ===== Gallery section (restyled to match article cards) ===== */}
  {featuredGalleries.length > 0 && (
    <section class="section gallery-section">
      <div class="container">
        <div class="section-header-row">
          <h2 class="section-heading">Galleria</h2>
          <a href="/fi/galleria" class="section-all-link">Kaikki galleriat →</a>
        </div>

        <div class="gallery-grid">
          {featuredGalleries.map(gallery => (
            <ArticleCard
              href={`/fi/galleria/${gallery.data.slug}`}
              image={`/galleries/${gallery.data.slug}/${gallery.data.cover_image}`}
              title={gallery.data.title}
              subtitle={t['gallery.photoCount'].replace('{count}', gallery.data.images.length.toString())}
              size="sm"
            />
          ))}
        </div>
      </div>
    </section>
  )}

  {/* ===== Podcast section ===== */}
  <section class="section podcast-section">
    <div class="container">
      <div class="section-header-row">
        <h2 class="section-heading">Podcast</h2>
        <a href="/fi/podcast" class="section-all-link">Kaikki jaksot →</a>
      </div>

      <div class="podcast-grid">
        {podcastEpisodes.map(ep => (
          <ArticleCard
            href={ep.href}
            image="/images/hero-podcast.jpg"
            title={ep.title}
            subtitle={ep.subtitle}
            size="sm"
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Section shared */
  .section-header-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: var(--space-4);
    gap: var(--space-3);
  }

  .section-heading {
    font-family: var(--font-headline);
    font-size: 1.75rem;
    font-weight: 900;
    color: var(--text-primary);
    margin: 0;
  }

  .section-all-link {
    font-family: var(--font-headline);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--brand-primary);
    text-decoration: none;
    white-space: nowrap;
  }
  .section-all-link:hover {
    text-decoration: underline;
  }

  /* Articles section */
  .featured-grid-section {
    background: var(--bg-secondary);
    padding-top: var(--space-5);
    padding-bottom: var(--space-6);
  }

  /* 1 big + 2 stacked — columns sync height */
  .featured-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: var(--space-3);
    align-items: stretch;
  }

  .featured-grid__big {
    display: flex;
    min-height: 500px;
  }
  .featured-grid__big > article {
    width: 100%;
  }

  .featured-grid__stack {
    display: grid;
    grid-template-rows: 1fr 1fr;
    gap: var(--space-3);
  }
  .featured-grid__stack > article {
    min-height: 0;
  }

  /* Secondary row: 4 cards */
  .secondary-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-3);
    margin-top: var(--space-3);
  }

  /* Gallery section */
  .gallery-section {
    background: white;
    padding: var(--space-6) 0;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-3);
  }

  /* Podcast section */
  .podcast-section {
    background: var(--bg-secondary);
    padding: var(--space-6) 0;
  }

  .podcast-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-3);
  }

  /* Responsive breakpoints */
  @media (max-width: 900px) {
    .featured-grid {
      grid-template-columns: 1fr;
    }
    .featured-grid__big {
      min-height: 320px;
    }
    .featured-grid__stack {
      grid-template-rows: auto auto;
      grid-template-columns: 1fr 1fr;
    }
    .secondary-row,
    .gallery-grid,
    .podcast-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 540px) {
    .featured-grid__stack {
      grid-template-columns: 1fr;
    }
    .secondary-row,
    .gallery-grid,
    .podcast-grid {
      grid-template-columns: 1fr;
    }
    .section-heading {
      font-size: 1.4rem;
    }
  }
</style>

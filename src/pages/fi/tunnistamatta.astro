---
import BaseLayout from '../../layouts/BaseLayout.astro';
const lang = 'fi';
---
<BaseLayout title="Tunnista kuva" lang={lang} description="Auta tunnistamaan vanhoja moottoriurheilukuvia.">
  <section class="mp">
    <div class="container">
      <div class="mp-header">
        <h1 class="mp-title">Tunnista kuva</h1>
        <p class="mp-sub">Auta meitä tunnistamaan vanhoja moottoriurheilukuvia. Kuka on kuvassa? Mistä vuodelta? Missä otettu?</p>
        <button id="adminToggle" class="mp-btn mp-btn--sec">Ylläpito</button>
      </div>

      <!-- Admin panel -->
      <div id="adminPanel" class="mp-panel" style="display:none;">
        <div id="adminAuth" class="auth-box">
          <input type="password" id="adminPw" class="mp-inp" placeholder="Salasana" />
          <button id="adminPwBtn" class="mp-btn">Kirjaudu</button>
          <span id="adminPwErr" class="auth-err" style="display:none;">Väärä salasana</span>
        </div>
        <div id="adminArea" style="display:none;">
          <h3 class="panel-title">Lähetä kuva tunnistettavaksi</h3>
          <p class="form-hint">Täytä kentät joita tiedät. Tyhjät kentät avautuvat yhteisölle.</p>
          <div class="form-grid">
            <div class="fg fg--full"><label>Kuva *</label><input type="file" id="photoFile" accept="image/jpeg,image/png,image/webp" class="mp-inp" /></div>
            <div class="fg"><label>Vuosiarvio</label><input type="text" id="fYear" class="mp-inp" placeholder="Esim. 1977" /></div>
            <div class="fg"><label>Henkilöt kuvassa</label><input type="text" id="fPeople" class="mp-inp" placeholder="Keitä tunnistat?" /></div>
            <div class="fg"><label>Paikka / tapahtuma</label><input type="text" id="fLocation" class="mp-inp" placeholder="Missä otettu?" /></div>
            <div class="fg"><label>Lisätietoja</label><input type="text" id="fNotes" class="mp-inp" placeholder="Muuta tietoa?" /></div>
          </div>
          <button id="uploadBtn" class="mp-btn">Lataa kuva</button>
          <div id="uploadMsg"></div>
        </div>
      </div>

      <!-- Filters -->
      <div class="filters">
        <button class="filt is-on" data-s="all">Kaikki</button>
        <button class="filt" data-s="new">Uudet</button>
        <button class="filt" data-s="partial">Osittain tunnistettu</button>
      </div>

      <!-- Grid -->
      <div id="grid" class="grid"><div class="empty">Ladataan kuvia...</div></div>

      <!-- Modal -->
      <div id="modal" class="modal" style="display:none;">
        <div class="modal-bg"></div>
        <div class="modal-box">
          <button class="modal-x" id="modalX">&#x2715;</button>
          <div class="modal-layout">
            <div class="modal-left">
              <div class="modal-img-wrap"><img id="modalImg" class="modal-img" src="" alt="" /></div>
              <div id="modalForm" class="modal-form-card"></div>
            </div>
            <div class="modal-right">
              <div class="modal-thread-card" id="modalThread"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
let photos=[],adminPw=null,curFilter='all',curPhoto=null;
const voted=JSON.parse(localStorage.getItem('pm_v')||'{}');
const grid=document.getElementById('grid');
const modal=document.getElementById('modal');

const FIELDS=[
  {key:'year_estimate',label:'Vuosiarvio',type:'year',ph:'Esim. 1977'},
  {key:'people',label:'Henkilöt kuvassa',type:'people',ph:'Kenet tunnistat?'},
  {key:'location_notes',label:'Paikka / tapahtuma',type:'location',ph:'Missä otettu?'},
  {key:'notes',label:'Lisätietoja',type:'notes',ph:'Mitä muuta tiedät?'},
];
const FIELD_LABELS={year:'Vuosiarvio',people:'Henkilöt',location:'Paikka',notes:'Lisätiedot',general:''};

fetch('/api/mystery/init',{method:'POST'}).catch(()=>{});

async function verifyPw(pw){
  const r=await fetch('/api/mystery/verify',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({password:pw})});
  return (await r.json()).valid===true;
}

async function load(){
  try{const r=await fetch('/api/mystery/photos');photos=(await r.json()).photos||[];renderGrid();}
  catch(e){grid.innerHTML='<div class="empty">Virhe ladattaessa.</div>';}
}

function renderGrid(){
  const f=curFilter==='all'?photos:photos.filter(p=>p.status===curFilter);
  if(!f.length){grid.innerHTML='<div class="empty">Ei kuvia tässä kategoriassa.</div>';return;}
  grid.innerHTML=f.map(p=>`
    <div class="card" data-id="${p.id}">
      <div class="card-img"><img src="${p.image_url}" alt="" loading="lazy"/>
        <span class="card-badge card-badge--${p.status}">${p.status==='new'?'Uusi':'Osittain'}</span>
        ${p.comments.length?`<span class="card-count">${p.comments.length} 💬</span>`:''}
      </div>
      <div class="card-info">
        ${p.people?`<span class="card-who">${esc(p.people)}</span>`:''}
        ${p.year_estimate?`<span class="card-yr">${esc(p.year_estimate)}</span>`:''}
        ${!p.people&&!p.year_estimate?'<span class="card-unk">Tuntematon — auta tunnistamaan!</span>':''}
      </div>
    </div>`).join('');
  grid.querySelectorAll('.card').forEach(c=>c.addEventListener('click',()=>openModal(+c.dataset.id)));
}

function openModal(id){
  const p=photos.find(x=>x.id===id);if(!p)return;
  curPhoto=p;
  document.getElementById('modalImg').src=p.image_url;

  // Left: form card
  const formEl=document.getElementById('modalForm');
  if(adminPw){ renderAdminForm(p,formEl); }
  else { renderCommunityForm(p,formEl); }

  // Right: thread
  renderThread(p);

  modal.style.display='flex';
  document.body.style.overflow='hidden';
}

// ===== COMMUNITY FORM =====
function renderCommunityForm(p,el){
  const locked=FIELDS.filter(f=>p[f.key]&&p[f.key].trim());
  const open=FIELDS.filter(f=>!p[f.key]||!p[f.key].trim());

  el.innerHTML=`
    <h3 class="fc-title">Kommentoi tiedoilla</h3>
    <p class="fc-hint">Yksi tai kaikki</p>
    ${locked.length?`<div class="fc-locked">${locked.map(f=>`<div class="fc-lf"><span class="fc-lf-label">${f.label}:</span> <strong>${esc(p[f.key])}</strong></div>`).join('')}</div>`:''}
    <div class="fc-fields">
      <div class="fc-row"><label>Nimesi (vapaaehtoinen)</label><input type="text" class="fc-inp" id="sfName" placeholder="Nimetön" /></div>
      ${open.map(f=>`<div class="fc-row"><label>${f.label}</label><input type="text" class="fc-inp sf-inp" data-ft="${f.type}" placeholder="${f.ph}" /></div>`).join('')}
      <div class="fc-row"><label>Vapaa kommentti</label><textarea class="fc-inp fc-ta" id="sfComment" placeholder="Muita havaintoja..."></textarea></div>
      <button class="fc-btn" id="sfSubmit">Lähetä</button>
    </div>`;

  el.querySelector('#sfSubmit').addEventListener('click',async()=>{
    const name=(el.querySelector('#sfName').value.trim())||'Nimetön';
    const promises=[];
    el.querySelectorAll('.sf-inp').forEach(inp=>{
      const val=inp.value.trim();
      if(val.length>=2){
        promises.push(fetch('/api/mystery/comment',{method:'POST',headers:{'Content-Type':'application/json'},
          body:JSON.stringify({photo_id:p.id,author_name:name,content:val,field_type:inp.dataset.ft})}));
        inp.value='';
      }
    });
    const comment=el.querySelector('#sfComment').value.trim();
    if(comment.length>=2){
      promises.push(fetch('/api/mystery/comment',{method:'POST',headers:{'Content-Type':'application/json'},
        body:JSON.stringify({photo_id:p.id,author_name:name,content:comment,field_type:'general'})}));
      el.querySelector('#sfComment').value='';
    }
    if(promises.length){await Promise.all(promises);await load();openModal(p.id);}
  });
}

// ===== ADMIN FORM =====
function renderAdminForm(p,el){
  el.innerHTML=`
    <h3 class="fc-title ab-color">Ylläpito</h3>
    <div class="fc-fields">
      ${FIELDS.map(f=>`<div class="fc-row"><label>${f.label}</label><input type="text" class="fc-inp" id="ab_${f.key}" value="${esc(p[f.key]||'')}" /></div>`).join('')}
      <div class="ab-bar">
        <button class="fc-btn" id="abSave">Tallenna</button>
        <select class="fc-inp ab-sel" id="abStatus">
          <option value="new" ${p.status==='new'?'selected':''}>Uusi</option>
          <option value="partial" ${p.status==='partial'?'selected':''}>Osittain</option>
          <option value="identified" ${p.status==='identified'?'selected':''}>Tunnistettu</option>
        </select>
        <button class="fc-btn ab-status-btn" id="abSetStatus">Päivitä tila</button>
      </div>
      <button class="fc-btn fc-btn--danger" id="abDel">Poista kuva</button>
    </div>`;

  el.querySelector('#abSave').addEventListener('click',async()=>{
    await adminAction('update_meta',{photo_id:p.id,
      year_estimate:el.querySelector('#ab_year_estimate').value,
      people:el.querySelector('#ab_people').value,
      location_notes:el.querySelector('#ab_location_notes').value,
      notes:el.querySelector('#ab_notes').value});
    await load();openModal(p.id);
  });
  el.querySelector('#abSetStatus').addEventListener('click',async()=>{
    await adminAction('set_status',{photo_id:p.id,status:el.querySelector('#abStatus').value});
    await load();openModal(p.id);
  });
  el.querySelector('#abDel').addEventListener('click',async()=>{
    if(!confirm('Poistetaanko kuva pysyvästi?'))return;
    await adminAction('delete_photo',{photo_id:p.id});
    closeModal();await load();
  });
}

// ===== THREAD =====
function renderThread(p){
  const threadEl=document.getElementById('modalThread');
  const topLevel=p.comments.filter(c=>!c.parent_id);

  let html=`<h3 class="th-title">Kommentoi keskustelua</h3>`;
  if(!topLevel.length){
    html+=`<p class="th-empty">Ei vielä keskustelua.</p>`;
  } else {
    html+=`<div class="th-list">`;
    html+=topLevel.map(c=>{
      const replies=p.comments.filter(r=>r.parent_id===c.id);
      const tag=c.field_type&&c.field_type!=='general'?`<span class="th-tag">${FIELD_LABELS[c.field_type]||''}</span>`:'';
      return `<div class="th-post">
        <div class="th-head">${tag}<span class="th-author">${esc(c.author_name)}</span><span class="th-date">${fmtDate(c.created_at)}</span>${adminPw?`<button class="th-del" data-cid="${c.id}">🗑</button>`:''}</div>
        ${c.field_type&&c.field_type!=='general'?`<div class="th-field-label">${FIELD_LABELS[c.field_type]}:</div>`:''}
        <p class="th-text">${esc(c.content)}</p>
        <div class="th-foot">${voteBtns(c)}<button class="th-reply-btn" data-cid="${c.id}">Kommentoi</button></div>
        <div class="th-reply-box" id="rb-${c.id}" style="display:none;">
          <input type="text" class="fc-inp th-reply-inp" placeholder="Kommenttisi..." />
          <button class="fc-btn fc-btn--sm th-reply-send" data-cid="${c.id}" data-pid="${p.id}">Lähetä</button>
        </div>
        ${replies.length?`<div class="th-replies">${replies.map(r=>`
          <div class="th-post th-post--reply">
            <div class="th-head"><span class="th-author">${esc(r.author_name)}</span><span class="th-date">${fmtDate(r.created_at)}</span>${adminPw?`<button class="th-del" data-cid="${r.id}">🗑</button>`:''}</div>
            <p class="th-text">${esc(r.content)}</p>
            <div class="th-foot">${voteBtns(r)}</div>
          </div>`).join('')}</div>`:''}
      </div>`;
    }).join('');
    html+=`</div>`;
  }
  threadEl.innerHTML=html;

  // Bind votes
  threadEl.querySelectorAll('.th-vote').forEach(btn=>btn.addEventListener('click',async e=>{
    e.stopPropagation();
    const cid=+btn.dataset.cid,v=+btn.dataset.v;
    if(voted[cid])return;
    const r=await fetch('/api/mystery/vote',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({comment_id:cid,vote:v})});
    if((await r.json()).success){voted[cid]=v;localStorage.setItem('pm_v',JSON.stringify(voted));await load();openModal(curPhoto.id);}
  }));

  // Bind Kommentoi toggles
  threadEl.querySelectorAll('.th-reply-btn').forEach(btn=>btn.addEventListener('click',()=>{
    const rb=document.getElementById('rb-'+btn.dataset.cid);
    rb.style.display=rb.style.display==='none'?'flex':'none';
  }));

  // Bind reply submit
  threadEl.querySelectorAll('.th-reply-send').forEach(btn=>btn.addEventListener('click',async()=>{
    const inp=btn.parentElement.querySelector('.th-reply-inp');
    const txt=inp.value.trim();if(txt.length<2)return;
    const nameEl=document.getElementById('sfName');
    const name=nameEl?nameEl.value.trim()||'Nimetön':'Nimetön';
    await fetch('/api/mystery/comment',{method:'POST',headers:{'Content-Type':'application/json'},
      body:JSON.stringify({photo_id:+btn.dataset.pid,author_name:name,content:txt,field_type:'general',parent_id:+btn.dataset.cid})});
    await load();openModal(curPhoto.id);
  }));

  // Admin delete
  if(adminPw){threadEl.querySelectorAll('.th-del').forEach(btn=>btn.addEventListener('click',async e=>{
    e.stopPropagation();if(!confirm('Poistetaanko?'))return;
    await adminAction('delete_comment',{comment_id:+btn.dataset.cid});
    await load();openModal(curPhoto.id);
  }));}
}

function voteBtns(c){
  const v=voted[c.id];
  return `<button class="th-vote ${v===1?'th-vote--on':''}" data-cid="${c.id}" data-v="1">👍 ${c.upvotes||0}</button><button class="th-vote ${v===-1?'th-vote--on':''}" data-cid="${c.id}" data-v="-1">👎 ${c.downvotes||0}</button>`;
}

function fmtDate(d){return new Date(d).toLocaleDateString('fi-FI');}
async function adminAction(action,data){
  await fetch('/api/mystery/admin',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({password:adminPw,action,...data})});
}

function closeModal(){modal.style.display='none';document.body.style.overflow='';curPhoto=null;}
document.getElementById('modalX').addEventListener('click',closeModal);
document.querySelector('.modal-bg').addEventListener('click',closeModal);
document.addEventListener('keydown',e=>{if(e.key==='Escape')closeModal();});

// Admin toggle + auth
document.getElementById('adminToggle').addEventListener('click',()=>{
  const p=document.getElementById('adminPanel');p.style.display=p.style.display==='none'?'block':'none';
});
document.getElementById('adminPwBtn').addEventListener('click',async()=>{
  const pw=document.getElementById('adminPw').value;
  if(await verifyPw(pw)){adminPw=pw;document.getElementById('adminAuth').style.display='none';document.getElementById('adminArea').style.display='block';}
  else{document.getElementById('adminPwErr').style.display='inline';}
});

// Upload
document.getElementById('uploadBtn').addEventListener('click',async()=>{
  const file=document.getElementById('photoFile').files[0];if(!file)return;
  const fd=new FormData();
  fd.append('photo',file);fd.append('password',adminPw);
  fd.append('year_estimate',document.getElementById('fYear').value);
  fd.append('people',document.getElementById('fPeople').value);
  fd.append('location_notes',document.getElementById('fLocation').value);
  fd.append('notes',document.getElementById('fNotes').value);
  const msg=document.getElementById('uploadMsg');
  msg.innerHTML='<span class="msg-load">Ladataan...</span>';
  document.getElementById('uploadBtn').disabled=true;
  try{
    const r=await fetch('/api/mystery/upload',{method:'POST',body:fd});const d=await r.json();
    if(d.success){msg.innerHTML='<span class="msg-ok">✓ Kuva ladattu!</span>';
      ['photoFile','fYear','fPeople','fLocation','fNotes'].forEach(id=>document.getElementById(id).value='');
      await load();}
    else{msg.innerHTML=`<span class="msg-err">${d.error}</span>`;}
  }catch(e){msg.innerHTML='<span class="msg-err">Virhe</span>';}
  document.getElementById('uploadBtn').disabled=false;
});

// Filters
document.querySelectorAll('.filt').forEach(b=>b.addEventListener('click',()=>{
  document.querySelectorAll('.filt').forEach(x=>x.classList.remove('is-on'));
  b.classList.add('is-on');curFilter=b.dataset.s;renderGrid();
}));

function esc(s){const d=document.createElement('div');d.textContent=s||'';return d.innerHTML;}
load();
</script>

<style is:global>
/* ===== Page ===== */
.mp{background:var(--bg-secondary);padding:var(--space-6) 0 var(--space-12);min-height:80vh}
.mp-header{margin-bottom:var(--space-5)}
.mp-title{font-family:var(--font-headline);font-size:2rem;font-weight:900;margin:0 0 var(--space-2)}
.mp-sub{font-size:1rem;color:var(--text-secondary);margin:0 0 var(--space-3);max-width:550px}
.mp-btn{font-family:var(--font-headline);font-size:.85rem;font-weight:700;padding:10px 20px;border-radius:8px;border:2px solid var(--brand-primary);background:var(--brand-primary);color:#000;cursor:pointer;transition:all .15s}
.mp-btn:hover{background:#e08800;border-color:#e08800}
.mp-btn--sec{background:transparent;color:var(--brand-primary)}
.mp-btn--sec:hover{background:var(--brand-primary);color:#000}
.mp-btn:disabled{opacity:.5;cursor:not-allowed}
.mp-inp{font-family:var(--font-body);font-size:.9rem;padding:8px 12px;border:2px solid #ddd;border-radius:6px;background:#fff;color:var(--text-primary);width:100%;box-sizing:border-box}
.mp-inp:focus{border-color:var(--brand-primary);outline:none}

/* Admin top panel */
.mp-panel{background:#fff;border-radius:12px;padding:24px;margin-bottom:20px;border:1px solid #eee}
.panel-title{font-family:var(--font-headline);font-size:1.1rem;font-weight:800;margin:0 0 8px}
.auth-box{display:flex;gap:10px;align-items:center;flex-wrap:wrap}
.auth-box .mp-inp{flex:1;min-width:150px;max-width:280px}
.auth-err{color:#E24B4A;font-size:.85rem;font-weight:600}
.form-hint{font-size:.85rem;color:var(--text-secondary);margin:0 0 16px}
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:16px}
.fg label{display:block;font-size:.8rem;font-weight:600;color:var(--text-secondary);margin-bottom:3px}
.fg--full{grid-column:1/-1}
.msg-ok{color:#1D9E75;font-weight:600;font-size:.9rem}
.msg-err{color:#E24B4A;font-weight:600;font-size:.9rem}
.msg-load{color:var(--brand-primary);font-weight:600;font-size:.9rem}

/* Filters */
.filters{display:flex;gap:8px;margin-bottom:20px;flex-wrap:wrap}
.filt{font-family:var(--font-headline);font-size:.78rem;font-weight:700;padding:6px 14px;border-radius:20px;border:2px solid #ccc;background:transparent;color:var(--text-secondary);cursor:pointer;transition:all .15s}
.filt.is-on,.filt:hover{border-color:var(--brand-primary);color:var(--brand-primary)}
.filt.is-on{background:var(--brand-primary);color:#000}

/* Grid */
.grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px}
.card{background:#fff;border-radius:12px;overflow:hidden;cursor:pointer;transition:transform .15s,box-shadow .15s}
.card:hover{transform:translateY(-3px);box-shadow:0 4px 20px rgba(0,0,0,.12)}
.card-img{position:relative;aspect-ratio:4/3;overflow:hidden}
.card-img img{width:100%;height:100%;object-fit:cover;display:block}
.card-badge{position:absolute;top:8px;left:8px;font-family:var(--font-headline);font-size:.6rem;font-weight:700;color:#fff;padding:2px 8px;border-radius:10px;text-transform:uppercase}
.card-badge--new{background:var(--brand-primary)}
.card-badge--partial{background:#378ADD}
.card-count{position:absolute;bottom:8px;right:8px;font-size:.75rem;font-weight:700;color:#fff;background:rgba(0,0,0,.6);padding:2px 8px;border-radius:10px}
.card-info{padding:10px 12px}
.card-who{font-size:.8rem;font-weight:600;color:var(--text-primary)}
.card-yr{font-size:.8rem;font-weight:700;color:var(--brand-primary);margin-left:6px}
.card-unk{font-size:.8rem;color:#aaa;font-style:italic}
.empty{text-align:center;color:var(--text-secondary);padding:40px;grid-column:1/-1}

/* ===== MODAL ===== */
.modal{position:fixed;inset:0;z-index:1000;display:flex;align-items:center;justify-content:center;padding:20px}
.modal-bg{position:absolute;inset:0;background:rgba(0,0,0,.85)}
.modal-box{position:relative;background:#f0f0f0;border-radius:16px;max-width:1200px;width:100%;max-height:90vh;overflow:hidden}
.modal-x{position:absolute;top:12px;right:16px;font-size:1.5rem;background:none;border:none;cursor:pointer;color:#666;z-index:10}

/* Three-area layout */
.modal-layout{display:grid;grid-template-columns:1fr 1fr;max-height:90vh}
.modal-left{display:flex;flex-direction:column;overflow:hidden}
.modal-img-wrap{background:#000;display:flex;align-items:center;justify-content:center;flex:0 0 auto;max-height:50vh}
.modal-img{width:100%;height:100%;max-height:50vh;object-fit:contain}

/* Form card (below photo on left) */
.modal-form-card{background:#fff;border-radius:12px;margin:12px;padding:20px;flex:1;overflow-y:auto}

/* Thread card (right side, full height) */
.modal-right{overflow-y:auto;max-height:90vh;padding:12px 12px 12px 0}
.modal-thread-card{background:#fff;border-radius:12px;padding:20px;min-height:100%}

/* ===== FORM CARD CONTENT ===== */
.fc-title{font-family:var(--font-headline);font-size:1rem;font-weight:800;margin:0 0 4px;color:var(--text-primary)}
.ab-color{color:var(--brand-primary)}
.fc-hint{font-size:.82rem;color:var(--text-secondary);margin:0 0 12px}
.fc-locked{margin-bottom:12px;padding-bottom:12px;border-bottom:1px solid #eee}
.fc-lf{font-size:.88rem;margin-bottom:4px}
.fc-lf-label{font-size:.78rem;color:var(--text-secondary);font-weight:600}
.fc-fields{display:flex;flex-direction:column;gap:10px}
.fc-row label{display:block;font-size:.78rem;font-weight:700;color:var(--text-secondary);margin-bottom:3px}
.fc-inp{font-family:var(--font-body);font-size:.88rem;padding:8px 12px;border:2px solid #ddd;border-radius:6px;background:#fff;color:var(--text-primary);width:100%;box-sizing:border-box}
.fc-inp:focus{border-color:var(--brand-primary);outline:none}
.fc-ta{min-height:50px;resize:vertical}
.fc-btn{font-family:var(--font-headline);font-size:.82rem;font-weight:700;padding:10px 20px;border-radius:8px;border:2px solid var(--brand-primary);background:var(--brand-primary);color:#000;cursor:pointer;transition:all .15s;width:100%;text-align:center}

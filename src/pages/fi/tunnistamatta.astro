---
import BaseLayout from '../../layouts/BaseLayout.astro';
const lang = 'fi';
---
<BaseLayout title="Tunnista kuva" lang={lang} description="Auta tunnistamaan vanhoja moottoriurheilukuvia.">
  <section class="mp">
    <div class="container">
      <div class="mp-header">
        <div class="mp-header__left">
          <h1 class="mp-title">Tunnista kuva</h1>
          <p class="mp-sub" id="mpSubCommunity">Auta meitä tunnistamaan vanhoja moottoriurheilukuvia.<br/>Kuka on kuvassa? Mistä vuodelta? Missä otettu?</p>
          <div class="mp-sub mp-sub--admin mp-sub--collapsed" id="mpSubAdmin" style="display:none;">
            <button type="button" class="ohje-toggle" id="ohjeToggle">
              <span class="ohje-toggle__label">Ohje</span>
              <span class="ohje-toggle__icon">▸</span>
            </button>
            <div class="ohje-content">
              <div class="ohje-section">
                <span class="ohje-section__title">Tarkista-välilehti</span>
                <div class="ohje-subsection">
                  <span class="ohje-subsection__title">Yleistä</span>
                  <ul class="ohje-list">
                    <li>Klikkaa kuvaa → lue yhteisön ehdotukset</li>
                    <li>Kirjoita viralliset tiedot per kenttä ja tallenna</li>
                    <li>Kun vuosi, henkilöt ja paikka on täytetty → status muuttuu Tunnistetuksi</li>
                    <li>Julkaise Galleriaan siirtää kuvan pysyvään galleriaan</li>
                  </ul>
                </div>
                <div class="ohje-subsection">
                  <span class="ohje-subsection__title">Julkaise olemassa olevaan galleriaan</span>
                  <ul class="ohje-list">
                    <li>Avaa Tunnistettu-kuva → klikkaa <strong>Julkaise Galleriaan</strong></li>
                    <li>Valitse galleria pudotusvalikosta</li>
                    <li>Tarkista kuvateksti (vakio: henkilöt + paikka + vuosi) ja muokkaa tarvittaessa</li>
                    <li>Klikkaa <strong>Julkaise</strong> → kuva ilmestyy galleriaan ~2 minuutissa</li>
                  </ul>
                </div>
                <div class="ohje-subsection">
                  <span class="ohje-subsection__title">Luo uusi galleria</span>
                  <ul class="ohje-list">
                    <li>Avaa Tunnistettu-kuva → klikkaa <strong>Julkaise Galleriaan</strong></li>
                    <li>Valitse pudotusvalikosta <strong>➕ Luo uusi galleria…</strong></li>
                    <li>Anna gallerialle nimi alla olevien ohjeiden mukaisesti</li>
                    <li>Tarkista kuvateksti ja klikkaa <strong>Julkaise</strong></li>
                  </ul>
                  <div class="ohje-naming">
                    <span class="ohje-naming__title">Nimeämiskäytäntö</span>
                    <p class="ohje-naming__intro">Galleriat järjestyvät indeksisivulla aakkosjärjestyksessä. Käytä näitä kaavoja, jotta uusi galleria asettuu loogiseen paikkaan olemassa olevien rinnalle:</p>
                    <ul class="ohje-list">
                      <li><strong>Vuosikymmen-galleria:</strong> <em>Suomi 60s</em>, <em>International 60s</em> — käytä kaksinumeroista vuosikymmentä, jotta järjestys pysyy yhtenäisenä olemassa olevien kanssa</li>
                      <li><strong>Tapahtuma- tai paikkagalleria:</strong> <em>Hyvinkää Scramble 2026</em>, <em>Orimattila SM 1984</em> — paikka ensin, sitten tapahtuma ja vuosi</li>
                      <li><strong>Erikoiskategoria:</strong> <em>Enduro 70s</em>, <em>Black White 60s</em> — laji + vuosikymmen</li>
                    </ul>
                    <p class="ohje-naming__hint"><strong>Vinkki:</strong> Kirjoita nimi suomeksi ja luonnollisilla välilyönneillä — ä/ö/å muunnetaan automaattisesti URL-osoitteen muotoon (esim. "Hyvinkää" → <code>hyvinkaa</code>).</p>
                  </div>
                </div>
                <div class="ohje-subsection">
                  <span class="ohje-subsection__title">Suodattimet</span>
                  <ul class="ohje-list">
                    <li><strong>Tarkistettavaa</strong> — kuvia, joihin on tullut uusia ehdotuksia tai jotka on ladattu edellisen kirjautumisen jälkeen</li>
                    <li><strong>Kesken</strong> — osittain täytetyt tai tyhjät kuvat, ei uutta aktiviteettia</li>
                    <li><strong>Valmiit</strong> — tunnistetut kuvat, valmiina julkaistavaksi galleriaan</li>
                  </ul>
                </div>
              </div>
              <div class="ohje-section">
                <span class="ohje-section__title">Lähetä kuva -välilehti</span>
                <ul class="ohje-list">
                  <li>Valitse kuvatiedosto (JPEG, PNG, WEBP, max 5 MB)</li>
                  <li>Täytä tiedot, jotka jo tiedät — tyhjät kentät aukeavat yhteisön ehdotettavaksi</li>
                  <li>Lataa kuva → näkyy heti yhteisölle</li>
                </ul>
              </div>
            </div>
          </div>
        </div>
        <div class="mp-header__right">
          <a href="#" id="adminToggle" class="admin-link">Ylläpito →</a>
          <div id="adminActions" class="admin-actions" style="display:none;">
            <button id="adminLogout" class="admin-logout">Kirjaudu ulos</button>
          </div>
        </div>
      </div>

      <!-- Admin login panel (small, shown on demand) -->
      <div id="adminPanel" class="admin-panel" style="display:none;">
        <div id="adminAuth" class="admin-auth">
          <input type="password" id="adminPw" class="inp" placeholder="Salasana" />
          <button id="adminPwBtn" class="btn">Kirjaudu</button>
          <span id="adminPwErr" class="err-msg" style="display:none;">Väärä salasana</span>
        </div>
      </div>

      <!-- Admin tabs (visible only when logged in) -->
      <div id="adminTabs" class="admin-tabs" style="display:none;">
        <button type="button" class="admin-tab admin-tab--on" data-tab="tarkista">Tarkista</button>
        <button type="button" class="admin-tab" data-tab="laheta">Lähetä kuva</button>
        <button type="button" class="admin-tab" data-tab="hallitse">Hallitse galleriaa</button>
      </div>

      <!-- Tarkista tab: filters + grid (community sees filters too) -->
      <div id="tabTarkista" class="tab-content">
        <div class="filters" id="filterBar"></div>
        <div id="grid" class="photo-grid"><div class="grid-empty">Ladataan kuvia...</div></div>
      </div>

      <!-- Lähetä tab: upload form (admin only) -->
      <div id="tabLaheta" class="tab-content" style="display:none;">
        <div class="upload-section">
          <h3 class="upload-title">Lähetä kuva tunnistettavaksi</h3>
          <p class="upload-hint">Täytä kentät joita tiedät. Tyhjät kentät avautuvat yhteisölle.</p>
          <div class="upload-stack">
            <div class="uf"><label>Kuva *</label><input type="file" id="photoFile" accept="image/jpeg,image/png,image/webp" class="inp" /></div>
            <div class="uf"><label>Vuosiarvio</label><input type="text" id="fYear" class="inp" placeholder="Esim. 1977" /></div>
            <div class="uf"><label>Henkilöt kuvassa</label><input type="text" id="fPeople" class="inp" placeholder="Keitä tunnistat?" /></div>
            <div class="uf"><label>Paikka / tapahtuma</label><input type="text" id="fLocation" class="inp" placeholder="Missä otettu?" /></div>
            <div class="uf"><label>Lisätietoja</label><input type="text" id="fNotes" class="inp" placeholder="Muuta tietoa?" /></div>
          </div>
          <div class="upload-copyright">
            <strong>⚠ Ennen lähettämistä varmista</strong>, että sinulla on kuvan tekijänoikeudet tai oikeudenhaltijan lupa julkaista kuva.
          </div>
          <div class="upload-actions">
            <button id="uploadBtn" class="btn btn--submit">Lataa kuva</button>
            <div id="uploadMsg" class="upload-msg"></div>
          </div>
        </div>
      </div>

      
      <!-- Hallitse galleriaa tab (admin only) -->
      <div id="tabHallitse" class="tab-content" style="display:none;">
        <div class="hallitse-section">
          <h3 class="upload-title">Hallitse galleriaa</h3>
          <div class="hallitse-top">
            <div class="hallitse-select-row">
              <select id="hallitseGallerySelect" class="inp inp--sel">
                <option value="">— valitse galleria —</option>
              </select>
              <button id="hallitseLoadBtn" class="btn" disabled>Lataa kuvat</button>
            </div>
            <div id="hallitseGalleryActions" class="hallitse-gallery-actions" style="display:none;">
              <button id="hallitseRenameGalleryBtn" class="btn btn--ghost">✏ Muuta nimeä</button>
              <button id="hallitseDeleteGalleryBtn" class="btn btn--danger">🗑 Poista galleria</button>
            </div>
          </div>
          <div id="hallitseMsg" class="upload-msg" style="margin-top:8px;"></div>
          <div id="hallitseGrid" class="hallitse-grid"></div>
        </div>
      </div>

      <!-- Modal overlay -->
      <div id="modal" class="overlay" style="display:none;">
        <div class="overlay-bg"></div>
        <div class="lightbox">
          <button class="lightbox-close" id="modalX">Sulje</button>
          <div class="lb-layout">
            <!-- Left: photo + form (scrollable if tall) -->
            <div class="lb-left">
              <div class="lb-thumb-card" id="thumbCard">
                <img id="modalImg" class="lb-thumb-img" src="" alt="" />
                <div class="lb-thumb-hint">Klikkaa suurentaaksesi</div>
              </div>
              <div class="lb-form-wrap" id="modalForm"></div>
            </div>
            <!-- Right: thread (scrollable) -->
            <div class="lb-right" id="modalThread"></div>
          </div>
        </div>
      </div>

      <!-- Fullscreen photo viewer -->
      <div id="photoViewer" class="photo-viewer" style="display:none;">
        <div class="pv-bg"></div>
        <img id="pvImg" class="pv-img" src="" alt="" />
        <button class="pv-close" id="pvClose">&#x2715;</button>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
let photos=[],adminPw=null,curFilter=null,curPhoto=null,adminLastVisit=null;
let cachedGalleries=null; // cached list from /api/mystery/galleries
const voted=JSON.parse(localStorage.getItem('pm_v')||'{}');
const grid=document.getElementById('grid');
const modal=document.getElementById('modal');
const LANG=window.location.pathname.startsWith('/en')?'en':'fi';
const T=LANG==='en'?{
  commentWithInfo:'Share what you know',oneOrAll:'One or all',
  yourName:'Your name',nameOpt:'(optional)',anonymous:'Anonymous',submit:'Submit',
  yearEst:'Year estimate',people:'People in photo',place:'Place / event',moreInfo:'Additional info',
  phYear:'E.g. 1977',phPeople:'Who do you recognise?',phPlace:'Where was it taken?',phNotes:'What else do you know?',
  joinDiscussion:'Join the discussion',noDiscussion:'Start the discussion by sharing what you know first',
  comment:'Comment',writeComment:'Write a comment...',
  all:'All',new_:'New',partial:'Partially identified',
  flYear:'Year',flPeople:'People',flPlace:'Place',flNotes:'Info'
}:{
  commentWithInfo:'Kommentoi tiedoilla',oneOrAll:'Yksi tai kaikki',
  yourName:'Nimesi',nameOpt:'(vapaaehtoinen)',anonymous:'Nimetön',submit:'Lähetä',
  yearEst:'Vuosiarvio',people:'Henkilöt kuvassa',place:'Paikka / tapahtuma',moreInfo:'Lisätietoja',
  phYear:'Esim. 1977',phPeople:'Kenet tunnistat?',phPlace:'Missä otettu?',phNotes:'Mitä muuta tiedät?',
  joinDiscussion:'Kommentoi keskustelua',noDiscussion:'Aloita keskustelu kommentoimalla tiedoillasi ensin',
  comment:'Kommentoi',writeComment:'Kirjoita kommentti...',
  all:'Kaikki',new_:'Uudet',partial:'Osittain tunnistettu',
  flYear:'Vuosiarvio',flPeople:'Henkilöt',flPlace:'Paikka',flNotes:'Lisätiedot'
};
const FIELDS=[
  {key:'year_estimate',label:T.yearEst,type:'year',ph:T.phYear},
  {key:'people',label:T.people,type:'people',ph:T.phPeople},
  {key:'location_notes',label:T.place,type:'location',ph:T.phPlace},
  {key:'notes',label:T.moreInfo,type:'notes',ph:T.phNotes},
];
const FL={year:T.flYear,people:T.flPeople,location:T.flPlace,notes:T.flNotes};

// Filter definitions — different set depending on role.
const COMMUNITY_FILTERS=[
  {key:'all',label:T.all},
  {key:'new',label:T.new_},
  {key:'partial',label:T.partial},
];
const ADMIN_FILTERS=[
  {key:'tarkistettavaa',label:'Tarkistettavaa'},
  {key:'kesken',label:'Kesken'},
  {key:'valmiit',label:'Valmiit'},
];

function renderFilters(){
  const bar=document.getElementById('filterBar');
  const set=adminPw?ADMIN_FILTERS:COMMUNITY_FILTERS;
  const defaultKey=adminPw?'tarkistettavaa':'all';
  if(!curFilter || !set.find(f=>f.key===curFilter))curFilter=defaultKey;
  // Compute badge count for Tarkistettavaa
  bar.innerHTML=set.map(f=>{
    let badge='';
    if(adminPw && f.key==='tarkistettavaa'){
      const n=photos.filter(p=>isTarkistettavaa(p)).length;
      if(n>0)badge=` <span class="pill__badge">${n}</span>`;
    }
    return `<button class="pill ${f.key===curFilter?'pill--on':''}" data-s="${f.key}">${f.label}${badge}</button>`;
  }).join('');
  bar.querySelectorAll('.pill').forEach(b=>b.addEventListener('click',()=>{
    curFilter=b.dataset.s;
    renderFilters();
    renderGrid();
  }));
}

// Count comments created after the admin's last-visit timestamp.
function getNewCount(p){
  if(!adminPw || !adminLastVisit)return 0;
  const cutoff=new Date(adminLastVisit).getTime();
  return p.comments.filter(c=>new Date(c.created_at).getTime()>cutoff).length;
}

// A photo is "tarkistettavaa" if it has new comments OR was uploaded since last admin visit.
function isTarkistettavaa(p){
  if(!adminPw || !adminLastVisit)return false;
  if(getNewCount(p)>0)return true;
  if(p.created_at){
    const cutoff=new Date(adminLastVisit).getTime();
    if(new Date(p.created_at).getTime()>cutoff)return true;
  }
  return false;
}

fetch('/api/mystery/init',{method:'POST'}).catch(()=>{});
async function verifyPw(pw){const r=await fetch('/api/mystery/verify',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({password:pw})});return(await r.json()).valid===true;}

async function load(){
  try{
    const qs=adminPw?'?include=all':'';
    const r=await fetch('/api/mystery/photos'+qs);
    photos=(await r.json()).photos||[];
    renderFilters();renderGrid();
  }
  catch(e){grid.innerHTML='<div class="grid-empty">Virhe ladattaessa.</div>';}
}

// Fetch the list of available galleries from the backend.
// Cached for the session — admin can force a reload by logging out + back in.
async function loadGalleries(){
  if(cachedGalleries) return cachedGalleries;
  try{
    const r=await fetch('/api/mystery/galleries?password='+encodeURIComponent(adminPw));
    if(!r.ok) throw new Error('HTTP '+r.status);
    const data=await r.json();
    cachedGalleries=data.galleries||[];
    return cachedGalleries;
  }catch(e){
    return [];
  }
}

function renderGrid(){
  let f;
  if(adminPw){
    const enriched=photos.map(p=>({...p, newCount: getNewCount(p)}));
    switch(curFilter){
      case 'tarkistettavaa': f=enriched.filter(p=>isTarkistettavaa(p)); break;
      case 'kesken': f=enriched.filter(p=>p.status!=='identified' && !isTarkistettavaa(p)); break;
      case 'valmiit': f=enriched.filter(p=>p.status==='identified'); break;
      default: f=enriched; break;
    }
  }else{
    // Community: hide identified photos entirely (done via photos API, but double-filter here for safety)
    const base=photos.filter(p=>p.status!=='identified');
    switch(curFilter){
      case 'new': f=base.filter(p=>p.status==='new'); break;
      case 'partial': f=base.filter(p=>p.status==='partial'); break;
      default: f=base; break;
    }
    f=f.map(p=>({...p, newCount:0}));
  }
  if(!f.length){grid.innerHTML='<div class="grid-empty">Ei kuvia tässä kategoriassa.</div>';return;}
  grid.innerHTML=f.map(p=>`
    <article class="pcard" data-id="${p.id}">
      <div class="pcard-visual">
        <img src="${p.image_url}" alt="" loading="lazy"/>
        <div class="pcard-badge pcard-badge--${p.status}">${p.status==='new'?'Uusi':p.status==='partial'?'Osittain tunnistettu':'Tunnistettu'}</div>
        ${p.newCount>0?`<div class="pcard-newbadge">${p.newCount} uutta</div>`:''}
        ${p.comments.length?`<div class="pcard-comments">💬 ${p.comments.length}</div>`:''}
      </div>
      <div class="pcard-meta">
        ${p.people?`<span class="pcard-who">${esc(p.people)}</span>`:''}
        ${p.year_estimate?`<span class="pcard-yr">${esc(p.year_estimate)}</span>`:''}
        ${!p.people&&!p.year_estimate?'<span class="pcard-unk">Tuntematon — auta tunnistamaan!</span>':''}
      </div>
    </article>`).join('');
  grid.querySelectorAll('.pcard').forEach(c=>c.addEventListener('click',()=>openModal(+c.dataset.id)));
}

function openModal(id){
  const p=photos.find(x=>x.id===id);if(!p)return;curPhoto=p;
  document.getElementById('modalImg').src=p.image_url;
  // Admin mode: single column (no thread). Community: two columns (form + thread).
  document.querySelector('.lb-layout').classList.toggle('lb-layout--admin',!!adminPw);
  document.querySelector('.lb-right').style.display=adminPw?'none':'';
  if(adminPw){renderAdminForm(p);}else{renderCommunityForm(p);renderThread(p);}
  modal.style.display='flex';document.body.style.overflow='hidden';
  // Reset scroll positions on open
  document.querySelector('.lb-left').scrollTop=0;
  const r=document.querySelector('.lb-right');if(r)r.scrollTop=0;
}

function renderCommunityForm(p){
  const el=document.getElementById('modalForm');
  const locked=FIELDS.filter(f=>p[f.key]&&p[f.key].trim());
  const open=FIELDS.filter(f=>!p[f.key]||!p[f.key].trim());
  el.innerHTML=`
    <div class="form-card">
      <div class="form-card__header form-card__toggle">
        <h3>${T.commentWithInfo}</h3>
        <span class="form-card__sub"><span class='form-hint'>Klikkaa avataksesi</span> <span class='form-toggle-arrow' id='sfArrow'>\u25B8</span></span>
      </div>
      ${locked.length?`<div class="form-locked" id="sfLocked" style="display:none;">${locked.map(f=>`<div class="form-locked__row"><span class="form-locked__label">${f.label}</span><span class="form-locked__value">${esc(p[f.key])}</span></div>`).join('')}</div>`:''}
      <div class="form-fields" id="sfFields" style="display:none;">
        <div class="ff"><label>${T.yourName} <span class="ff-opt">${T.nameOpt}</span></label><input type="text" class="inp" id="sfName" placeholder="${T.anonymous}" /></div>
        ${open.map(f=>`<div class="ff"><label>${f.label}</label><input type="text" class="inp sf-inp" data-ft="${f.type}" placeholder="${f.ph}" /></div>`).join('')}
        <button class="btn btn--wide" id="sfSubmit">${T.submit}</button>
      </div>
    </div>`;
  el.querySelector('#sfSubmit').addEventListener('click',async()=>{
    const name=(el.querySelector('#sfName').value.trim())||T.anonymous;
    const promises=[];
    el.querySelectorAll('.sf-inp').forEach(inp=>{
      const val=inp.value.trim();
      if(val.length>=2){promises.push(postComment(p.id,name,val,inp.dataset.ft));inp.value='';}
    });
    if(promises.length){window._keepThreadOpen=true;await Promise.all(promises);await load();openModal(p.id);}
  });
  // Toggle form collapse
  el.querySelector('.form-card__toggle').addEventListener('click',()=>{
    const fields=el.querySelector('#sfFields');
    const locked=el.querySelector('#sfLocked');
    const arrow=el.querySelector('#sfArrow');
    const card=el.querySelector('.form-card');
    if(fields.style.display==='none'){
      fields.style.display='';
      if(locked)locked.style.display='';
      arrow.textContent='\u25BE';
      card.classList.add('expanded');
    }else{
      fields.style.display='none';
      if(locked)locked.style.display='none';
      arrow.textContent='\u25B8';
      card.classList.remove('expanded');
    }
  });
}

function renderAdminForm(p){
  const el=document.getElementById('modalForm');

  // Per field: top-level suggestions with matching field_type + all their replies.
  // Sort: upvotes DESC, created_at DESC (newest among same vote count).
  const perField={};
  FIELDS.forEach(f=>{
    const top=p.comments.filter(c=>!c.parent_id&&c.field_type===f.type);
    const topIds=top.map(t=>t.id);
    const replies=p.comments.filter(c=>c.parent_id&&topIds.includes(c.parent_id));
    const all=[...top,...replies];
    all.sort((a,b)=>(b.upvotes||0)-(a.upvotes||0)||new Date(b.created_at)-new Date(a.created_at));
    perField[f.key]=all;
  });

  const fieldsHtml=FIELDS.map(f=>{
    const suggs=perField[f.key];
    // Lookup map for parent text when rendering reply context
    const byId=Object.fromEntries(p.comments.map(c=>[c.id,c]));
    const suggHtml=suggs.length
      ? `<div class="af-suggs">${suggs.map(s=>{
          const parent=s.parent_id?byId[s.parent_id]:null;
          const replyPrefix=parent?'<span class="af-sugg__arrow">↳</span> ':'';
          const replyCtx=parent?`<span class="af-sugg__replyctx">vastaus: "${esc(parent.content)}"</span> · `:'';
          const rowCls=parent?'af-sugg af-sugg--reply':'af-sugg';
          return `
          <div class="${rowCls}">
            <div class="af-sugg__main">
              <span class="af-sugg__text">${replyPrefix}${esc(s.content)}</span>
              <div class="af-sugg__actions">
                <button type="button" class="af-sugg__copy" data-target="ab_${f.key}" data-text="${escAttr(s.content)}">↪ kopioi</button>
                <button type="button" class="af-sugg__del" data-cid="${s.id}" title="Poista kokonaan">🗑</button>
              </div>
            </div>
            <div class="af-sugg__meta">${replyCtx}${esc(s.author_name)} · 👍 ${s.upvotes||0} · 👎 ${s.downvotes||0} · ${fmtDate(s.created_at)}</div>
          </div>`;
        }).join('')}</div>`
      : `<p class="af-empty">Ei ehdotuksia vielä</p>`;
    return `
      <div class="af-field">
        <div class="af-field__head">
          <label>${f.label}</label>
          ${suggs.length?`<span class="af-field__count">${suggs.length} ${suggs.length===1?'ehdotus':'ehdotusta'}</span>`:''}
        </div>
        ${suggHtml}
        <input type="text" class="inp af-input" id="ab_${f.key}" value="${escAttr(p[f.key]||'')}" placeholder="Kirjoita virallinen tieto" />
      </div>`;
  }).join('');

  el.innerHTML=`
    <div class="form-card form-card--admin">
      <div class="form-card__header form-card__header--admin">
        <h3>Ylläpito</h3>
        <span class="form-card__sub">Tarkista ehdotukset ja kirjoita viralliset tiedot</span>
      </div>
      <div id="afStatus" class="af-status"></div>
      ${fieldsHtml}
      <button class="btn btn--wide" id="abSave">Tallenna</button>
      <div id="abSaveMsg" class="ab-save-msg" aria-live="polite"></div>
      <div class="af-footer">
        <button type="button" class="btn btn--secondary" id="afPublish" disabled>Julkaise Galleriaan</button>
        <button type="button" class="af-footer__del" id="abDel">Poista kuva</button>
      </div>
      <div id="pubPanel" class="pub-panel" style="display:none;"></div>
    </div>`;

  el.querySelectorAll('.af-sugg__copy').forEach(btn=>btn.addEventListener('click',()=>{
    const t=document.getElementById(btn.dataset.target);
    if(t){t.value=btn.dataset.text;t.focus();updateStatusDisplay(el);}
  }));
  el.querySelectorAll('.af-sugg__del').forEach(btn=>btn.addEventListener('click',async()=>{
    if(!confirm('Poistetaanko ehdotus kokonaan?'))return;
    const ok=await adminAction('delete_comment',{comment_id:+btn.dataset.cid});
    if(ok){await load();openModal(p.id);}
  }));
  ['year_estimate','people','location_notes','notes'].forEach(k=>{
    const inp=el.querySelector('#ab_'+k);
    if(inp)inp.addEventListener('input',()=>updateStatusDisplay(el));
  });
  el.querySelector('#abSave').addEventListener('click',async()=>{
    const btn=el.querySelector('#abSave');const msg=el.querySelector('#abSaveMsg');
    btn.disabled=true;btn.textContent='Tallennetaan…';if(msg){msg.textContent='';msg.className='ab-save-msg';}
    const ok=await adminAction('update_meta',{photo_id:p.id,year_estimate:el.querySelector('#ab_year_estimate').value,people:el.querySelector('#ab_people').value,location_notes:el.querySelector('#ab_location_notes').value,notes:el.querySelector('#ab_notes').value});
    if(ok){
      if(msg){msg.textContent='✓ Tallennettu';msg.className='ab-save-msg ab-save-msg--ok';}
      setTimeout(async()=>{await load();openModal(p.id);},900);
    } else {
      btn.disabled=false;btn.textContent='Tallenna';
      if(msg){msg.textContent='✗ Virhe — yritä uudelleen';msg.className='ab-save-msg ab-save-msg--err';}
    }
  });
  el.querySelector('#afPublish').addEventListener('click',()=>openPublishPanel(p));
  el.querySelector('#abDel').addEventListener('click',async()=>{
    if(!confirm('Poistetaanko kuva pysyvästi?'))return;
    const ok=await adminAction('delete_photo',{photo_id:p.id});
    if(ok){closeModal();await load();}
  });

  updateStatusDisplay(el);
}

// =====================================================================
// PUBLISH PANEL — inline confirmation UI for "Julkaise Galleriaan"
// =====================================================================
//
// Expands below the Julkaise button. Lets admin:
//   - Pick a target gallery from a dropdown (or "+ Luo uusi")
//   - Preview the auto-composed caption (people + location + year)
//   - Edit the caption / filename if desired
//   - Confirm or cancel
//
// On confirm: calls POST /api/mystery/publish, shows progress, then on success
// closes the modal, clears the gallery cache (in case a new one was created),
// and reloads the grid.

async function openPublishPanel(p){
  const panel=document.getElementById('pubPanel');
  if(!panel) return;

  // Toggle: clicking Julkaise twice closes the panel
  if(panel.style.display!=='none' && panel.dataset.photoId===String(p.id)){
    closePublishPanel();
    return;
  }
  panel.dataset.photoId=String(p.id);

  panel.style.display='block';
  panel.innerHTML=`<div class="pub-loading">Ladataan gallerioita...</div>`;

  const galleries=await loadGalleries();
  const captionDefault=composeCaption(p);

  const optionsHtml=galleries.map(g=>`<option value="${escAttr(g.slug)}">${esc(g.title)}</option>`).join('');

  panel.innerHTML=`
    <div class="pub-panel__header">
      <h4>Julkaise galleriaan</h4>
      <button type="button" class="pub-panel__close" id="pubClose">&#x2715;</button>
    </div>
    <div class="pub-panel__body">
      <div class="pub-row">
        <label>Galleria</label>
        <div class="pub-select-row">
          <select id="pubGallerySelect" class="inp inp--sel">
            <option value="">— valitse —</option>
            ${optionsHtml}
            <option value="__new__">➕ Luo uusi galleria…</option>
          </select>
        </div>
      </div>
      <div id="pubNewBox" class="pub-row pub-newbox" style="display:none;">
        <label>Uuden gallerian nimi</label>
        <input type="text" id="pubNewTitle" class="inp" placeholder="Esim. Hyvinkää 1980s" />
        <div class="pub-hint" id="pubSlugPreview"></div>
      </div>
      <div class="pub-row">
        <label>Kuvateksti (näkyy galleriassa)</label>
        <input type="text" id="pubCaption" class="inp" value="${escAttr(captionDefault)}" />
        <div class="pub-hint">Nimi pohjautuu kuvatekstiin: <span id="pubFilenamePreview"></span></div>
      </div>
      <div class="pub-actions">
        <button type="button" class="btn btn--ghost" id="pubCancel">Peruuta</button>
        <button type="button" class="btn" id="pubGo" disabled>Julkaise</button>
      </div>
      <div id="pubMsg" class="pub-msg"></div>
    </div>
  `;

  const sel=panel.querySelector('#pubGallerySelect');
  const newBox=panel.querySelector('#pubNewBox');
  const newTitleInp=panel.querySelector('#pubNewTitle');
  const slugPrev=panel.querySelector('#pubSlugPreview');
  const captionInp=panel.querySelector('#pubCaption');
  const filenamePrev=panel.querySelector('#pubFilenamePreview');
  const goBtn=panel.querySelector('#pubGo');

  function refreshFilenamePreview(){
    const cap=captionInp.value.trim();
    filenamePrev.textContent=cap?cap.replace(/[\\/:*?"<>|]/g,'').replace(/\s+/g,' ')+'.jpg':'(tyhjä)';
  }
  function refreshSlugPreview(){
    const t=newTitleInp.value.trim();
    slugPrev.textContent=t?'Slug: '+slugify(t):'';
  }
  function refreshGoEnabled(){
    const slugPicked=sel.value && sel.value!=='';
    const newReady=sel.value==='__new__' && newTitleInp.value.trim().length>=2;
    const captionOk=captionInp.value.trim().length>=2;
    goBtn.disabled=!((slugPicked && sel.value!=='__new__' && captionOk) || (newReady && captionOk));
  }

  sel.addEventListener('change',()=>{
    newBox.style.display=sel.value==='__new__'?'block':'none';
    if(sel.value==='__new__')newTitleInp.focus();
    refreshGoEnabled();
  });
  newTitleInp.addEventListener('input',()=>{refreshSlugPreview();refreshGoEnabled();});
  captionInp.addEventListener('input',()=>{refreshFilenamePreview();refreshGoEnabled();});

  panel.querySelector('#pubCancel').addEventListener('click',closePublishPanel);
  panel.querySelector('#pubClose').addEventListener('click',closePublishPanel);
  goBtn.addEventListener('click',()=>doPublish(p,sel,newTitleInp,captionInp,goBtn));

  refreshFilenamePreview();
  refreshGoEnabled();
}

function closePublishPanel(){
  const panel=document.getElementById('pubPanel');
  if(!panel) return;
  panel.style.display='none';
  panel.innerHTML='';
  delete panel.dataset.photoId;
}

function composeCaption(p){
  return [p.people, p.location_notes, p.year_estimate]
    .map(s=>(s||'').trim())
    .filter(Boolean)
    .join(' ');
}

function slugify(s){
  return String(s||'')
    .toLowerCase()
    // normalise common Nordic chars for slug use
    .replace(/[äà]/g,'a').replace(/[öø]/g,'o').replace(/[å]/g,'a').replace(/[éè]/g,'e').replace(/[ü]/g,'u')
    .replace(/[^a-z0-9-]+/g,'-')
    .replace(/-+/g,'-')
    .replace(/^-|-$/g,'');
}

async function doPublish(p,sel,newTitleInp,captionInp,goBtn){
  const msg=document.getElementById('pubMsg');
  goBtn.disabled=true;
  msg.innerHTML='<span class="u-load">Julkaistaan…</span>';

  const createNew=sel.value==='__new__';
  const slug=createNew?slugify(newTitleInp.value):sel.value;
  const title=createNew?newTitleInp.value.trim():'';
  const filename=captionInp.value.trim();

  try{
    const r=await fetch('/api/mystery/publish',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({
        password:adminPw,
        photo_id:p.id,
        gallery_slug:slug,
        gallery_title:title,
        create_new:createNew,
        filename_override:filename,
      }),
    });
    const data=await r.json().catch(()=>({}));
    if(!r.ok || data.success!==true){
      msg.innerHTML=`<span class="u-err">Virhe: ${esc(data.error||('HTTP '+r.status))}</span>`;
      goBtn.disabled=false;
      return;
    }
    if(data.cleanup_warning){
      msg.innerHTML=`<span class="u-ok">✓ Julkaistu. Huom: ${esc(data.cleanup_warning)}</span>`;
    }else{
      msg.innerHTML=`<span class="u-ok">✓ Julkaistu galleriaan ${esc(data.gallery_slug)}.</span>`;
    }
    // If admin created a new gallery, drop the cache so next time it's re-fetched
    if(createNew) cachedGalleries=null;
    // Brief pause so admin sees the success message, then close + reload
    setTimeout(()=>{
      closePublishPanel();
      closeModal();
      load();
    },900);
  }catch(e){
    msg.innerHTML=`<span class="u-err">Virhe: ${esc(e.message||'yhteysvirhe')}</span>`;
    goBtn.disabled=false;
  }
}

// Derive status live from the 3 core field inputs (notes is optional).
// Updates the status readout, enables/disables the Julkaise button,
// and marks filled inputs with a "done" visual.
function updateStatusDisplay(el){
  const core=['year_estimate','people','location_notes'];
  const all=['year_estimate','people','location_notes','notes'];
  // Visual done-state on every input (including notes)
  all.forEach(k=>{
    const inp=el.querySelector('#ab_'+k);
    if(!inp)return;
    const field=inp.closest('.af-field');
    if(inp.value.trim()){
      inp.classList.add('af-input--done');
      if(field)field.classList.add('af-field--done');
    }else{
      inp.classList.remove('af-input--done');
      if(field)field.classList.remove('af-field--done');
    }
  });
  const filled=core.map(k=>{
    const inp=el.querySelector('#ab_'+k);
    return inp && inp.value.trim();
  }).filter(Boolean).length;
  let key,label,detail,ready;
  if(filled===0){key='new';label='Uusi';detail=`${filled}/3 tarvittavista`;ready=false;}
  else if(filled<3){key='partial';label='Osittain tunnistettu';detail=`${filled}/3 tarvittavista`;ready=false;}
  else{key='identified';label='Tunnistettu';detail='Kaikki tiedot täytetty';ready=true;}
  const statusEl=el.querySelector('#afStatus');
  if(statusEl){
    statusEl.className='af-status af-status--'+key;
    statusEl.innerHTML=`<span class="af-status__dot"></span><strong>${label}</strong><span class="af-status__detail">· ${detail}</span>`;
  }
  const pubBtn=el.querySelector('#afPublish');
  if(pubBtn){
    pubBtn.disabled=!ready;
    pubBtn.title=ready?'Julkaise kuva Galleriaan':'Tiedot puuttuvat — ei voi julkaista';
  }
}

function renderThread(p){
  const el=document.getElementById('modalThread');
  // Determine which fields have been officially confirmed — their whole
  // discussion is removed from the community thread to reduce clutter.
  // Admin mode: field-typed comments + their replies are shown in the admin form instead.
  let comments=p.comments;
  const hide=new Set();
  if(adminPw){
    // Old admin rule: hide all field-type top-levels and their replies (moved to admin form)
    p.comments.forEach(c=>{
      if(!c.parent_id&&c.field_type&&c.field_type!=='general'){
        hide.add(c.id);
        p.comments.forEach(r=>{if(r.parent_id===c.id)hide.add(r.id);});
      }
    });
  }else{
    // Community rule: hide a field's top-levels (and their replies) once the field is confirmed.
    const confirmedTypes=new Set();
    FIELDS.forEach(f=>{if(p[f.key]&&String(p[f.key]).trim())confirmedTypes.add(f.type);});
    p.comments.forEach(c=>{
      if(!c.parent_id&&c.field_type&&confirmedTypes.has(c.field_type)){
        hide.add(c.id);
        p.comments.forEach(r=>{if(r.parent_id===c.id)hide.add(r.id);});
      }
    });
  }
  if(hide.size)comments=p.comments.filter(c=>!hide.has(c.id));
  const top=comments.filter(c=>!c.parent_id).reverse();
  let h=`<div class="thread-card"><div class="thread-card__header"><h3 onclick="var p=this.closest('.thread-card');var t=p.querySelector('.thread-list')||p.querySelector('.thread-empty');if(t){t.style.display=t.style.display==='none'?'':'none';}p.classList.toggle('expanded');var a=this.querySelector('.thread-arrow');if(a)a.textContent=a.textContent==='\u25B8'?'\u25BE':'\u25B8';">${T.joinDiscussion}</h3><div class='thread-sub' style='font-size:0.85rem;font-weight:400;font-style:italic;color:#000;opacity:0.75;display:flex;justify-content:space-between;align-items:center;margin-top:4px;'><span>Klikkaa avataksesi</span><span class='thread-arrow' style='font-style:normal;font-size:1.2em;opacity:1;'>\u25B8</span></div></div>`;
  if(!top.length){h+=`<p class="thread-empty"><span class="thread-empty__arrow" aria-hidden="true">←</span><span class="thread-empty__text">${T.noDiscussion}</span></p>`;}
  else{
    h+=`<div class="thread-list" style="display:none;">`;
    let idx=0;
    top.forEach(c=>{
      const replies=comments.filter(r=>r.parent_id===c.id);
      const tag=c.field_type&&c.field_type!=='general'?`<span class="post-tag">${FL[c.field_type]||''}</span>`:'';
      const alt=idx%2===1?'post--alt':'';
      h+=`<div class="post ${alt}">
        <div class="post-header">${tag}<span class="post-author">${esc(c.author_name)}</span><time class="post-date">${fmtDate(c.created_at)}</time>${adminPw?`<button class="post-del" data-cid="${c.id}">🗑</button>`:''}</div>
        <p class="post-body">${esc(c.content)}</p>
        <div class="post-actions">${voteBtns(c)}<button class="post-reply-btn" data-cid="${c.id}">${T.comment}</button></div>
        <div class="post-reply-box" id="rb-${c.id}" style="display:none;"><input type="text" class="inp post-reply-inp" placeholder="${T.writeComment}" /><button class="btn btn--sm post-reply-send" data-cid="${c.id}" data-pid="${p.id}">${T.submit}</button><button class="btn btn--sm post-reply-cancel" data-cid="${c.id}" style="background:#ccc;color:#000;margin-left:6px;">✕</button></div>
      </div>`;
      if(replies.length){
        replies.forEach(r=>{
          h+=`<div class="post post--child ${alt}">
            <div class="post-header"><span class="post-author">${esc(r.author_name)}</span><time class="post-date">${fmtDate(r.created_at)}</time>${adminPw?`<button class="post-del" data-cid="${r.id}">🗑</button>`:''}</div>
            <p class="post-body">${esc(r.content)}</p>
            <div class="post-actions">${voteBtns(r)}</div>
          </div>`;
        });
      }
      idx++;
    });
    h+=`</div>`;
  }
  h+=`</div>`;
  el.innerHTML=h;
  if(window._keepThreadOpen){
    const tc=el.querySelector('.thread-card');
    if(tc){
      tc.classList.add('expanded');
      const tl=tc.querySelector('.thread-list, .thread-empty');
      if(tl)tl.style.display='';
      const ta=tc.querySelector('.thread-arrow');
      if(ta)ta.textContent='\u25BE';
    }
    window._keepThreadOpen=false;
  }

  el.querySelectorAll('.th-vote').forEach(btn=>btn.addEventListener('click',async e=>{
    e.stopPropagation();const cid=+btn.dataset.cid,v=+btn.dataset.v;if(voted[cid])return;
    const r=await fetch('/api/mystery/vote',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({comment_id:cid,vote:v})});
    if((await r.json()).success){voted[cid]=v;localStorage.setItem('pm_v',JSON.stringify(voted));window._keepThreadOpen=true;await load();openModal(curPhoto.id);}
  }));
  el.querySelectorAll('.post-reply-btn').forEach(btn=>btn.addEventListener('click',()=>{
    const rb=document.getElementById('rb-'+btn.dataset.cid);rb.style.display=rb.style.display==='none'?'flex':'none';
  }));
  el.querySelectorAll('.post-reply-send').forEach(btn=>btn.addEventListener('click',async()=>{
    const inp=btn.parentElement.querySelector('.post-reply-inp');const txt=inp.value.trim();if(txt.length<2)return;
    const nameEl=document.getElementById('sfName');const name=nameEl?nameEl.value.trim()||'Nimetön':'Nimetön';
    const parentCid=+btn.dataset.cid;
    // Inherit field_type from the root of the thread — replies stay bound to their parent field.
    const ft=getRootFieldType(curPhoto.comments, parentCid);
    await postComment(+btn.dataset.pid,name,txt,ft,parentCid);
    window._keepThreadOpen=true;await load();openModal(curPhoto.id);
  }));
  if(adminPw){el.querySelectorAll('.post-del').forEach(btn=>btn.addEventListener('click',async e=>{
    e.stopPropagation();if(!confirm('Poistetaanko?'))return;
    await adminAction('delete_comment',{comment_id:+btn.dataset.cid});window._keepThreadOpen=true;await load();openModal(curPhoto.id);
  }));}
}

function voteBtns(c){

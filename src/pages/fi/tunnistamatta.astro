// =====================================================================
// THUMBNAIL GENERATION (browser-side, before upload)
// =====================================================================
//
// Generates a small thumbnail of the uploaded image using Canvas API.
// The thumb is sent alongside the original and stored in D1 (thumb_data column).
// This thumb is later used by the landing page "Help needed" block.
//
// Target: 300px max edge, JPEG quality 0.7, transparent fail (returns null on error).
// Result is a base64 data URL string, typically 10-25 KB.

async function generateThumbDataUrl(file){
  return new Promise((resolve)=>{
    try{
      const reader=new FileReader();
      reader.onload=(e)=>{
        const img=new Image();
        img.onload=()=>{
          try{
            const MAX=300;
            let w=img.width, h=img.height;
            if(w>h){
              if(w>MAX){h=Math.round(h*(MAX/w));w=MAX;}
            }else{
              if(h>MAX){w=Math.round(w*(MAX/h));h=MAX;}
            }
            const canvas=document.createElement('canvas');
            canvas.width=w; canvas.height=h;
            const ctx=canvas.getContext('2d');
            ctx.drawImage(img,0,0,w,h);
            const dataUrl=canvas.toDataURL('image/jpeg',0.7);
            resolve(dataUrl);
          }catch(err){
            console.warn('Thumb canvas error:',err);
            resolve(null);
          }
        };
        img.onerror=()=>{console.warn('Thumb img load error');resolve(null);};
        img.src=e.target.result;
      };
      reader.onerror=()=>{console.warn('Thumb FileReader error');resolve(null);};
      reader.readAsDataURL(file);
    }catch(err){
      console.warn('Thumb generation error:',err);
      resolve(null);
    }
  });
}


---
import BaseLayout from '../../layouts/BaseLayout.astro';
const lang = 'fi';
---
<BaseLayout title="Tunnista kuva" lang={lang} description="Auta tunnistamaan vanhoja moottoriurheilukuvia. Kuka kuvassa on, mistä vuodelta ja missä kuva on otettu?">
  <section class="mp">
    <div class="container">
      <div class="mp-header">
        <h1 class="mp-title">Tunnista kuva</h1>
        <p class="mp-sub">Auta meitä tunnistamaan vanhoja moottoriurheilukuvia. Kuka on kuvassa? Mistä vuodelta? Missä otettu?</p>
        <button id="adminToggle" class="mp-btn mp-btn--sec">Ylläpito</button>
      </div>

      <!-- Admin panel (upload + tools) -->
      <div id="adminPanel" class="mp-panel" style="display:none;">
        <div id="adminAuth" class="auth-box">
          <input type="password" id="adminPw" class="mp-inp" placeholder="Salasana" />
          <button id="adminPwBtn" class="mp-btn">Kirjaudu</button>
          <span id="adminPwErr" class="auth-err" style="display:none;">Väärä salasana</span>
        </div>
        <div id="adminArea" style="display:none;">
          <h3 class="panel-title">Lähetä kuva tunnistettavaksi</h3>
          <p class="form-hint">Täytä kentät joita tiedät. Tyhjät kentät avautuvat yhteisölle.</p>
          <div class="form-grid">
            <div class="fg fg--full"><label>Kuva *</label><input type="file" id="photoFile" accept="image/jpeg,image/png,image/webp" class="mp-inp" /></div>
            <div class="fg"><label>Vuosiarvio</label><input type="text" id="fYear" class="mp-inp" placeholder="Esim. 1977, 1970-luku" /></div>
            <div class="fg"><label>Henkilöt kuvassa</label><input type="text" id="fPeople" class="mp-inp" placeholder="Keitä tunnistat?" /></div>
            <div class="fg"><label>Paikka / tapahtuma</label><input type="text" id="fLocation" class="mp-inp" placeholder="Missä otettu?" /></div>
            <div class="fg"><label>Lisätietoja</label><input type="text" id="fNotes" class="mp-inp" placeholder="Muuta tietoa?" /></div>
          </div>
          <button id="uploadBtn" class="mp-btn">Lataa kuva</button>
          <div id="uploadMsg"></div>
        </div>
      </div>

      <!-- Filters -->
      <div class="filters">
        <button class="filt is-on" data-s="all">Kaikki</button>
        <button class="filt" data-s="new">Uudet</button>
        <button class="filt" data-s="partial">Osittain tunnistettu</button>
      </div>

      <!-- Grid -->
      <div id="grid" class="grid">
        <div class="empty">Ladataan kuvia...</div>
      </div>

      <!-- Modal -->
      <div id="modal" class="modal" style="display:none;">
        <div class="modal-bg"></div>
        <div class="modal-box">
          <button class="modal-x" id="modalX">&#x2715;</button>
          <div class="modal-inner">
            <div class="modal-img-wrap"><img id="modalImg" class="modal-img" src="" alt="" /></div>
            <div class="modal-side">

              <!-- Admin bar -->
              <div id="adminBar" class="admin-bar" style="display:none;"></div>

              <!-- Section A: Ehdota tietoja -->
              <div id="secA" class="sec-a">
                <h3 class="sec-title">Ehdota tietoja</h3>
                <div class="name-row">
                  <input type="text" id="myName" class="mp-inp" placeholder="Nimesi (vapaaehtoinen)" />
                </div>
                <div id="fieldInputs"></div>
              </div>

              <!-- Section B: Keskustelu -->
              <div id="secB" class="sec-b">
                <h3 class="sec-title">Keskustelu</h3>
                <div id="thread"></div>
                <div class="free-comment">
                  <textarea id="freeText" class="mp-inp mp-ta" placeholder="Vapaa kommentti..."></textarea>
                  <button id="freeBtn" class="mp-btn mp-btn--sm">Lähetä kommentti</button>
                </div>
              </div>

            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
let photos=[], adminPw=null, curFilter='all', curPhoto=null;
const voted = JSON.parse(localStorage.getItem('pm_v')||'{}');
const grid=document.getElementById('grid');
const modal=document.getElementById('modal');

const FIELDS = [
  {key:'year_estimate', label:'Vuosiarvio', type:'year', ph:'Esim. 1977'},
  {key:'people', label:'Henkilöt kuvassa', type:'people', ph:'Kenet tunnistat?'},
  {key:'location_notes', label:'Paikka / tapahtuma', type:'location', ph:'Missä otettu?'},
  {key:'notes', label:'Lisätietoja', type:'notes', ph:'Mitä muuta tiedät?'},
];

fetch('/api/mystery/init',{method:'POST'}).catch(()=>{});

async function verifyPw(pw){
  const r=await fetch('/api/mystery/verify',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({password:pw})});
  return (await r.json()).valid===true;
}

async function load(){
  try{const r=await fetch('/api/mystery/photos');const d=await r.json();photos=d.photos||[];renderGrid();}
  catch(e){grid.innerHTML='<div class="empty">Virhe ladattaessa.</div>';}
}

function renderGrid(){
  const f=curFilter==='all'?photos:photos.filter(p=>p.status===curFilter);
  if(!f.length){grid.innerHTML='<div class="empty">Ei kuvia tässä kategoriassa.</div>';return;}
  grid.innerHTML=f.map(p=>{
    const n=p.comments.length;
    return `<div class="card" data-id="${p.id}">
      <div class="card-img"><img src="${p.image_url}" alt="" loading="lazy"/>
        <span class="card-badge card-badge--${p.status}">${p.status==='new'?'Uusi':'Osittain'}</span>
        ${n?`<span class="card-count">${n} 💬</span>`:''}
      </div>
      <div class="card-info">
        ${p.people?`<span class="card-who">${esc(p.people)}</span>`:''}
        ${p.year_estimate?`<span class="card-yr">${esc(p.year_estimate)}</span>`:''}
        ${!p.people&&!p.year_estimate?'<span class="card-unk">Tuntematon — auta tunnistamaan!</span>':''}
      </div>
    </div>`;
  }).join('');
  grid.querySelectorAll('.card').forEach(c=>c.addEventListener('click',()=>openModal(+c.dataset.id)));
}

function openModal(id){
  const p=photos.find(x=>x.id===id);if(!p)return;
  curPhoto=p;
  document.getElementById('modalImg').src=p.image_url;

  // Section A — field inputs (only unlocked fields)
  const fi=document.getElementById('fieldInputs');
  const openFields=FIELDS.filter(f=>!p[f.key]||!p[f.key].trim());
  if(openFields.length){
    fi.innerHTML=openFields.map(f=>`
      <div class="fi-row">
        <label class="fi-label">${f.label}</label>
        <div class="fi-input-row">
          <input type="text" class="mp-inp fi-inp" placeholder="${f.ph}" data-ft="${f.type}" />
          <button class="mp-btn mp-btn--sm fi-btn" data-ft="${f.type}">Ehdota</button>
        </div>
      </div>`).join('');
    fi.querySelectorAll('.fi-btn').forEach(btn=>{
      btn.addEventListener('click',async()=>{
        const inp=btn.parentElement.querySelector('.fi-inp');
        const txt=inp.value.trim();if(txt.length<2)return;
        const name=document.getElementById('myName').value.trim()||'Nimetön';
        await fetch('/api/mystery/comment',{method:'POST',headers:{'Content-Type':'application/json'},
          body:JSON.stringify({photo_id:id,author_name:name,content:txt,field_type:btn.dataset.ft})});
        inp.value='';
        await load();openModal(id);
      });
    });
    document.getElementById('secA').style.display='block';
  } else {
    fi.innerHTML='<p class="all-done">Kaikki tiedot täytetty!</p>';
    document.getElementById('secA').style.display='block';
  }

  // Show locked fields as info
  const locked=FIELDS.filter(f=>p[f.key]&&p[f.key].trim());
  if(locked.length){
    const lockedHtml=locked.map(f=>`<div class="locked-field"><span class="lf-label">${f.label}:</span> <strong>${esc(p[f.key])}</strong></div>`).join('');
    fi.innerHTML=`<div class="locked-fields">${lockedHtml}</div>`+fi.innerHTML;
  }

  // Section B — thread
  renderThread(p);

  // Admin bar
  const ab=document.getElementById('adminBar');
  if(adminPw){
    ab.style.display='block';
    ab.innerHTML=`<div class="ab-inner">
      <h4 class="ab-title">Ylläpito</h4>
      <div class="ab-fields">
        ${FIELDS.map(f=>`<div class="ab-f"><label>${f.label}</label><input type="text" class="mp-inp" id="ab_${f.key}" value="${esc(p[f.key]||'')}" /></div>`).join('')}
      </div>
      <div class="ab-actions">
        <button class="mp-btn mp-btn--sm" id="abSave">Tallenna</button>
        <select class="mp-inp ab-sel" id="abStatus">
          <option value="new" ${p.status==='new'?'selected':''}>Uusi</option>
          <option value="partial" ${p.status==='partial'?'selected':''}>Osittain</option>
          <option value="identified" ${p.status==='identified'?'selected':''}>Tunnistettu</option>
        </select>
        <button class="mp-btn mp-btn--sm" id="abSetStatus">Päivitä tila</button>
        <button class="mp-btn mp-btn--sm mp-btn--danger" id="abDel">Poista kuva</button>
      </div>
    </div>`;
    document.getElementById('abSave').addEventListener('click',async()=>{
      await fetch('/api/mystery/admin',{method:'POST',headers:{'Content-Type':'application/json'},
        body:JSON.stringify({password:adminPw,action:'update_meta',photo_id:id,
          year_estimate:document.getElementById('ab_year_estimate').value,
          people:document.getElementById('ab_people').value,
          location_notes:document.getElementById('ab_location_notes').value,
          notes:document.getElementById('ab_notes').value})});
      await load();openModal(id);
    });
    document.getElementById('abSetStatus').addEventListener('click',async()=>{
      await fetch('/api/mystery/admin',{method:'POST',headers:{'Content-Type':'application/json'},
        body:JSON.stringify({password:adminPw,action:'set_status',photo_id:id,status:document.getElementById('abStatus').value})});
      await load();openModal(id);
    });
    document.getElementById('abDel').addEventListener('click',async()=>{
      if(!confirm('Poistetaanko kuva pysyvästi?'))return;
      await fetch('/api/mystery/admin',{method:'POST',headers:{'Content-Type':'application/json'},
        body:JSON.stringify({password:adminPw,action:'delete_photo',photo_id:id})});
      closeModal();await load();
    });
  } else { ab.style.display='none'; }

  modal.style.display='flex';
  document.body.style.overflow='hidden';
}

function renderThread(p){
  const thread=document.getElementById('thread');
  const topLevel=p.comments.filter(c=>!c.parent_id);
  if(!topLevel.length){thread.innerHTML='<p class="no-msg">Ei vielä keskustelua.</p>';return;}

  thread.innerHTML=topLevel.map(c=>{
    const replies=p.comments.filter(r=>r.parent_id===c.id);
    const fieldLabel=c.field_type&&c.field_type!=='general'
      ? `<span class="msg-field">${{year:'Vuosiarvio',people:'Henkilöt',location:'Paikka',notes:'Lisätiedot'}[c.field_type]||''}</span>`:'';
    return `<div class="msg">
      <div class="msg-head">
        ${fieldLabel}
        <span class="msg-author">${esc(c.author_name)}</span>
        <span class="msg-date">${new Date(c.created_at).toLocaleDateString('fi-FI')}</span>
        ${adminPw?`<button class="msg-del" data-cid="${c.id}">🗑</button>`:''}
      </div>
      <p class="msg-text">${esc(c.content)}</p>
      <div class="msg-actions">
        ${voteButtons(c)}
        <button class="reply-toggle" data-cid="${c.id}">Vastaa</button>
      </div>
      <div class="reply-form" id="rf-${c.id}" style="display:none;">
        <input type="text" class="mp-inp reply-inp" placeholder="Vastaa..." />
        <button class="mp-btn mp-btn--sm reply-btn" data-cid="${c.id}" data-pid="${p.id}">Lähetä</button>
      </div>
      ${replies.length?`<div class="replies">${replies.map(r=>`
        <div class="msg msg--reply">
          <div class="msg-head">
            <span class="msg-author">${esc(r.author_name)}</span>
            <span class="msg-date">${new Date(r.created_at).toLocaleDateString('fi-FI')}</span>
            ${adminPw?`<button class="msg-del" data-cid="${r.id}">🗑</button>`:''}
          </div>
          <p class="msg-text">${esc(r.content)}</p>
          <div class="msg-actions">${voteButtons(r)}</div>
        </div>`).join('')}</div>`:''}
    </div>`;
  }).join('');

  // Bind vote buttons
  thread.querySelectorAll('.vote-btn').forEach(btn=>{
    btn.addEventListener('click',async(e)=>{
      e.stopPropagation();
      const cid=+btn.dataset.cid, v=+btn.dataset.v;
      if(voted[cid])return;
      const r=await fetch('/api/mystery/vote',{method:'POST',headers:{'Content-Type':'application/json'},
        body:JSON.stringify({comment_id:cid,vote:v})});
      if((await r.json()).success){voted[cid]=v;localStorage.setItem('pm_v',JSON.stringify(voted));await load();openModal(curPhoto.id);}
    });
  });

  // Bind reply toggles
  thread.querySelectorAll('.reply-toggle').forEach(btn=>{
    btn.addEventListener('click',()=>{
      const rf=document.getElementById('rf-'+btn.dataset.cid);
      rf.style.display=rf.style.display==='none'?'flex':'none';
    });
  });

  // Bind reply submit
  thread.querySelectorAll('.reply-btn').forEach(btn=>{
    btn.addEventListener('click',async()=>{
      const inp=btn.parentElement.querySelector('.reply-inp');
      const txt=inp.value.trim();if(txt.length<2)return;
      const name=document.getElementById('myName').value.trim()||'Nimetön';
      await fetch('/api/mystery/comment',{method:'POST',headers:{'Content-Type':'application/json'},
        body:JSON.stringify({photo_id:+btn.dataset.pid,author_name:name,content:txt,field_type:'general',parent_id:+btn.dataset.cid})});
      await load();openModal(curPhoto.id);
    });
  });

  // Bind admin delete
  if(adminPw){
    thread.querySelectorAll('.msg-del').forEach(btn=>{
      btn.addEventListener('click',async(e)=>{
        e.stopPropagation();
        if(!confirm('Poistetaanko?'))return;
        await fetch('/api/mystery/admin',{method:'POST',headers:{'Content-Type':'application/json'},
          body:JSON.stringify({password:adminPw,action:'delete_comment',comment_id:+btn.dataset.cid})});
        await load();openModal(curPhoto.id);
      });
    });
  }
}

function voteButtons(c){
  const v=voted[c.id];
  return `<button class="vote-btn ${v===1?'vote-on':''}" data-cid="${c.id}" data-v="1">👍 ${c.upvotes||0}</button>
          <button class="vote-btn ${v===-1?'vote-on':''}" data-cid="${c.id}" data-v="-1">👎 ${c.downvotes||0}</button>`;
}

function closeModal(){modal.style.display='none';document.body.style.overflow='';curPhoto=null;}
document.getElementById('modalX').addEventListener('click',closeModal);
document.querySelector('.modal-bg').addEventListener('click',closeModal);
document.addEventListener('keydown',e=>{if(e.key==='Escape')closeModal();});

// Free comment
document.getElementById('freeBtn').addEventListener('click',async()=>{
  const txt=document.getElementById('freeText').value.trim();if(txt.length<2)return;
  const name=document.getElementById('myName').value.trim()||'Nimetön';
  await fetch('/api/mystery/comment',{method:'POST',headers:{'Content-Type':'application/json'},
    body:JSON.stringify({photo_id:curPhoto.id,author_name:name,content:txt,field_type:'general'})});
  document.getElementById('freeText').value='';
  await load();openModal(curPhoto.id);
});

// Admin toggle + auth
document.getElementById('adminToggle').addEventListener('click',()=>{
  const p=document.getElementById('adminPanel');
  p.style.display=p.style.display==='none'?'block':'none';
});
document.getElementById('adminPwBtn').addEventListener('click',async()=>{
  const pw=document.getElementById('adminPw').value;
  if(await verifyPw(pw)){
    adminPw=pw;
    document.getElementById('adminAuth').style.display='none';
    document.getElementById('adminArea').style.display='block';
  } else { document.getElementById('adminPwErr').style.display='inline'; }
});

// Upload
document.getElementById('uploadBtn').addEventListener('click',async()=>{
  const file=document.getElementById('photoFile').files[0];if(!file)return;
  const fd=new FormData();
  fd.append('photo',file);fd.append('password',adminPw);
  fd.append('year_estimate',document.getElementById('fYear').value);
  fd.append('people',document.getElementById('fPeople').value);
  fd.append('location_notes',document.getElementById('fLocation').value);
  fd.append('notes',document.getElementById('fNotes').value);
  const msg=document.getElementById('uploadMsg');
  msg.innerHTML='<span class="msg-load">Ladataan...</span>';
  document.getElementById('uploadBtn').disabled=true;
  try{
    const r=await fetch('/api/mystery/upload',{method:'POST',body:fd});
    const d=await r.json();
    if(d.success){
      msg.innerHTML='<span class="msg-ok">✓ Kuva ladattu!</span>';
      document.getElementById('photoFile').value='';
      document.getElementById('fYear').value='';
      document.getElementById('fPeople').value='';
      document.getElementById('fLocation').value='';
      document.getElementById('fNotes').value='';
      await load();
    } else { msg.innerHTML=`<span class="msg-err">${d.error}</span>`; }
  }catch(e){msg.innerHTML='<span class="msg-err">Virhe</span>';}
  document.getElementById('uploadBtn').disabled=false;
});

// Filters
document.querySelectorAll('.filt').forEach(b=>{
  b.addEventListener('click',()=>{
    document.querySelectorAll('.filt').forEach(x=>x.classList.remove('is-on'));
    b.classList.add('is-on');curFilter=b.dataset.s;renderGrid();
  });
});

function esc(s){const d=document.createElement('div');d.textContent=s||'';return d.innerHTML;}

load();
</script>

<style>
.mp{background:var(--bg-secondary);padding:var(--space-6) 0 var(--space-12);min-height:80vh}
.mp-header{margin-bottom:var(--space-5)}
.mp-title{font-family:var(--font-headline);font-size:2rem;font-weight:900;margin:0 0 var(--space-2)}
.mp-sub{font-size:1rem;color:var(--text-secondary);margin:0 0 var(--space-3);max-width:550px}

.mp-btn{font-family:var(--font-headline);font-size:.85rem;font-weight:700;padding:10px 20px;border-radius:var(--radius-sm);border:2px solid var(--brand-primary);background:var(--brand-primary);color:#000;cursor:pointer;transition:all .15s}
.mp-btn:hover{background:#e08800;border-color:#e08800}
.mp-btn--sec{background:transparent;color:var(--brand-primary)}
.mp-btn--sec:hover{background:var(--brand-primary);color:#000}
.mp-btn--sm{padding:6px 14px;font-size:.78rem}
.mp-btn--danger{background:#E24B4A;border-color:#E24B4A;color:#fff}
.mp-btn--danger:hover{background:#c33;border-color:#c33}
.mp-btn:disabled{opacity:.5;cursor:not-allowed}

.mp-inp{font-family:var(--font-body);font-size:.9rem;padding:8px 12px;border:2px solid #ddd;border-radius:var(--radius-sm);background:#fff;color:var(--text-primary);width:100%;box-sizing:border-box}
.mp-inp:focus{border-color:var(--brand-primary);outline:none}
.mp-ta{min-height:60px;resize:vertical}

.mp-panel{background:#fff;border-radius:var(--radius-md);padding:var(--space-4);margin-bottom:var(--space-4);border:1px solid #eee}
.panel-title{font-family:var(--font-headline);font-size:1.1rem;font-weight:800;margin:0 0 var(--space-2)}
.auth-box{display:flex;gap:var(--space-2);align-items:center;flex-wrap:wrap}
.auth-box .mp-inp{flex:1;min-width:150px;max-width:280px}
.auth-err{color:#E24B4A;font-size:.85rem;font-weight:600}
.form-hint{font-size:.85rem;color:var(--text-secondary);margin:0 0 var(--space-3)}
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:var(--space-2);margin-bottom:var(--space-3)}
.fg label{display:block;font-size:.8rem;font-weight:600;color:var(--text-secondary);margin-bottom:3px}
.fg--full{grid-column:1/-1}

.msg-ok{color:#1D9E75;font-weight:600;font-size:.9rem}
.msg-err{color:#E24B4A;font-weight:600;font-size:.9rem}
.msg-load{color:var(--brand-primary);font-weight:600;font-size:.9rem}

.filters{display:flex;gap:var(--space-2);margin-bottom:var(--space-4);flex-wrap:wrap}
.filt{font-family:var(--font-headline);font-size:.78rem;font-weight:700;padding:6px 14px;border-radius:20px;border:2px solid #ccc;background:transparent;color:var(--text-secondary);cursor:pointer;transition:all .15s}
.filt.is-on,.filt:hover{border-color:var(--brand-primary);color:var(--brand-primary)}
.filt.is-on{background:var(--brand-primary);color:#000}

.grid{display:grid;grid-template-columns:repeat(4,1fr);gap:var(--space-3)}
.card{background:#fff;border-radius:var(--radius-md);overflow:hidden;cursor:pointer;transition:transform .15s,box-shadow .15s}
.card:hover{transform:translateY(-3px);box-shadow:0 4px 20px rgba(0,0,0,.12)}
.card-img{position:relative;aspect-ratio:4/3;overflow:hidden}
.card-img img{width:100%;height:100%;object-fit:cover;display:block}
.card-badge{position:absolute;top:8px;left:8px;font-family:var(--font-headline);font-size:.6rem;font-weight:700;color:#fff;padding:2px 8px;border-radius:10px;text-transform:uppercase}
.card-badge--new{background:var(--brand-primary)}
.card-badge--partial{background:#378ADD}
.card-count{position:absolute;bottom:8px;right:8px;font-size:.75rem;font-weight:700;color:#fff;background:rgba(0,0,0,.6);padding:2px 8px;border-radius:10px}
.card-info{padding:10px 12px}
.card-who{font-size:.8rem;font-weight:600;color:var(--text-primary)}
.card-yr{font-size:.8rem;font-weight:700;color:var(--brand-primary);margin-left:6px}
.card-unk{font-size:.8rem;color:#aaa;font-style:italic}
.empty{text-align:center;color:var(--text-secondary);padding:var(--space-6);grid-column:1/-1}

/* Modal */
.modal{position:fixed;inset:0;z-index:1000;display:flex;align-items:center;justify-content:center}
.modal-bg{position:absolute;inset:0;background:rgba(0,0,0,.85)}
.modal-box{position:relative;background:#fff;border-radius:var(--radius-md);max-width:1100px;width:95%;max-height:90vh;overflow-y:auto}
.modal-x{position:absolute;top:12px;right:16px;font-size:1.5rem;background:none;border:none;cursor:pointer;color:#666;z-index:10}
.modal-inner{display:grid;grid-template-columns:1fr 1fr}
.modal-img-wrap{background:#000;display:flex;align-items:center;justify-content:center;min-height:400px}
.modal-img{width:100%;height:auto;max-height:80vh;object-fit:contain}
.modal-side{padding:var(--space-4);overflow-y:auto;max-height:80vh}

/* Admin bar */
.admin-bar{margin-bottom:var(--space-3)}
.ab-inner{background:#FFF3E0;border-radius:var(--radius-sm);padding:var(--space-3);border:1px solid #FFE0B2}
.ab-title{font-family:var(--font-headline);font-size:.85rem;font-weight:800;color:var(--brand-primary);margin:0 0 var(--space-2)}
.ab-fields{display:grid;grid-template-columns:1fr 1fr;gap:var(--space-2);margin-bottom:var(--space-2)}
.ab-f label{font-size:.7rem;font-weight:600;color:var(--text-secondary);display:block;margin-bottom:2px}
.ab-actions{display:flex;gap:var(--space-2);flex-wrap:wrap;align-items:center}
.ab-sel{width:auto;min-width:130px}

/* Section A */
.sec-a{margin-bottom:var(--space-3);padding-bottom:var(--space-3);border-bottom:1px solid #eee}
.sec-title{font-family:var(--font-headline);font-size:1rem;font-weight:800;margin:0 0 var(--space-2)}
.name-row{margin-bottom:var(--space-2)}
.name-row .mp-inp{max-width:250px}
.locked-fields{margin-bottom:var(--space-2)}
.locked-field{font-size:.9rem;margin-bottom:4px;color:var(--text-primary)}
.lf-label{color:var(--text-secondary);font-weight:600;font-size:.8rem}
.fi-row{margin-bottom:var(--space-2)}
.fi-label{font-size:.8rem;font-weight:700;color:var(--text-secondary);display:block;margin-bottom:3px}
.fi-input-row{display:flex;gap:6px}
.fi-inp{flex:1}
.all-done{color:#1D9E75;font-weight:600;font-size:.9rem;margin:0}

/* Section B — Thread */
.sec-b{margin-top:var(--space-2)}
.no-msg{color:#aaa;font-style:italic;font-size:.9rem}
.msg{background:#f5f5f5;border-radius:var(--radius-sm);padding:12px;margin-bottom:var(--space-2)}
.msg--reply{background:#fafafa;margin-top:8px;margin-left:16px;border-left:2px solid #ddd;padding:10px 12px}
.msg-head{display:flex;align-items:center;gap:8px;margin-bottom:4px;flex-wrap:wrap}
.msg-field{font-size:.65rem;font-weight:700;color:#fff;background:var(--brand-primary);padding:1px 6px;border-radius:8px;text-transform:uppercase}
.msg-author{font-size:.85rem;font-weight:700;color:var(--text-primary)}
.msg-date{font-size:.72rem;color:#aaa}
.msg-del{background:none;border:none;cursor:pointer;font-size:.85rem;opacity:.4;padding:0}
.msg-del:hover{opacity:1}
.msg-text{font-size:.9rem;color:var(--text-primary);margin:0 0 6px;line-height:1.5}
.msg-actions{display:flex;gap:8px;align-items:center}
.vote-btn{background:none;border:1px solid #ddd;border-radius:14px;padding:2px 10px;font-size:.78rem;cursor:pointer;transition:all .15s}
.vote-btn:hover{border-color:var(--brand-primary)}
.vote-on{background:#eee;border-color:var(--brand-primary)}
.reply-toggle{background:none;border:none;font-size:.78rem;color:var(--brand-primary);cursor:pointer;font-weight:600}
.reply-toggle:hover{text-decoration:underline}
.reply-form{display:flex;gap:6px;margin-top:8px}
.reply-inp{flex:1}
.replies{margin-top:8px}
.free-comment{margin-top:var(--space-3);display:flex;flex-direction:column;gap:var(--space-2)}

@media(max-width:900px){.grid{grid-template-columns:repeat(2,1fr)}.modal-inner{grid-template-columns:1fr}.modal-img-wrap{min-height:250px}.form-grid,.ab-fields{grid-template-columns:1fr}}
@media(max-width:540px){.grid{grid-template-columns:1fr}.mp-title{font-size:1.5rem}.fi-input-row{flex-direction:column}}
</style>

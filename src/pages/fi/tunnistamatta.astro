function esc(s){const d=document.createElement('div');d.textContent=s||'';return d.innerHTML;}
function escAttr(s){return esc(s).replace(/"/g,'&quot;');}
// Walk up parent_id chain to find the root comment's field_type.
// New replies inherit the field they belong to, so the whole debate stays bound to its parent field.
function getRootFieldType(comments, commentId){
  const byId=Object.fromEntries(comments.map(c=>[c.id,c]));
  let c=byId[commentId];
  while(c && c.parent_id){c=byId[c.parent_id];}
  return c ? (c.field_type||'general') : 'general';
}

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { ui } from '../../i18n/ui';

const lang = 'en';
const t = ui[lang];

const galleries = await getCollection('galleries');
const featuredGalleries = galleries.slice(0, 4);
---

<BaseLayout 
  title="Home" 
  lang={lang}
  description="Motorsport history photos and stories - Photo & Moto"
>
  <section class="hero">
    <div class="container">
      <h1 class="hero-title">{t['hero.tagline']}</h1>
      <p class="hero-subtitle">{t['hero.subtitle']}</p>
    </div>
  </section>
  
  <section class="intro-section">
    <div class="container">
      <div class="intro-grid">
        <div class="intro-col">
          <h2 class="intro-title">Welcome to the archive</h2>
          <div class="intro-image-wrap">
            <img src="/images/intro-gallery.jpg" alt="Welcome" class="intro-image" />
          </div>
          <p class="intro-text">Motorsport history and amazing stories. We add new photos and articles regularly, so stay tuned!</p>
        </div>
        <div class="intro-col">
          <h2 class="intro-title">Travel back in time</h2>
          <div class="intro-image-wrap">
            <img src="/images/intro-articles.jpg" alt="Time Machine" class="intro-image" />
          </div>
          <p class="intro-text">Dive into the stories and technology of motorsport. We bring history's most thrilling moments straight to you.</p>
        </div>
      </div>
    </div>
  </section>
  
  {featuredGalleries.length > 0 && (
    <section class="section featured-galleries">
      <div class="container">
        <div class="section__header">
          <h2 class="section__title">Gallery</h2>
          <p class="section__subtitle">Explore photo galleries from different eras</p>
        </div>
        
        <p class="gallery-intro">Find your favorite moments easily. These photos capture the atmosphere of history and take you straight to the sport's most significant moments.</p>
        
        <div class="grid grid--4">
          {featuredGalleries.map(gallery => (
            <article class="card">
              <a href={`/en/gallery/${gallery.data.slug}`}>
                <img src={`/galleries/${gallery.data.slug}/${gallery.data.cover_image}`} alt={gallery.data.title} class="card__image" loading="lazy" />
                <div class="card__content">
                  <h3 class="card__title">{gallery.data.title}</h3>
                  <p class="card__text">{t['gallery.photoCount'].replace('{count}', gallery.data.images.length.toString())}</p>
                </div>
              </a>
            </article>
          ))}
        </div>
        
        <div style="text-align: center; margin-top: var(--space-6);">
          <a href="/en/gallery" class="btn btn--secondary">View all galleries</a>
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .hero {
    background: linear-gradient(rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0.5)),
                url('/images/hero-bg.jpg') center/cover;
    color: white;
    text-align: center;
    padding: var(--space-12) 0;
    margin-bottom: 0;
  }
  .hero-title { font-size: clamp(2.5rem, 6vw, 4rem); margin-bottom: var(--space-3); color: white; font-weight: 900; text-shadow: 2px 2px 4px rgba(0,0,0,0.3); }
  .hero-subtitle { font-size: clamp(1.125rem, 2vw, 1.5rem); color: rgba(255, 255, 255, 0.9); font-style: italic; margin-bottom: 0; }
  .intro-section { background: white; color: var(--text-primary); padding: var(--space-12) 0 var(--space-8); }
  .intro-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-6); align-items: start; }
  .intro-image-wrap { position: relative; overflow: hidden; border-radius: var(--radius-md); margin-bottom: var(--space-3); height: 280px; }
  .intro-image { width: 100%; height: 100%; display: block; object-fit: cover; }
  .intro-title { font-size: 1.75rem; font-weight: 900; color: var(--text-primary); margin-bottom: var(--space-3); text-align: center; }
  .intro-text { font-size: 1rem; line-height: 1.7; color: var(--text-secondary); font-weight: 600; }
  .featured-galleries { background: white; }
  .gallery-intro { max-width: 100%; margin: 0 auto var(--space-6); text-align: center; font-size: 1.05rem; line-height: 1.7; color: var(--text-secondary); font-weight: 600; }
  @media (max-width: 768px) { .intro-grid { grid-template-columns: 1fr; } .intro-image-wrap { height: 220px; } }
</style>
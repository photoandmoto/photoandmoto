---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TrendingTicker from '../../components/TrendingTicker.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import UpcomingRaces from '../../components/UpcomingRaces.astro';
import RotatingHeroSplit from '../../components/RotatingHeroSplit.astro';
import MysteryHelpBlock from '../../components/MysteryHelpBlock.astro';
import { getCollection } from 'astro:content';
import { ui } from '../../i18n/ui';

const lang = 'en';
const t = ui[lang];

const articles = (await getCollection('articles', ({ data }) =>
  data.language === 'en' && !data.draft
)).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const slugFor = (a) => `/en/time-machine/${a.slug.replace(/^en\//, '')}`;
const imgFor = (a) => a.data.card_image || a.data.featured_image;

const bigCard = articles[0];
const stackedCards = articles.slice(1, 3);
const secondaryCards = articles.slice(3, 7);

const tickerItems = articles.slice(0, 5).map(a => ({
  href: slugFor(a),
  title: a.data.title,
}));

const galleries = await getCollection('galleries');
const featuredGalleries = galleries.slice(0, 4);

// Build items array for galleries
const galleryItems = featuredGalleries.map(g => ({
  href: `/en/gallery/${g.data.slug}`,
  image: `/galleries/${g.data.slug}/${g.data.cover_image}`,
  title: g.data.title,
  subtitle: t['gallery.photoCount'].replace('{count}', g.data.images.length.toString()),
}));
---

<BaseLayout
  title="Home"
  lang={lang}
  description="Motocross and motorcycle sport photos, stories and race results from the 1960s to today. MXGP 2026, Time Machine archive and photo gallery."
>

  <TrendingTicker label="Trending now" items={tickerItems} slot="pre-header" />

  {/* ===== Typographic hero band ===== */}
  <section class="hero-band">
    <div class="container">
      <div class="hero-band__row">
        <h1 class="hero-band__title">Speed and life through the lens – Every frame tells a story</h1>
      </div>
    </div>
  </section>

  {/* ===== Featured grid (articles) ===== */}
  {bigCard && (
    <section class="section featured-grid-section">
      <div class="container">
        <div class="section-header-row">
          <h2 class="section-heading">Latest articles</h2>
          <a href="/en/time-machine" class="section-all-link">All articles →</a>
        </div>
        <div class="hero-split">
          <div class="hero-split__big">
            <ArticleCard
              href={slugFor(bigCard)}
              image={imgFor(bigCard)}
              category={bigCard.data.category}
              title={bigCard.data.title}
              subtitle={bigCard.data.subtitle}
              size="lg"
            />
          </div>
          <div class="hero-split__stack">
            {stackedCards.map(a => (
              <ArticleCard
                href={slugFor(a)}
                image={imgFor(a)}
                category={a.data.category}
                title={a.data.title}
                size="md"
              />
            ))}
          </div>
        </div>

        {secondaryCards.length > 0 && (
          <div class="secondary-row">
            {secondaryCards.map(a => (
              <ArticleCard
                href={slugFor(a)}
                image={imgFor(a)}
                category={a.data.category}
                title={a.data.title}
                size="sm"
              />
            ))}
          </div>
        )}
      </div>
    </section>
  )}

  {/* ===== Gallery section (rotating 1 big + 3 stacked) ===== */}
  {featuredGalleries.length > 0 && (
    <section class="section gallery-section">
      <div class="container">
        <div class="section-header-row">
          <h2 class="section-heading">Gallery</h2>
          <a href="/en/gallery" class="section-all-link">All galleries →</a>
        </div>
        <RotatingHeroSplit items={galleryItems} />
      </div>
    </section>
  )}

  {/* ===== Mystery photo help block — appears only when unidentified photos exist ===== */}
  <MysteryHelpBlock lang="en" />

  {/* ===== Upcoming races band ===== */}
  <UpcomingRaces lang="en" />


  {/* ===== Contact CTA section ===== */}
  <section class="section cta-section">
    <div class="container">
      <h2 class="cta-section__heading">Get in touch</h2>
      <div class="cta-grid">
        <a href="/en/yhteystiedot" class="cta-card">
          <h3 class="cta-card__heading">Photo usage</h3>
          <p class="cta-card__body">Want to use our photos? We handle requests on a case-by-case basis.</p>
        </a>
        <a href="/en/yhteystiedot" class="cta-card">
          <h3 class="cta-card__heading">Questions</h3>
          <p class="cta-card__body">Something on your mind? We might have the answer.</p>
        </a>
        <a href="/en/yhteystiedot" class="cta-card">
          <h3 class="cta-card__heading">Stories</h3>
          <p class="cta-card__body">Share a related story as our article.</p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ===== Typographic hero band ===== */
  .hero-band {
    background: #0e0e0e;
    padding: var(--space-3) 0;
  }

  .hero-band__row {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .hero-band__title {
    font-family: var(--font-headline);
    font-size: 1.4rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.75);
    letter-spacing: 0.5px;
    line-height: 1;
    margin: 0;
  }

  /* Section shared */
  .section-header-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: var(--space-4);
    gap: var(--space-3);
  }

  .section-heading {
    font-family: var(--font-headline);
    font-size: 1.75rem;
    font-weight: 900;
    color: var(--text-primary);
    margin: 0;
  }

  .section-all-link {
    font-family: var(--font-headline);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--brand-primary);
    text-decoration: none;
    white-space: nowrap;
  }
  .section-all-link:hover {
    text-decoration: underline;
  }

  /* ===== Shared: 1 big + N stacked layout (hero-split) ===== */
  .hero-split {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: var(--space-3);
    align-items: stretch;
  }

  .hero-split__big {
    display: flex;
    min-height: 380px;
  }
  .hero-split__big > article {
    width: 100%;
  }

  .hero-split__stack {
    display: grid;
    grid-template-rows: repeat(auto-fit, minmax(0, 1fr));
    gap: var(--space-3);
  }
  .hero-split__stack > article {
    min-height: 0;
  }

  /* Articles section */
  .featured-grid-section {
    background: var(--bg-secondary);
    padding-top: var(--space-8);
    padding-bottom: var(--space-6);
  }

  /* Secondary row: 4 cards */
  .secondary-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-3);
    margin-top: var(--space-3);
  }

  /* Gallery section */
  .gallery-section {
    background: white;
    padding: var(--space-6) 0;
  }


  /* ===== CTA section ===== */
  .cta-section {
    background: white;
    padding: var(--space-12) 0;
  }

  .cta-section__heading {
    font-family: var(--font-headline);
    font-size: 1.75rem;
    font-weight: 900;
    color: var(--text-primary);
    margin: 0 0 var(--space-4);
  }

  .cta-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
  }

  .cta-card {
    display: block;
    background: #0e0e0e;
    border-radius: var(--radius-md);
    padding: var(--space-4);
    text-decoration: none;
    transition: transform 0.2s ease, background 0.2s ease;
    border: 1px solid rgba(255, 153, 0, 0.15);
  }

  .cta-card:hover {
    transform: translateY(-2px);
    background: #1a1a1a;
    border-color: rgba(255, 153, 0, 0.4);
  }

  .cta-card__heading {
    font-family: var(--font-headline);
    font-size: 1.2rem;
    font-weight: 900;
    color: var(--brand-primary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin: 0 0 var(--space-2);
    line-height: 1.2;
  }

  .cta-card__body {
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.5;
    margin: 0;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .hero-split {
      grid-template-columns: 1fr;
    }
    .hero-split__big {
      min-height: 320px;
    }
    .hero-split__stack {
      grid-template-rows: auto;
      grid-template-columns: repeat(3, 1fr);
    }
    .secondary-row {
      grid-template-columns: repeat(2, 1fr);
    }
    .cta-grid {
      grid-template-columns: 1fr;
    }
    .cta-section {
      padding: var(--space-8) 0;
    }
  }

  @media (max-width: 640px) {
    .hero-split__stack {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 540px) {
    .hero-split__stack {
      grid-template-columns: 1fr;
    }
    .secondary-row {
      grid-template-columns: 1fr;
    }
    .section-heading {
      font-size: 1.4rem;
    }
    .hero-band__title {
      font-size: 1.1rem;
    }
  }
</style>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
const lang = 'en';
---
<BaseLayout title="AI Search" lang={lang} description="Search Photo & Moto's content with AI">
  <section class="search-page">
    <div class="container">
      <div class="section__header">
        <h1 class="section__title">AI Search</h1>
        <p class="section__subtitle">Ask anything about the site's content</p>
      </div>
      <div class="ai-search-box">
        <div class="ai-input-wrap">
          <input type="text" id="aiQuery" class="ai-input" placeholder="e.g. Who won the world title in 1977?" />
          <button id="aiSearchBtn" class="ai-btn">Search</button>
        </div>
        <div class="ai-examples">
          <span class="ai-ex-label">Try:</span>
          <button class="ai-ex" data-q="Who won the most world championship titles?">Who won the most world titles?</button>
          <button class="ai-ex" data-q="What races are in June 2026?">What races are in June?</button>
          <button class="ai-ex" data-q="Tell me about Pentti Kalteva">Tell me about Pentti Kalteva</button>
        </div>
      </div>
      <div id="aiResult" class="ai-result"></div>
      <p class="search-hint-link">Looking for a page by keyword? Try <a href="/en/search" target="_blank" rel="noopener">keyword search</a>.</p>
    </div>
  </section>
</BaseLayout>
<script>
  const input = document.getElementById('aiQuery');
  const btn = document.getElementById('aiSearchBtn');
  const result = document.getElementById('aiResult');
  let siteData = null;
  let lastSearchTime = 0;
  const COOLDOWN_MS = 15000;
  const queryCache = {};
  // Load site index on page load
  fetch('/data/site-index.json')
    .then(r => r.json())
    .then(d => { siteData = JSON.stringify(d); })
    .catch(() => { siteData = '[]'; });
  function renderMarkdown(text) {
    let lines = text.split('\n');
    let html = '';
    let inList = false;
    lines.forEach(line => {
      line = line.trim();
      if (!line) {
        if (inList) { html += '</ul>'; inList = false; }
        html += '<br>';
        return;
      }
      // Bold
      line = line.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
      // Italic
      line = line.replace(/\*([^*]+)\*/g, '<em>$1</em>');
      // List items (*, -, •)
      if (/^[\*\-•]\s/.test(line)) {
        if (!inList) { html += '<ul class="ai-list">'; inList = true; }
        html += '<li>' + line.replace(/^[\*\-•]\s+/, '') + '</li>';
        return;
      }
      // Numbered list
      if (/^\d+[\.\)]\s/.test(line)) {
        if (!inList) { html += '<ol class="ai-list">'; inList = true; }
        html += '<li>' + line.replace(/^\d+[\.\)]\s+/, '') + '</li>';
        return;
      }
      if (inList) { html += '</ul>'; inList = false; }
      // Headings
      if (line.startsWith('### ')) { html += '<h4 class="ai-h">' + line.slice(4) + '</h4>'; return; }
      if (line.startsWith('## ')) { html += '<h3 class="ai-h">' + line.slice(3) + '</h3>'; return; }
      html += '<p>' + line + '</p>';
    });
    if (inList) html += '</ul>';
    return html;
  }
  async function doSearch() {
    const q = input.value.trim();
    if (q.length < 2) return;
    // Check cooldown
    const now = Date.now();
    const remaining = Math.ceil((COOLDOWN_MS - (now - lastSearchTime)) / 1000);
    if (remaining > 0) {
      result.innerHTML = '<div class="ai-error">Please wait ' + remaining + ' seconds before the next search.</div>';
      return;
    }
    // Check cache
    if (queryCache[q]) {
      const html = renderMarkdown(queryCache[q]);
      result.innerHTML = '<div class="ai-answer"><div class="ai-answer-label">Answer (cached)</div><div class="ai-answer-text">' + html + '</div></div>';
      return;
    }
    result.innerHTML = '<div class="ai-loading"><div class="ai-spinner"></div><span>Searching for an answer...</span></div>';
    btn.disabled = true;
    lastSearchTime = Date.now();
    try {
      const resp = await fetch('/api/search', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ query: q, siteData: siteData, lang: 'en' })
      });
      const data = await resp.json();
      if (data.error) {
        if (data.error.includes('429')) {
          result.innerHTML = '<div class="ai-error">Too many searches. Please wait a moment and try again.</div>';
        } else {
          result.innerHTML = '<div class="ai-error">Search failed: ' + data.error + '</div>';
        }
      } else {
        queryCache[q] = data.answer;
        const html = renderMarkdown(data.answer);
        result.innerHTML = '<div class="ai-answer"><div class="ai-answer-label">Answer</div><div class="ai-answer-text">' + html + '</div></div>';
      }
    } catch (err) {
      result.innerHTML = '<div class="ai-error">Connection error. Please try again.</div>';
    }
    btn.disabled = false;
  }
  btn.addEventListener('click', doSearch);
  input.addEventListener('keydown', (e) => { if (e.key === 'Enter') doSearch(); });
  document.querySelectorAll('.ai-ex').forEach(ex => {
    ex.addEventListener('click', () => {
      input.value = ex.dataset.q;
      doSearch();
    });
  });
</script>

<style is:global>
  .search-page { padding: var(--space-6) 0; }
  .ai-search-box { max-width: 700px; margin: 0 auto var(--space-6); }
  .ai-input-wrap { display: flex; gap: 8px; margin-bottom: var(--space-3); }
  .ai-input { flex: 1; padding: 16px 20px; font-family: var(--font-body); font-size: 1.1rem; border: 2px solid #ddd; border-radius: var(--radius-md); background: #fff; transition: border-color 0.15s; }
  .ai-input:focus { outline: none; border-color: #ff9900; }
  .ai-btn { padding: 16px 32px; background: #ff9900; color: #fff; font-family: var(--font-headline); font-size: 1rem; font-weight: 800; border: none; border-radius: var(--radius-md); cursor: pointer; transition: background 0.15s; text-transform: uppercase; letter-spacing: 0.5px; }
  .ai-btn:hover { background: #cc7a00; }
  .ai-btn:disabled { background: #ccc; cursor: not-allowed; }
  .ai-examples { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; }
  .ai-ex-label { font-size: 0.82rem; color: #6E6E73; font-weight: 600; }
  .ai-ex { padding: 6px 12px; background: #F9F9F9; border: 1px solid #ddd; border-radius: 20px; font-size: 0.78rem; cursor: pointer; transition: all 0.15s; color: #1D1D1F; font-family: var(--font-body); }
  .ai-ex:hover { border-color: #ff9900; color: #ff9900; }
  .ai-result { max-width: 700px; margin: 0 auto; }
  .ai-loading { display: flex; align-items: center; gap: 12px; padding: var(--space-4); color: #6E6E73; font-size: 0.95rem; }
  .ai-spinner { width: 24px; height: 24px; border: 3px solid #eee; border-top-color: #ff9900; border-radius: 50%; animation: spin 0.8s linear infinite; }
  @keyframes spin { to { transform: rotate(360deg); } }
  .ai-answer { background: #F9F9F9; border-radius: var(--radius-md); padding: var(--space-4); border-left: 4px solid #ff9900; }
  .ai-answer-label { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: #ff9900; margin-bottom: var(--space-2); font-family: var(--font-headline); }
  .ai-answer-text { font-size: 0.95rem; line-height: 1.7; color: #1D1D1F; }
  .ai-answer-text p { margin-bottom: 8px; }
  .ai-answer-text strong { font-weight: 800; color: #ff9900; }
  .ai-answer-text .ai-list { margin: 12px 0; padding: 0; list-style: none; display: grid; gap: 6px; }
  .ai-answer-text .ai-list li { background: #fff; border: 1px solid #eee; border-left: 3px solid #ff9900; border-radius: 0 var(--radius-sm) var(--radius-sm) 0; padding: 8px 14px; font-size: 0.9rem; }
  .ai-answer-text .ai-list li strong { color: #1D1D1F; }
  .ai-answer-text .ai-h { font-size: 1rem; font-weight: 800; color: #ff9900; margin: 16px 0 8px; font-family: var(--font-headline); }
  .ai-error { background: #FCEBEB; border-radius: var(--radius-md); padding: var(--space-4); color: #A32D2D; border-left: 4px solid #E24B4A; }
  .search-hint-link { text-align: center; color: var(--text-secondary); font-size: 0.9rem; margin-top: var(--space-6); }
  .search-hint-link a { color: var(--brand-primary); font-weight: 600; }
  .search-hint-link a:hover { text-decoration: underline; }
</style>

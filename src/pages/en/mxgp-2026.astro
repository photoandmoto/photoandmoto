---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import heroImage from '../../assets/mxgp/hero-trentino.jpg';
import upcomingImage from '../../assets/mxgp/upcoming-default.jpg';
import fs from 'fs';

const lang = 'en';
const raw = fs.readFileSync('public/data/mxgp-results.json', 'utf-8');
const data = JSON.parse(raw);
const race = data.latestRace;
const standings = data.standings;
const nextRace = data.nextRace;
const highlights = data.highlights || {};

// Backward-compat: if old flat shape ({fi:[], en:[]}) is still on disk, treat as empty per-tab
const rawHL = data.highlights || {};
const hlEn = (rawHL.en && !Array.isArray(rawHL.en)) ? rawHL.en : {};
// New 5-bucket schema (with backward-compat for older 3-bucket schema)
const highlightsByTab: {
  mxgp_quali: string[]; mxgp_race: string[];
  mx2_quali: string[];  mx2_race: string[];
  standings: string[];
} = {
  mxgp_quali: hlEn.mxgp_quali || [],
  mxgp_race:  hlEn.mxgp_race  || hlEn.mxgp || [],
  mx2_quali:  hlEn.mx2_quali  || [],
  mx2_race:   hlEn.mx2_race   || hlEn.mx2  || [],
  standings:  hlEn.standings  || [],
};
const tabTitles: Record<string, string> = {
  mxgp: 'MXGP – Weekend Highlights',
  mx2: 'MX2 – Weekend Highlights',
  standings: 'Championship Standings',
};
const qualiTitles: Record<string, string> = {
  mxgp: 'MXGP – Qualifying Race (Saturday)',
  mx2: 'MX2 – Qualifying Race (Saturday)',
};
const hasAnyHighlights =
  highlightsByTab.mxgp_quali.length + highlightsByTab.mxgp_race.length +
  highlightsByTab.mx2_quali.length  + highlightsByTab.mx2_race.length +
  highlightsByTab.standings.length > 0;

function formatDate(dateStr: string) {
  const d = new Date(dateStr);
  const months = ['January','February','March','April','May','June','July','August','September','October','November','December'];
  return `${months[d.getMonth()]} ${d.getDate()}, ${d.getFullYear()}`;
}

function daysUntil(dateStr: string): number | null {
  if (!dateStr) return null;
  const target = new Date(dateStr + 'T00:00:00').getTime();
  const today = new Date(); today.setHours(0,0,0,0);
  const diff = Math.round((target - today.getTime()) / (1000 * 60 * 60 * 24));
  return diff >= 0 ? diff : null;
}
---

<BaseLayout 
  title="MXGP 2026 — Results & Standings" 
  lang={lang}
  description="MXGP and MX2 2026 results, latest race highlights and world championship standings. Updated weekly."
>
  <section class="mxgp-page">
    <div class="container">
      <p class="page-eyebrow">MXGP 2026 · Results &amp; Championship Standings</p>

      {race ? (
        <>
          <!-- Race overview: hero (current race) + next-race card side-by-side on desktop -->
          <div class={`race-overview ${nextRace ? 'race-overview--has-next' : ''}`}>
            <!-- Hero Race Banner: photo background + race info overlay -->
            <div class="race-hero">
              <Image
                src={heroImage}
                alt="MXGP race photo"
                class="race-hero__img"
                widths={[768, 1280, 1920]}
                sizes="(max-width: 768px) 100vw, (max-width: 1280px) 100vw, 1920px"
                loading="eager"
              />
              <div class="race-hero__overlay"></div>
              <div class="race-hero__content">
                <div class="race-hero__round">Round {race.round}/{data.totalRounds}</div>
                <h1 class="race-hero__title">{race.name}</h1>
                <div class="race-hero__meta">
                  <span>📍 {race.location}</span>
                  <span>📅 {formatDate(race.date)}</span>
                </div>
                {data.seasonComplete && (
                  <div class="race-hero__final">🏆 Season complete — final results</div>
                )}
              </div>
            </div>

            {nextRace && (
              <div class="next-race">
                <Image
                  src={upcomingImage}
                  alt="Upcoming MXGP race"
                  class="next-race__img"
                  widths={[400, 600, 900]}
                  sizes="(max-width: 768px) 100vw, 33vw"
                  loading="eager"
                />
                <div class="next-race__overlay"></div>
                <div class="next-race__content">
                  <div class="next-race__eyebrow">Next round</div>
                  <div class="next-race__round">Round {nextRace.round}/{data.totalRounds}</div>
                  <h2 class="next-race__title">{nextRace.name}</h2>
                  <div class="next-race__meta">
                    <div>📍 {nextRace.location}</div>
                    {nextRace.date && <div>📅 {formatDate(nextRace.date)}</div>}
                  </div>
                  {daysUntil(nextRace.date) !== null && (
                    <div class="next-race__countdown">
                      <span class="next-race__countdown-num">{daysUntil(nextRace.date)}</span>
                      <span class="next-race__countdown-label">{daysUntil(nextRace.date) === 1 ? 'day to go' : 'days to go'}</span>
                    </div>
                  )}
                </div>
              </div>
            )}
          </div>

          {hasAnyHighlights && (
            <div class="highlights-stack" id="highlightsStack">
              <!-- MXGP group -->
              <div class="highlights-group highlights-group--active" data-highlights-group="mxgp">
                {highlightsByTab.mxgp_quali.length > 0 && (
                  <div class="highlights-card highlights-card--saturday">
                    <div class="highlights-card__header">
                      <span class="highlights-card__icon">🕒</span>
                      <h3 class="highlights-card__title">{qualiTitles.mxgp}</h3>
                    </div>
                    <ul class="highlights-card__list">
                      {highlightsByTab.mxgp_quali.map((h: string) => (<li>{h}</li>))}
                    </ul>
                  </div>
                )}
                {highlightsByTab.mxgp_race.length > 0 && (
                  <div class="highlights-card">
                    <div class="highlights-card__header">
                      <span class="highlights-card__icon">🏁</span>
                      <h3 class="highlights-card__title">{tabTitles.mxgp}</h3>
                    </div>
                    <ul class="highlights-card__list">
                      {highlightsByTab.mxgp_race.map((h: string) => (<li>{h}</li>))}
                    </ul>
                  </div>
                )}
              </div>

              <!-- MX2 group -->
              <div class="highlights-group" data-highlights-group="mx2">
                {highlightsByTab.mx2_quali.length > 0 && (
                  <div class="highlights-card highlights-card--saturday">
                    <div class="highlights-card__header">
                      <span class="highlights-card__icon">🕒</span>
                      <h3 class="highlights-card__title">{qualiTitles.mx2}</h3>
                    </div>
                    <ul class="highlights-card__list">
                      {highlightsByTab.mx2_quali.map((h: string) => (<li>{h}</li>))}
                    </ul>
                  </div>
                )}
                {highlightsByTab.mx2_race.length > 0 && (
                  <div class="highlights-card">
                    <div class="highlights-card__header">
                      <span class="highlights-card__icon">🏁</span>
                      <h3 class="highlights-card__title">{tabTitles.mx2}</h3>
                    </div>
                    <ul class="highlights-card__list">
                      {highlightsByTab.mx2_race.map((h: string) => (<li>{h}</li>))}
                    </ul>
                  </div>
                )}
              </div>

              <!-- Standings group -->
              <div class="highlights-group" data-highlights-group="standings">
                {highlightsByTab.standings.length > 0 && (
                  <div class="highlights-card">
                    <div class="highlights-card__header">
                      <span class="highlights-card__icon">🏆</span>
                      <h3 class="highlights-card__title">{tabTitles.standings}</h3>
                    </div>
                    <ul class="highlights-card__list">
                      {highlightsByTab.standings.map((h: string) => (<li>{h}</li>))}
                    </ul>
                  </div>
                )}
              </div>
            </div>
          )}

          <div class="mxgp-tabs" id="classTabs">
            <button class="mxgp-tab mxgp-tab--active" data-class="mxgp">MXGP</button>
            <button class="mxgp-tab" data-class="mx2">MX2</button>
            <button class="mxgp-tab" data-class="standings">Standings</button>
          </div>

          <!-- MXGP Results -->
          <div class="mxgp-panel mxgp-panel--active" data-panel="mxgp">
            {race.mxgp.qualifying.length > 0 && (
              <>
                <h3 class="result-section-title">Qualifying Race (Saturday)</h3>
                <div class="table-wrap">
                  <table class="result-table result-table--compact">
                    <thead><tr><th>Pos</th><th>Rider</th><th>Bike</th><th>Nat</th></tr></thead>
                    <tbody>
                      {race.mxgp.qualifying.map((r: any) => (
                        <tr class={r.pos <= 3 ? `podium podium--${r.pos}` : ''}>
                          <td class="pos">{r.pos}</td><td class="rider">{r.rider}</td><td>{r.bike}</td><td>{r.nat}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </>
            )}

            <div class="race-grid">
              <div>
                <h3 class="result-section-title">Race 1 (Sunday)</h3>
                <div class="table-wrap">
                  <table class="result-table result-table--compact">
                    <thead><tr><th>Pos</th><th>Rider</th><th>Bike</th><th>Pts</th></tr></thead>
                    <tbody>
                      {race.mxgp.race1.map((r: any) => (
                        <tr class={r.pos <= 3 ? `podium podium--${r.pos}` : ''}>
                          <td class="pos">{r.pos}</td><td class="rider">{r.rider}</td><td>{r.bike}</td><td class="pts">{r.pts}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
              <div>
                <h3 class="result-section-title">Race 2 (Sunday)</h3>
                <div class="table-wrap">
                  <table class="result-table result-table--compact">
                    <thead><tr><th>Pos</th><th>Rider</th><th>Bike</th><th>Pts</th></tr></thead>
                    <tbody>
                      {race.mxgp.race2.map((r: any) => (
                        <tr class={r.pos <= 3 ? `podium podium--${r.pos}` : ''}>
                          <td class="pos">{r.pos}</td><td class="rider">{r.rider}</td><td>{r.bike}</td><td class="pts">{r.pts}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
            </div>

            <h3 class="result-section-title">GP Overall Classification</h3>
            <div class="table-wrap">
              <table class="result-table">
                <thead><tr><th>Pos</th><th>Rider</th><th>Bike</th><th>Nat</th><th>Pts</th></tr></thead>
                <tbody>
                  {race.mxgp.overall.map((r: any) => (
                    <tr class={r.pos <= 3 ? `podium podium--${r.pos}` : ''}>
                      <td class="pos">{r.pos}</td><td class="rider">{r.rider}</td><td>{r.bike}</td><td>{r.nat}</td><td class="pts">{r.pts}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>

          <!-- MX2 Results -->
          <div class="mxgp-panel" data-panel="mx2">
            {race.mx2.qualifying.length > 0 && (
              <>
                <h3 class="result-section-title">Qualifying Race (Saturday)</h3>
                <div class="table-wrap">
                  <table class="result-table result-table--compact">
                    <thead><tr><th>Pos</th><th>Rider</th><th>Bike</th><th>Nat</th></tr></thead>
                    <tbody>
                      {race.mx2.qualifying.map((r: any) => (
                        <tr class={r.pos <= 3 ? `podium podium--${r.pos}` : ''}>
                          <td class="pos">{r.pos}</td><td class="rider">{r.rider}</td><td>{r.bike}</td><td>{r.nat}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </>
            )}

            <div class="race-grid">
              <div>
                <h3 class="result-section-title">Race 1 (Sunday)</h3>
                <div class="table-wrap">
                  <table class="result-table result-table--compact">
                    <thead><tr><th>Pos</th><th>Rider</th><th>Bike</th><th>Pts</th></tr></thead>
                    <tbody>
                      {race.mx2.race1.map((r: any) => (
                        <tr class={r.pos <= 3 ? `podium podium--${r.pos}` : ''}>
                          <td class="pos">{r.pos}</td><td class="rider">{r.rider}</td><td>{r.bike}</td><td class="pts">{r.pts}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
              <div>
                <h3 class="result-section-title">Race 2 (Sunday)</h3>
                <div class="table-wrap">
                  <table class="result-table result-table--compact">
                    <thead><tr><th>Pos</th><th>Rider</th><th>Bike</th><th>Pts</th></tr></thead>
                    <tbody>
                      {race.mx2.race2.map((r: any) => (
                        <tr class={r.pos <= 3 ? `podium podium--${r.pos}` : ''}>
                          <td class="pos">{r.pos}</td><td class="rider">{r.rider}</td><td>{r.bike}</td><td class="pts">{r.pts}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
            </div>

            <h3 class="result-section-title">GP Overall Classification</h3>
            <div class="table-wrap">
              <table class="result-table">
                <thead><tr><th>Pos</th><th>Rider</th><th>Bike</th><th>Nat</th><th>Pts</th></tr></thead>
                <tbody>
                  {race.mx2.overall.map((r: any) => (
                    <tr class={r.pos <= 3 ? `podium podium--${r.pos}` : ''}>
                      <td class="pos">{r.pos}</td><td class="rider">{r.rider}</td><td>{r.bike}</td><td>{r.nat}</td><td class="pts">{r.pts}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>

          <!-- Standings -->
          <div class="mxgp-panel" data-panel="standings">
            <div class="standings-grid">
              <div>
                <h3 class="result-section-title">MXGP — Championship Standings</h3>
                <div class="table-wrap">
                  <table class="result-table">
                    <thead><tr><th>Pos</th><th>Rider</th><th>Bike</th><th>Nat</th><th>Pts</th></tr></thead>
                    <tbody>
                      {standings.mxgp.map((r: any) => (
                        <tr class={r.pos <= 3 ? `podium podium--${r.pos}` : ''}>
                          <td class="pos">{r.pos}</td><td class="rider">{r.rider}</td><td>{r.bike}</td><td>{r.nat}</td><td class="pts">{r.pts}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
              <div>
                <h3 class="result-section-title">MX2 — Championship Standings</h3>
                <div class="table-wrap">
                  <table class="result-table">
                    <thead><tr><th>Pos</th><th>Rider</th><th>Bike</th><th>Nat</th><th>Pts</th></tr></thead>
                    <tbody>
                      {standings.mx2.map((r: any) => (
                        <tr class={r.pos <= 3 ? `podium podium--${r.pos}` : ''}>
                          <td class="pos">{r.pos}</td><td class="rider">{r.rider}</td><td>{r.bike}</td><td>{r.nat}</td><td class="pts">{r.pts}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
          </div>

          <p class="mxgp-updated">Updated: {data.lastUpdated} · Auto-updates every Sunday</p>
          <p class="mxgp-source">Source: <a href="https://mxgpresults.com" target="_blank" rel="noopener">mxgpresults.com</a></p>
        </>
      ) : (
        <div class="mxgp-offseason">
          <p>The 2026 MXGP season has not started yet. Results will update automatically after the first round.</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<script>
  const tabs = document.querySelectorAll('.mxgp-tab');
  const panels = document.querySelectorAll('.mxgp-panel');
  const hlGroups = document.querySelectorAll('.highlights-group');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const target = (tab as HTMLElement).dataset.class;
      tabs.forEach(t => t.classList.remove('mxgp-tab--active'));
      panels.forEach(p => p.classList.remove('mxgp-panel--active'));
      tab.classList.add('mxgp-tab--active');
      document.querySelector(`[data-panel="${target}"]`)?.classList.add('mxgp-panel--active');

      hlGroups.forEach(g => g.classList.remove('highlights-group--active'));
      document.querySelector(`[data-highlights-group="${target}"]`)?.classList.add('highlights-group--active');
    });
  });
</script>

<style is:global>
  .mxgp-page { padding: var(--space-6) 0 var(--space-8); }
  .page-eyebrow { font-family: var(--font-headline); font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1.2px; color: var(--text-secondary); margin: 0 0 var(--space-2); }
  .race-overview { display: grid; grid-template-columns: 1fr; gap: var(--space-4); margin-bottom: var(--space-5); }
  .race-overview--has-next { grid-template-columns: minmax(0, 2fr) minmax(0, 1fr); }
  .next-race { position: relative; border-radius: var(--radius-lg); overflow: hidden; color: white; border-left: 4px solid rgba(255, 165, 0, 0.55); min-height: 360px; background: #1a1a1a; }
  .next-race__img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: center; }
  .next-race__overlay { position: absolute; inset: 0; background: linear-gradient(135deg, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.55) 60%, rgba(0,0,0,0.4) 100%), linear-gradient(to top, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0) 55%); }
  .next-race__content { position: absolute; inset: 0; padding: var(--space-5); display: flex; flex-direction: column; justify-content: space-between; }
  .next-race__eyebrow { font-family: var(--font-headline); font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px; color: rgba(255, 165, 0, 0.95); margin-bottom: var(--space-2); text-shadow: 0 1px 3px rgba(0,0,0,0.7); }
  .next-race__round { font-family: var(--font-headline); font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: rgba(255,255,255,0.85); margin-bottom: var(--space-1); text-shadow: 0 1px 3px rgba(0,0,0,0.7); }
  .next-race__title { font-size: clamp(1.3rem, 2.4vw, 1.8rem); font-weight: 900; margin: 0 0 var(--space-3); color: white; line-height: 1.15; text-shadow: 0 2px 6px rgba(0,0,0,0.85); }
  .next-race__meta { display: flex; flex-direction: column; gap: 4px; font-size: 0.92rem; color: rgba(255,255,255,0.95); margin-bottom: var(--space-3); text-shadow: 0 1px 3px rgba(0,0,0,0.7); }
  .next-race__countdown { display: flex; align-items: baseline; gap: 10px; margin-top: auto; padding-top: var(--space-3); border-top: 1px solid rgba(255,255,255,0.2); }
  .next-race__countdown-num { font-family: var(--font-headline); font-size: 2.4rem; font-weight: 900; color: var(--brand-primary); line-height: 1; text-shadow: 0 2px 6px rgba(0,0,0,0.85); }
  .next-race__countdown-label { font-size: 0.85rem; color: rgba(255,255,255,0.9); text-transform: lowercase; text-shadow: 0 1px 3px rgba(0,0,0,0.7); }
  .race-hero { position: relative; border-radius: var(--radius-lg); overflow: hidden; height: 360px; background: #1a1a1a; border-left: 5px solid var(--brand-primary); }
  .race-hero__img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: center; }
  .race-hero__overlay { position: absolute; inset: 0; background: linear-gradient(135deg, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.45) 50%, rgba(0,0,0,0.25) 100%), linear-gradient(to top, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0) 60%); }
  .race-hero__content { position: absolute; inset: 0; display: flex; flex-direction: column; justify-content: flex-end; padding: var(--space-5); color: white; }
  .race-hero__round { font-family: var(--font-headline); font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--brand-primary); margin-bottom: var(--space-1); text-shadow: 0 1px 3px rgba(0,0,0,0.7); }
  .race-hero__title { font-size: clamp(1.8rem, 4vw, 2.6rem); font-weight: 900; margin: 0 0 var(--space-2); color: white; text-shadow: 0 2px 6px rgba(0,0,0,0.8); line-height: 1.1; }
  .race-hero__meta { display: flex; gap: var(--space-4); font-size: 0.95rem; color: rgba(255,255,255,0.92); flex-wrap: wrap; text-shadow: 0 1px 3px rgba(0,0,0,0.7); }
  .race-hero__final { margin-top: var(--space-2); font-family: var(--font-headline); font-size: 0.9rem; font-weight: 700; color: var(--brand-primary); text-shadow: 0 1px 3px rgba(0,0,0,0.7); }
  .mxgp-tabs { display: flex; gap: 4px; margin-bottom: var(--space-4); background: #f0f0f0; border-radius: var(--radius-md); padding: 4px; }
  .mxgp-tab { flex: 1; padding: 10px 16px; font-family: var(--font-headline); font-size: 0.85rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; background: transparent; border: none; border-radius: var(--radius-sm); cursor: pointer; transition: all var(--transition-fast); color: var(--text-secondary); }
  .mxgp-tab:hover { background: #e0e0e0; }
  .mxgp-tab--active { background: #000; color: var(--brand-primary); box-shadow: var(--shadow-sm); }
  .mxgp-panel { display: none; }
  .mxgp-panel--active { display: block; }
  .result-section-title { font-family: var(--font-headline); font-size: 1rem; font-weight: 800; color: var(--text-primary); margin-bottom: var(--space-2); text-transform: uppercase; letter-spacing: 0.5px; }
  .result-section-title--toggle { cursor: pointer; color: var(--brand-primary); user-select: none; }
  .result-section-title--toggle:hover { opacity: 0.8; }
  .table-wrap { overflow-x: auto; margin-bottom: var(--space-4); border-radius: var(--radius-md); box-shadow: var(--shadow-sm); }
  .result-table { width: 100%; border-collapse: collapse; font-size: 0.9rem; background: white; }
  .result-table thead { background: #1a1a1a; color: white; }
  .result-table th { padding: 10px 12px; text-align: left; font-family: var(--font-headline); font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; white-space: nowrap; }
  .result-table td { padding: 10px 12px; border-bottom: 1px solid #f0f0f0; }
  .result-table tbody tr:hover { background: #fafafa; }
  .result-table .pos { font-weight: 800; font-family: var(--font-headline); width: 40px; text-align: center; }
  .result-table .rider { font-weight: 700; }
  .result-table .pts { font-weight: 800; font-family: var(--font-headline); color: var(--brand-primary); text-align: right; }
  .podium--1 { background: rgba(255,215,0,0.08); }
  .podium--1 .pos { color: #B8860B; }
  .podium--2 { background: rgba(192,192,192,0.08); }
  .podium--2 .pos { color: #808080; }

---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  lang: 'fi' | 'en';
}

const {
  title,
  description = 'Moottoriurheilun historian kuvia ja tarinoita',
  image = '/images/og-default.jpg',
  lang = 'fi',
} = Astro.props;

const siteUrl = 'https://photoandmoto.fi';
const fullTitle = `${title} | Photo & Moto`;
const ogImage = image.startsWith('http') ? image : `${siteUrl}${image}`;
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  
  <title>{fullTitle}</title>
  <meta name="description" content={description}>
  
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
  
  <!-- Styles -->
  <link rel="stylesheet" href="/src/styles/brand.css">
  <link rel="stylesheet" href="/src/styles/global.css">
  <link rel="stylesheet" href="/src/styles/components.css">
  
  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:url" content={`${siteUrl}${Astro.url.pathname}`}>
  <meta property="og:title" content={fullTitle}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={ogImage}>
  <meta property="og:locale" content={lang === 'fi' ? 'fi_FI' : 'en_US'}>
  
  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:url" content={`${siteUrl}${Astro.url.pathname}`}>
  <meta name="twitter:title" content={fullTitle}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={ogImage}>
  
  <!-- Favicon -->
  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  
  <!-- Language alternates -->
  <link rel="alternate" hreflang="fi" href={`${siteUrl}/fi${Astro.url.pathname.replace(/^\/(fi|en)/, '')}`}>
  <link rel="alternate" hreflang="en" href={`${siteUrl}/en${Astro.url.pathname.replace(/^\/(fi|en)/, '')}`}>
  <link rel="alternate" hreflang="x-default" href={`${siteUrl}/fi${Astro.url.pathname.replace(/^\/(fi|en)/, '')}`}>
</head>
<body>
  <Header lang={lang} currentPath={Astro.url.pathname} />
  
  <main>
    <slot />
  </main>
  
  <Footer lang={lang} />
</body>
</html>

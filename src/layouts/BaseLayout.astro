---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/brand.css';
import '../styles/global.css';
import '../styles/components.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  lang: 'fi' | 'en';
}

const {
  title,
  description = 'Moottoriurheilun historian kuvia ja tarinoita',
  image = '/images/og-default.jpg',
  lang = 'fi',
} = Astro.props;

const siteUrl = import.meta.env.SITE || 'https://photoandmoto.pages.dev';
const fullTitle = `${title} | Photo & Moto`;
const ogImage = image.startsWith('http') ? image : `${siteUrl}${image}`;
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  
  <title>{fullTitle}</title>
  <meta name="description" content={description}>
  
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,400;0,600;0,700;0,800;0,900;1,400;1,600&display=swap" rel="stylesheet">
  
  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:url" content={`${siteUrl}${Astro.url.pathname}`}>
  <meta property="og:title" content={fullTitle}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={ogImage}>
  <meta property="og:locale" content={lang === 'fi' ? 'fi_FI' : 'en_US'}>
  
  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/favicon.png">
  <link rel="apple-touch-icon" href="/favicon.png">

  <!-- Google Analytics (GA4) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-9Y0PEJY0XG"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-9Y0PEJY0XG');
  </script>
</head>
<body>
  <Header lang={lang} currentPath={Astro.url.pathname} />
  
  <main>
    <slot />
  </main>
  
  <Footer lang={lang} />
</body>
</html>
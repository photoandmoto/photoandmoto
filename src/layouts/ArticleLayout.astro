---
import BaseLayout from './BaseLayout.astro';
import { ui } from '../i18n/ui';

interface Props {
  frontmatter: {
    title: string;
    subtitle?: string;
    author: string;
    date: Date;
    category: string;
    tags: string[];
    featured_image: string;
    show_hero?: boolean;
    image_caption?: string;
    language: 'fi' | 'en';
    seo_description?: string;
  };
}

const { frontmatter } = Astro.props;
const t = ui[frontmatter.language];

const formattedDate = new Intl.DateTimeFormat(frontmatter.language === 'fi' ? 'fi-FI' : 'en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
}).format(frontmatter.date);
---

<BaseLayout
  title={frontmatter.title}
  description={frontmatter.seo_description || frontmatter.subtitle || frontmatter.title}
  image={frontmatter.featured_image}
  lang={frontmatter.language}
>
  <article class="article">
    <div class="container">
      <header class="article-header">
        <a href={`/${frontmatter.language}/aikakone`} class="back-link">
          {frontmatter.language === 'fi' ? '← Takaisin artikkeleihin' : '← Back to articles'}
        </a>
        
        <div class="article-meta-top">
          <span class="badge">{frontmatter.category}</span>
          <span class="meta-date">{formattedDate}</span>
        </div>
        
        <h1 class="article-title">{frontmatter.title}</h1>
        
        {frontmatter.subtitle && (
          <p class="article-subtitle">{frontmatter.subtitle}</p>
        )}
      </header>
      
      {frontmatter.featured_image && frontmatter.show_hero !== false && (
        <div class="article-hero">
          <img 
            src={frontmatter.featured_image} 
            alt={frontmatter.image_caption || frontmatter.title}
          />
          {frontmatter.image_caption && (
            <figcaption>{frontmatter.image_caption}</figcaption>
          )}
        </div>
      )}
      
      <div class="article-body">
        <slot />
      </div>
      
      <footer class="article-footer">
        <div class="author-info">
          <strong>{t['article.author']}:</strong> {frontmatter.author}
        </div>
        {frontmatter.tags.length > 0 && (
          <div class="article-tags">
            {frontmatter.tags.map(tag => (
              <span class="tag">#{tag}</span>
            ))}
          </div>
        )}
      </footer>
    </div>
  </article>
</BaseLayout>

<style>
  .article {
    padding: var(--space-6) 0;
  }
  
  .article .container {
    max-width: 1000px;
  }
  
  /* Header */
  .article-header {
    margin-bottom: var(--space-5);
  }
  
  .back-link {
    display: inline-block;
    font-family: var(--font-headline);
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--brand-primary);
    margin-bottom: var(--space-3);
  }
  
  .article-meta-top {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-2);
  }
  
  .meta-date {
    font-size: 0.9rem;
    color: var(--text-secondary);
  }
  
  .article-title {
    font-size: clamp(2rem, 5vw, 3rem);
    color: var(--text-primary);
    margin-bottom: var(--space-2);
    line-height: 1.1;
  }
  
  .article-subtitle {
    font-size: 1.25rem;
    color: #ff9900;
    font-style: italic;
    font-weight: 600;
    margin-bottom: 0;
  }
  
  /* Hero image */
  .article-hero {
    margin-bottom: var(--space-6);
    border-radius: var(--radius-md);
    overflow: hidden;
  }
  
  .article-hero img {
    width: 100%;
    height: auto;
    display: block;
  }
  
  .article-hero figcaption {
    padding: var(--space-2);
    background: var(--bg-secondary);
    font-size: 0.85rem;
    color: var(--text-secondary);
    text-align: center;
    font-style: italic;
  }
  
  /* Two-column article body */
  .article-body {
    max-width: 760px;
    margin: 0 auto;
    font-size: 1.05rem;
    line-height: 1.75;
  }
  
  /* Drop cap on first paragraph */
  .article-body :global(p:first-of-type::first-letter) {
    float: left;
    font-family: var(--font-headline);
    font-size: 4.5rem;
    line-height: 0.8;
    padding-right: 8px;
    padding-top: 6px;
    color: var(--text-primary);
    font-weight: bold;
  }
  
  .article-body :global(p) {
    margin-bottom: var(--space-3);

  }
  
  /* Headings as callout style */
  .article-body :global(h2) {
    font-family: var(--font-headline);
    font-size: 1.4rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--text-primary);
    border-left: 4px solid #ff9900;
    padding-left: var(--space-2);
    margin-top: var(--space-5);
    margin-bottom: var(--space-3);


  }
  
  .article-body :global(h3) {
    font-size: 1.2rem;
    color: var(--brand-secondary);
    margin-top: var(--space-4);
    margin-bottom: var(--space-2);


  }
  
  /* Blockquotes as callout boxes */
  .article-body :global(blockquote) {

    margin: var(--space-4) 0;
    padding: var(--space-3);
    background: var(--bg-secondary);
    border-left: 4px solid var(--brand-primary);
    font-style: italic;
    font-size: 1.1rem;
    color: var(--text-primary);
  }
  
  .article-body :global(blockquote p) {
    margin-bottom: 0;
  }
  
  /* Bold text */
  .article-body :global(strong) {
    font-weight: 700;
    color: var(--text-primary);
  }
  
  /* Emphasis / italic */
  .article-body :global(em) {
    font-style: italic;
    color: var(--text-secondary);
  }
  
  /* Images in article */
  /* Tables */
  .article-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: var(--space-4) 0;
    font-size: 0.9rem;
  }
  
  .article-body :global(thead) {
    background: #000000;
    color: white;
  }
  
  .article-body :global(th) {
    font-family: var(--font-headline);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    padding: 10px 12px;
    text-align: left;
    font-weight: 700;
  }
  
  .article-body :global(td) {
    padding: 8px 12px;
    border-bottom: 1px solid #eee;
  }
  
  .article-body :global(tr:nth-child(even)) {
    background: var(--bg-secondary);
  }
  
  .article-body :global(tr:first-child td) {
    font-weight: 700;
    color: var(--brand-primary);
  }

  .article-body :global(img) {
    width: 60%;
    max-width: 500px;
    height: auto;
    border-radius: var(--radius-md);
    margin: var(--space-4) auto;
    display: block;
  }
  
  /* Footer */
  .article-footer {
    margin-top: var(--space-6);
    padding-top: var(--space-4);
    border-top: 2px solid var(--bg-secondary);
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  
  .author-info {
    font-size: 0.95rem;
    color: var(--text-secondary);
  }
  
  .article-tags {
    display: flex;
    gap: var(--space-1);
    flex-wrap: wrap;
  }
  
  .tag {
    font-size: 0.85rem;
    color: var(--brand-primary);
    font-weight: 600;
  }
  
  /* Mobile: single column */
  @media (max-width: 768px) {
    .article-footer {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>

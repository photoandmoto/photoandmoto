---
// PhotoSwipe lightbox with download prevention
---

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/photoswipe@5.4.3/dist/photoswipe.css">

<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';
  import PhotoSwipe from 'photoswipe';
  
  const lightbox = new PhotoSwipeLightbox({
    gallery: '#gallery',
    children: 'a',
    pswpModule: PhotoSwipe,
    
    bgOpacity: 0.95,
    loop: true,
    zoom: true,
    preload: [1, 2],
    
    showHideAnimationType: 'fade',
    padding: { top: 20, bottom: 60, left: 20, right: 20 },
    
    imageClickAction: 'zoom',
    tapAction: 'close',
  });
  
  // Add caption
  lightbox.on('uiRegister', function() {
    lightbox.pswp.ui.registerElement({
      name: 'custom-caption',
      order: 9,
      isButton: false,
      appendTo: 'root',
      html: '',
      onInit: (el, pswp) => {
        el.style.cssText = 'position:absolute;bottom:10px;left:50%;transform:translateX(-50%);background:rgba(0,0,0,0.8);color:white;padding:8px 20px;border-radius:8px;font-size:14px;max-width:80%;text-align:center;pointer-events:none;';
        
        pswp.on('change', () => {
          const currSlideElement = pswp.currSlide.data.element;
          let captionHTML = '';
          if (currSlideElement) {
            const caption = currSlideElement.getAttribute('data-pswp-caption');
            if (caption) captionHTML = caption;
          }
          el.innerHTML = captionHTML || '';
          el.style.display = captionHTML ? 'block' : 'none';
        });
      }
    });
  });
  
  // Prevent download in lightbox
  lightbox.on('afterInit', () => {
    const pswpEl = document.querySelector('.pswp');
    if (pswpEl) {
      pswpEl.addEventListener('contextmenu', (e) => e.preventDefault());
      pswpEl.querySelectorAll('img').forEach(img => {
        img.setAttribute('draggable', 'false');
      });
    }
  });
  
  // Prevent drag on dynamically loaded images
  lightbox.on('change', () => {
    const pswpEl = document.querySelector('.pswp');
    if (pswpEl) {
      pswpEl.querySelectorAll('img').forEach(img => {
        img.setAttribute('draggable', 'false');
        img.style.userSelect = 'none';
        img.style.webkitUserDrag = 'none';
      });
    }
  });
  
  lightbox.init();
</script>

---
/**
 * PageHero — reusable photo-background hero for top-level pages.
 * Mirrors the design treatment of the MXGP race-hero (overlay, text-shadows, height).
 *
 * Props:
 *   image     – imported image asset (required)
 *   eyebrow   – small uppercase label above the title (optional)
 *   title     – main page title (required)
 *   subtitle  – one-line description below title (optional)
 *   alt       – image alt text (defaults to title)
 *   focus     – CSS object-position for cropping (default 'center')
 */
import { Image } from 'astro:assets';

interface Props {
  image: ImageMetadata;
  eyebrow?: string;
  title: string;
  subtitle?: string;
  alt?: string;
  focus?: string;
}

const { image, eyebrow, title, subtitle, alt, focus = 'center' } = Astro.props;
---

<div class="page-hero">
  <Image
    src={image}
    alt={alt ?? title}
    class="page-hero__img"
    style={`object-position: ${focus};`}
    widths={[768, 1280, 1920]}
    sizes="(max-width: 768px) 100vw, (max-width: 1280px) 100vw, 1920px"
    loading="eager"
  />
  <div class="page-hero__overlay"></div>
  <div class="page-hero__content">
    {eyebrow && <div class="page-hero__eyebrow">{eyebrow}</div>}
    <h1 class="page-hero__title">{title}</h1>
    {subtitle && <p class="page-hero__subtitle">{subtitle}</p>}
  </div>
</div>

<style is:global>
  .page-hero {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin-bottom: var(--space-5);
    height: 360px;
    background: #1a1a1a;
    border-left: 5px solid var(--brand-primary);
  }
  .page-hero__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .page-hero__overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(135deg, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.45) 50%, rgba(0,0,0,0.25) 100%),
      linear-gradient(to top, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0) 60%);
  }
  .page-hero__content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: var(--space-5);
    color: white;
  }
  .page-hero__eyebrow {
    font-family: var(--font-headline);
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    color: var(--brand-primary);
    margin-bottom: var(--space-1);
    text-shadow: 0 1px 3px rgba(0,0,0,0.7);
  }
  .page-hero__title {
    font-size: clamp(2rem, 5.5vw, 3.6rem);
    font-weight: 900;
    letter-spacing: -0.5px;
    margin: 0 0 var(--space-2);
    color: white;
    text-shadow: 0 2px 10px rgba(0,0,0,0.9), 0 1px 2px rgba(0,0,0,0.95);
    line-height: 1.02;
  }
  .page-hero__subtitle {
    margin: 0;
    font-size: clamp(0.95rem, 1.6vw, 1.25rem);
    font-weight: 600;
    color: rgba(255,255,255,0.95);
    text-shadow: 0 1px 4px rgba(0,0,0,0.85);
    max-width: 620px;
  }
  @media (max-width: 768px) {
    .page-hero { height: 280px; }
    .page-hero__content { padding: var(--space-4); }
    .page-hero__title { font-size: clamp(1.9rem, 7vw, 2.6rem); }
    .page-hero__subtitle { font-size: clamp(1.05rem, 3vw, 1.2rem); }
  }
</style>
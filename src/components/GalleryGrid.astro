---
interface ImageData {
  filename: string;
  caption?: string;
  width: number;
  height: number;
}

interface Props {
  images: ImageData[];
  gallerySlug: string;
}

const { images, gallerySlug } = Astro.props;

const processedImages = images.map((img, index) => ({
  href: `/galleries/${gallerySlug}/${img.filename}`,
  alt: img.caption || `Photo ${index + 1}`,
  caption: img.caption || '',
  width: img.width,
  height: img.height,
}));
---

<div class="gallery-grid" id="gallery">
  {processedImages.map((img, index) => (
    <a
      href={img.href}
      class:list={['gallery-item', { 'gallery-hidden': index >= 9 }]}
      data-pswp-width={img.width}
      data-pswp-height={img.height}
      data-pswp-caption={img.caption}
      target="_blank"
    >
      <img
        src={img.href}
        alt={img.alt}
        loading="lazy"
        class="gallery-thumb"
      />
      {img.caption && (
        <span class="gallery-caption">{img.caption}</span>
      )}
    </a>
  ))}
</div>

{processedImages.length > 9 && (
  <div class="load-more-wrapper">
    <button id="load-more-btn" class="btn" type="button">
      {`Näytä lisää (${processedImages.length - 9} kuvaa)`}
    </button>
  </div>
)}

<script>
  const btn = document.getElementById('load-more-btn');
  if (btn) {
    btn.addEventListener('click', () => {
      const hidden = document.querySelectorAll('.gallery-hidden');
      hidden.forEach(el => el.classList.remove('gallery-hidden'));
      btn.remove();
    });
  }
</script>

<style>
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-3);
    padding: var(--space-4) 0;
  }

  .gallery-item {
    position: relative;
    display: block;
    overflow: hidden;
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: transform var(--transition-base), box-shadow var(--transition-base);
    background: var(--bg-secondary);
    aspect-ratio: 4 / 3;
  }

  .gallery-hidden {
    display: none;
  }

  .gallery-item:hover {
    transform: scale(1.02);
    box-shadow: var(--shadow-lg);
  }

  .gallery-thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .gallery-caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--space-2);
    background: linear-gradient(to top, rgba(0,0,0,0.9), transparent);
    color: white;
    font-size: 0.9rem;
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .gallery-item:hover .gallery-caption {
    opacity: 1;
  }

  .load-more-wrapper {
    text-align: center;
    padding: var(--space-6) 0;
  }

  @media (max-width: 768px) {
    .gallery-grid {
      grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
      gap: var(--space-2);
    }
  }
</style>

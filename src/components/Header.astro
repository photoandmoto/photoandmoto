---
import { ui } from '../i18n/ui';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  lang: 'fi' | 'en';
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
const t = ui[lang];

const navItems = lang === 'fi' 
  ? [
      { href: '/fi', label: t['nav.home'] },
      { href: '/fi/galleria', label: t['nav.gallery'] },
      { href: '/fi/aikakone', label: t['nav.articles'] },
    ]
  : [
      { href: '/en', label: t['nav.home'] },
      { href: '/en/gallery', label: t['nav.gallery'] },
    ];

const contactItem = lang === 'fi'
  ? { href: '/fi/yhteystiedot', label: t['nav.contact'] }
  : { href: '/en/yhteystiedot', label: t['nav.contact'] };

const moreItems = lang === 'fi' 
  ? [
      { href: '/fi/mxgp-2026', label: 'MXGP 2026' },
      { href: '/fi/tilastot', label: 'Tilastot' },
      { href: '/fi/kalenteri', label: 'Kalenteri' },
      { href: '/fi/haku', label: 'AI-haku' },
      { href: '/fi/podcast', label: 'Podcast' },
    ]
  : [
      { href: '/en/mxgp-2026', label: 'MXGP 2026' },
    ];

const showMore = moreItems.length > 0;

const moreLabel = lang === 'fi' ? 'Muuta' : 'More';
const isMoreActive = moreItems.some(item => currentPath.startsWith(item.href));
---

<header class="site-header">
  <div class="container header-container">
    <a href={`/${lang}`} class="logo">
      <img src="/images/logo.png" alt="Photo & Moto" class="logo-icon" />
      <span class="logo-text">Photo & Moto</span>
    </a>
    
    <nav class="main-nav">
      <ul>
        {navItems.map(item => (
          <li>
            <a 
              href={item.href}
              class:list={['nav-link', { active: currentPath === item.href || (item.href !== `/${lang}` && currentPath.startsWith(item.href)) }]}
            >
              {item.label}
            </a>
          </li>
        ))}
        {showMore && (
        <li class="nav-dropdown">
          <button class:list={['nav-link', 'nav-drop-btn', { active: isMoreActive }]}>
            {moreLabel} <span class="drop-arrow">▾</span>
          </button>
          <div class="nav-drop-menu">
            {moreItems.map(item => (
              <a href={item.href} class:list={['nav-drop-item', { active: currentPath.startsWith(item.href) }]}>
                {item.label}
              </a>
            ))}
          </div>
        </li>
        )}
        <li>
          <a 
            href={contactItem.href}
            class:list={['nav-link', { active: currentPath === contactItem.href || currentPath.startsWith(contactItem.href) }]}
          >
            {contactItem.label}
          </a>
        </li>
      </ul>
    </nav>
    
    <LanguageSwitcher lang={lang} currentPath={currentPath} />
  </div>
</header>

<script>
  const dropdown = document.querySelector('.nav-dropdown');
  if (dropdown) {
    const btn = dropdown.querySelector('.nav-drop-btn');
    const menu = dropdown.querySelector('.nav-drop-menu');
    
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      menu.classList.toggle('nav-drop-open');
    });
    
    document.addEventListener('click', () => {
      menu.classList.remove('nav-drop-open');
    });
  }
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 1000;
    background: #000000;
    border-bottom: 1px solid rgba(255,255,255,0.1);
    backdrop-filter: blur(10px);
  }
  
  .header-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: var(--space-2);
    padding-bottom: var(--space-2);
  }
  
  .logo {
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  
  .logo-icon {
    height: 40px;
    width: auto;
  }
  
  .logo-text {
    font-family: var(--font-headline);
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--brand-primary);
    letter-spacing: 1px;
  }
  
  .main-nav ul {
    display: flex;
    gap: var(--space-4);
    list-style: none;
    margin: 0;
    padding: 0;
    align-items: center;
  }
  
  .nav-link {
    font-family: var(--font-headline);
    font-size: 0.9rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: white;
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
    transition: all var(--transition-fast);
    text-decoration: none;
  }
  
  .nav-link:hover {
    background: var(--brand-primary);
    color: black;
  }
  
  .nav-link.active {
    background: var(--brand-primary);
    color: black;
  }
  
  /* Dropdown */
  .nav-dropdown {
    position: relative;
  }
  
  .nav-drop-btn {
    background: none;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 4px;
  }
  
  .drop-arrow {
    font-size: 0.7rem;
  }
  
  .nav-drop-menu {
    display: none;
    position: absolute;
    top: 100%;
    right: 0;
    margin-top: 8px;
    background: #1a1a1a;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: var(--radius-md);
    min-width: 180px;
    padding: 6px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.4);
  }
  
  .nav-drop-open {
    display: flex;
    flex-direction: column;
  }
  
  .nav-drop-item {
    font-family: var(--font-headline);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: white;
    padding: 10px 14px;
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: all var(--transition-fast);
  }
  
  .nav-drop-item:hover {
    background: var(--brand-primary);
    color: black;
  }
  
  .nav-drop-item.active {
    color: var(--brand-primary);
  }
  
  @media (max-width: 768px) {
    .main-nav ul {
      gap: var(--space-2);
    }
    
    .nav-link {
      font-size: 0.8rem;
      padding: var(--space-1);
    }
    
    .logo-icon {
      height: 30px;
    }
    
    .logo-text {
      font-size: 1.1rem;
    }
  }
  
  @media (max-width: 640px) {
    .header-container {
      flex-wrap: wrap;
    }
    
    .main-nav {
      order: 3;
      width: 100%;
      margin-top: var(--space-2);
    }
    
    .main-nav ul {
      justify-content: space-between;
    }
  }
</style>
---
import { ui } from '../i18n/ui';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  lang: 'fi' | 'en';
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
const t = ui[lang];

const navItems = lang === 'fi' 
  ? [
      { href: '/fi', label: t['nav.home'] },
      { href: '/fi/galleria', label: t['nav.gallery'] },
      { href: '/fi/aikakone', label: t['nav.articles'] },
    ]
  : [
      { href: '/en', label: t['nav.home'] },
      { href: '/en/gallery', label: t['nav.gallery'] },
    ];

const contactItem = lang === 'fi'
  ? { href: '/fi/yhteystiedot', label: t['nav.contact'] }
  : { href: '/en/yhteystiedot', label: t['nav.contact'] };

const moreItems = lang === 'fi' 
  ? [
      { href: '/fi/mxgp-2026', label: 'MXGP 2026' },
      { href: '/fi/tilastot', label: 'Tilastot' },
      { href: '/fi/kalenteri', label: 'Kalenteri' },
      { href: '/fi/haku', label: 'AI-haku' },
      { href: '/fi/podcast', label: 'Podcast' },
    ]
  : [
      { href: '/en/mxgp-2026', label: 'MXGP 2026' },
    ];

const showMore = moreItems.length > 0;

const moreLabel = lang === 'fi' ? 'Muuta' : 'More';
const isMoreActive = moreItems.some(item => currentPath.startsWith(item.href));

// Flat list for mobile menu (in visual order: main + more + contact)
const mobileFlatItems = [
  ...navItems,
  ...moreItems,
  contactItem,
];
---

<header class="site-header">
  <div class="container header-container">
    <a href={`/${lang}`} class="logo">
      <img src="/images/logo.png" alt="Photo & Moto" class="logo-icon" />
      <span class="logo-text">Photo & Moto</span>
    </a>

    <!-- Desktop nav -->
    <nav class="main-nav desktop-nav">
      <ul>
        {navItems.map(item => (
          <li>
            <a 
              href={item.href}
              class:list={['nav-link', { active: currentPath === item.href || (item.href !== `/${lang}` && currentPath.startsWith(item.href)) }]}
            >
              {item.label}
            </a>
          </li>
        ))}
        {showMore && (
        <li class="nav-dropdown">
          <button class:list={['nav-link', 'nav-drop-btn', { active: isMoreActive }]}>
            {moreLabel} <span class="drop-arrow">▾</span>
          </button>
          <div class="nav-drop-menu">
            {moreItems.map(item => (
              <a href={item.href} class:list={['nav-drop-item', { active: currentPath.startsWith(item.href) }]}>
                {item.label}
              </a>
            ))}
          </div>
        </li>
        )}
        <li>
          <a 
            href={contactItem.href}
            class:list={['nav-link', { active: currentPath === contactItem.href || currentPath.startsWith(contactItem.href) }]}
          >
            {contactItem.label}
          </a>
        </li>
      </ul>
    </nav>

    <div class="header-right">
      <LanguageSwitcher lang={lang} currentPath={currentPath} />

      <!-- Hamburger button (mobile only) -->
      <button class="hamburger" id="hamburgerBtn" aria-label="Toggle menu" aria-expanded="false" aria-controls="mobileNav">
        <span class="hamburger-bar"></span>
        <span class="hamburger-bar"></span>
        <span class="hamburger-bar"></span>
      </button>
    </div>
  </div>

  <!-- Mobile nav panel -->
  <nav class="mobile-nav" id="mobileNav" aria-hidden="true">
    <ul>
      {mobileFlatItems.map(item => (
        <li>
          <a 
            href={item.href}
            class:list={['mobile-nav-link', { active: currentPath === item.href || (item.href !== `/${lang}` && currentPath.startsWith(item.href)) }]}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<script>
  // Desktop dropdown (Muuta)
  const dropdown = document.querySelector('.nav-dropdown');
  if (dropdown) {
    const btn = dropdown.querySelector('.nav-drop-btn');
    const menu = dropdown.querySelector('.nav-drop-menu');
    
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      menu.classList.toggle('nav-drop-open');
    });
    
    document.addEventListener('click', () => {
      menu.classList.remove('nav-drop-open');
    });
  }

  // Mobile hamburger
  const hamburgerBtn = document.getElementById('hamburgerBtn');
  const mobileNav = document.getElementById('mobileNav');
  if (hamburgerBtn && mobileNav) {
    hamburgerBtn.addEventListener('click', () => {
      const isOpen = hamburgerBtn.classList.toggle('hamburger-open');
      mobileNav.classList.toggle('mobile-nav-open', isOpen);
      hamburgerBtn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      mobileNav.setAttribute('aria-hidden', isOpen ? 'false' : 'true');
      document.body.style.overflow = isOpen ? 'hidden' : '';
    });

    // Close menu when a link is clicked
    mobileNav.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        hamburgerBtn.classList.remove('hamburger-open');
        mobileNav.classList.remove('mobile-nav-open');
        hamburgerBtn.setAttribute('aria-expanded', 'false');
        mobileNav.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      });
    });
  }
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 1000;
    background: #000000;
    border-bottom: 1px solid rgba(255,255,255,0.1);
    backdrop-filter: blur(10px);
  }
  
  .header-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: var(--space-2);
    padding-bottom: var(--space-2);
    gap: var(--space-3);
  }
  
  .logo {
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }
  
  .logo-icon {
    height: 40px;
    width: auto;
  }
  
  .logo-text {
    font-family: var(--font-headline);
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--brand-primary);
    letter-spacing: 1px;
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }
  
  .main-nav ul {
    display: flex;
    gap: var(--space-4);
    list-style: none;
    margin: 0;
    padding: 0;
    align-items: center;
  }
  
  .nav-link {
    font-family: var(--font-headline);
    font-size: 0.9rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: white;
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
    transition: all var(--transition-fast);
    text-decoration: none;
  }
  
  .nav-link:hover {
    background: var(--brand-primary);
    color: black;
  }
  
  .nav-link.active {
    background: var(--brand-primary);
    color: black;
  }
  
  /* Dropdown (desktop) */
  .nav-dropdown {
    position: relative;
  }
  
  .nav-drop-btn {
    background: none;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 4px;
  }
  
  .drop-arrow {
    font-size: 0.7rem;
  }
  
  .nav-drop-menu {
    display: none;
    position: absolute;
    top: 100%;
    right: 0;
    margin-top: 8px;
    background: #1a1a1a;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: var(--radius-md);
    min-width: 180px;
    padding: 6px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.4);
  }
  
  .nav-drop-open {
    display: flex;
    flex-direction: column;
  }
  
  .nav-drop-item {
    font-family: var(--font-headline);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: white;
    padding: 10px 14px;
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: all var(--transition-fast);
  }
  
  .nav-drop-item:hover {
    background: var(--brand-primary);
    color: black;
  }
  
  .nav-drop-item.active {
    color: var(--brand-primary);
  }

  /* Hamburger button — hidden on desktop */
  .hamburger {
    display: none;
    background: none;
    border: none;
    width: 44px;
    height: 44px;
    padding: 10px;
    cursor: pointer;
    flex-direction: column;
    justify-content: space-between;
    align-items: stretch;
  }

  .hamburger-bar {
    display: block;
    width: 100%;
    height: 3px;
    background: white;
    border-radius: 2px;
    transition: transform 0.2s ease, opacity 0.2s ease;
    transform-origin: center;
  }

  .hamburger-open .hamburger-bar:nth-child(1) {
    transform: translateY(10px) rotate(45deg);
  }
  .hamburger-open .hamburger-bar:nth-child(2) {
    opacity: 0;
  }
  .hamburger-open .hamburger-bar:nth-child(3) {
    transform: translateY(-10px) rotate(-45deg);
  }

  /* Mobile nav panel — hidden by default */
  .mobile-nav {
    display: none;
  }

  /* Mobile breakpoint */
  @media (max-width: 768px) {
    .desktop-nav {
      display: none;
    }

    .hamburger {
      display: flex;
    }

    .logo-icon {
      height: 32px;
    }

    .logo-text {
      font-size: 1.2rem;
    }

    .mobile-nav {
      display: block;
      max-height: 0;
      overflow: hidden;
      background: #000;
      border-top: 1px solid rgba(255,255,255,0.1);
      transition: max-height 0.3s ease;
    }

    .mobile-nav.mobile-nav-open {
      max-height: calc(100vh - 80px);
      overflow-y: auto;
    }

    .mobile-nav ul {
      list-style: none;
      margin: 0;
      padding: var(--space-2) 0;
      display: flex;
      flex-direction: column;
    }

    .mobile-nav-link {
      display: block;
      font-family: var(--font-headline);
      font-size: 1rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: white;
      padding: 16px var(--space-4);
      text-decoration: none;
      border-bottom: 1px solid rgba(255,255,255,0.06);
      transition: background 0.15s, color 0.15s;
    }

    .mobile-nav-link:last-child {
      border-bottom: none;
    }

    .mobile-nav-link:hover,
    .mobile-nav-link:focus {
      background: rgba(255,153,0,0.1);
    }

    .mobile-nav-link.active {
      background: var(--brand-primary);
      color: black;
    }
  }

  @media (max-width: 480px) {
    .logo-text {
      font-size: 1rem;
    }
    .logo-icon {
      height: 28px;
    }
  }
</style>
